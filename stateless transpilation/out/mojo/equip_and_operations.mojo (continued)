    fn ProcessAndSetAirSourcePlantEquipLists(inout self, state: AnyType) -> None:
        var CoolingLoadSignal: Float64 = self.Report.PrimaryPlantCoolingLoad
        var HeatingLoadSignal: Float64 = self.Report.PrimaryPlantHeatingLoad

        if self.PlantOps.AirSourcePlantCoolingOnly:
            for equipListNum in range(self.PlantOps.NumCoolingOnlyEquipLists):
                if (CoolingLoadSignal * state.constant_minusone > self.CoolingOnlyEquipList[equipListNum].RangeLowerLimit and
                    self.CoolingOnlyEquipList[equipListNum].RangeUpperLimit > CoolingLoadSignal * state.constant_minusone):
                    var NumComps: Int = self.CoolingOnlyEquipList[equipListNum].NumComps
                    for compNum in range(NumComps):
                        var this_equip: EquipListCompData = self.CoolingOnlyEquipList[equipListNum].Comp[compNum]
                        state.dataLoopNodes.Node[this_equip.SetPointNodeNum].TempSetPoint = self.Setpoint.PrimCW
                        state.dataLoopNodes.Node[state.dataPlnt.PlantLoop[this_equip.LoopNumPtr].TempSetPointNodeNum].TempSetPoint = self.Setpoint.PrimCW
                        if state.dataLoopNodes.Node[this_equip.DemandNodeNum].Temp > self.Setpoint.PrimCW:
                            state.dataPlnt.PlantLoop[this_equip.LoopNumPtr].LoopSide[this_equip.LoopSideNumPtr].Branch[this_equip.BranchNumPtr].Comp[this_equip.CompNumPtr].Available = True
                            state.dataPlnt.PlantLoop[this_equip.LoopNumPtr].LoopSide[this_equip.LoopSideNumPtr].Branch[this_equip.BranchNumPtr].Comp[this_equip.CompNumPtr].ON = True
                            state.dataPlnt.PlantLoop[this_equip.LoopNumPtr].LoopSide[this_equip.LoopSideNumPtr].Branch[this_equip.BranchNumPtr].Comp[this_equip.CompNumPtr].CurOpSchemeType = self.Type

        if self.PlantOps.AirSourcePlantHeatingOnly:
            var HWsetpt: Float64 = self.DetermineHWSetpointOARest(state)
            for equipListNum in range(self.PlantOps.NumHeatingOnlyEquipLists):
                if HeatingLoadSignal > self.HeatingOnlyEquipList[equipListNum].RangeLowerLimit and self.HeatingOnlyEquipList[equipListNum].RangeUpperLimit > HeatingLoadSignal:
                    var NumComps: Int = self.HeatingOnlyEquipList[equipListNum].NumComps
                    for compNum in range(NumComps):
                        var this_equip: EquipListCompData = self.HeatingOnlyEquipList[equipListNum].Comp[compNum]
                        state.dataLoopNodes.Node[this_equip.SetPointNodeNum].TempSetPoint = HWsetpt
                        state.dataLoopNodes.Node[state.dataPlnt.PlantLoop[this_equip.LoopNumPtr].TempSetPointNodeNum].TempSetPoint = HWsetpt
                        if state.dataLoopNodes.Node[this_equip.DemandNodeNum].Temp < HWsetpt:
                            state.dataPlnt.PlantLoop[this_equip.LoopNumPtr].LoopSide[this_equip.LoopSideNumPtr].Branch[this_equip.BranchNumPtr].Comp[this_equip.CompNumPtr].Available = True
                            state.dataPlnt.PlantLoop[this_equip.LoopNumPtr].LoopSide[this_equip.LoopSideNumPtr].Branch[this_equip.BranchNumPtr].Comp[this_equip.CompNumPtr].ON = True
                            state.dataPlnt.PlantLoop[this_equip.LoopNumPtr].LoopSide[this_equip.LoopSideNumPtr].Branch[this_equip.BranchNumPtr].Comp[this_equip.CompNumPtr].CurOpSchemeType = self.Type

        if self.PlantOps.AirSourcePlantSimultaneousHeatingAndCooling:
            for equipListNum in range(self.PlantOps.NumSimultHeatCoolCoolingEquipLists):
                if (CoolingLoadSignal * state.constant_minusone > self.SimultHeatCoolCoolingEquipList[equipListNum].RangeLowerLimit and
                    self.SimultHeatCoolCoolingEquipList[equipListNum].RangeUpperLimit > CoolingLoadSignal * state.constant_minusone):
                    var NumComps: Int = self.SimultHeatCoolCoolingEquipList[equipListNum].NumComps
                    for compNum in range(NumComps):
                        var this_equip: EquipListCompData = self.SimultHeatCoolCoolingEquipList[equipListNum].Comp[compNum]
                        state.dataLoopNodes.Node[this_equip.SetPointNodeNum].TempSetPoint = self.Setpoint.PrimCW
                        state.dataLoopNodes.Node[state.dataPlnt.PlantLoop[this_equip.LoopNumPtr].TempSetPointNodeNum].TempSetPoint = self.Setpoint.PrimCW
                        if state.dataLoopNodes.Node[this_equip.DemandNodeNum].Temp > self.Setpoint.PrimCW:
                            state.dataPlnt.PlantLoop[this_equip.LoopNumPtr].LoopSide[this_equip.LoopSideNumPtr].Branch[this_equip.BranchNumPtr].Comp[this_equip.CompNumPtr].Available = True
                            state.dataPlnt.PlantLoop[this_equip.LoopNumPtr].LoopSide[this_equip.LoopSideNumPtr].Branch[this_equip.BranchNumPtr].Comp[this_equip.CompNumPtr].ON = True
                            state.dataPlnt.PlantLoop[this_equip.LoopNumPtr].LoopSide[this_equip.LoopSideNumPtr].Branch[this_equip.BranchNumPtr].Comp[this_equip.CompNumPtr].CurOpSchemeType = self.Type

            var HWsetpt: Float64 = self.DetermineHWSetpointOARest(state)
            for equipListNum in range(self.PlantOps.NumSimultHeatCoolHeatingEquipLists):
                if HeatingLoadSignal > self.SimultHeatCoolHeatingEquipList[equipListNum].RangeLowerLimit and self.SimultHeatCoolHeatingEquipList[equipListNum].RangeUpperLimit > HeatingLoadSignal:
                    var NumComps: Int = self.SimultHeatCoolHeatingEquipList[equipListNum].NumComps
                    for compNum in range(NumComps):
                        var this_equip: EquipListCompData = self.SimultHeatCoolHeatingEquipList[equipListNum].Comp[compNum]
                        state.dataLoopNodes.Node[this_equip.SetPointNodeNum].TempSetPoint = HWsetpt
                        state.dataLoopNodes.Node[state.dataPlnt.PlantLoop[this_equip.LoopNumPtr].TempSetPointNodeNum].TempSetPoint = HWsetpt
                        if state.dataLoopNodes.Node[this_equip.DemandNodeNum].Temp < HWsetpt:
                            state.dataPlnt.PlantLoop[this_equip.LoopNumPtr].LoopSide[this_equip.LoopSideNumPtr].Branch[this_equip.BranchNumPtr].Comp[this_equip.CompNumPtr].Available = True
                            state.dataPlnt.PlantLoop[this_equip.LoopNumPtr].LoopSide[this_equip.LoopSideNumPtr].Branch[this_equip.BranchNumPtr].Comp[this_equip.CompNumPtr].ON = True
                            state.dataPlnt.PlantLoop[this_equip.LoopNumPtr].LoopSide[this_equip.LoopSideNumPtr].Branch[this_equip.BranchNumPtr].Comp[this_equip.CompNumPtr].CurOpSchemeType = self.Type

    fn ProcessAndSetDedicatedHeatRecovWWHP(inout self, state: AnyType) -> None:
        if not self.PlantOps.DedicatedHR_Present:
            return

        self.DedicatedHR_CoolingPLHP.loadSidePlantLoc.comp.Available = False
        self.DedicatedHR_CoolingPLHP.loadSidePlantLoc.comp.ON = False
        self.DedicatedHR_CoolingPLHP.sourceSidePlantLoc.comp.Available = False
        self.DedicatedHR_CoolingPLHP.sourceSidePlantLoc.comp.ON = False

        self.DedicatedHR_HeatingPLHP.loadSidePlantLoc.comp.Available = False
        self.DedicatedHR_HeatingPLHP.loadSidePlantLoc.comp.ON = False
        self.DedicatedHR_HeatingPLHP.sourceSidePlantLoc.comp.Available = False
        self.DedicatedHR_HeatingPLHP.sourceSidePlantLoc.comp.ON = False

        var inletChWReturnNodeNum: Int = self.DedicatedHR_HeatingPLHP.sourceSidePlantLoc.comp.NodeNumIn
        var inletHWReturnNodeNum: Int = self.DedicatedHR_CoolingPLHP.sourceSidePlantLoc.comp.NodeNumIn

        var CW_RetMdot: Float64 = state.dataLoopNodes.Node[inletChWReturnNodeNum].MassFlowRate
        var HW_RetMdot: Float64 = state.dataLoopNodes.Node[inletHWReturnNodeNum].MassFlowRate

        var flowInEach: Bool = False
        if CW_RetMdot <= state.HVAC_SmallWaterVolFlow or HW_RetMdot <= state.HVAC_SmallWaterVolFlow:
            flowInEach = False
        else:
            flowInEach = True

        var CpCW: Float64 = self.DedicatedHR_HeatingPLHP.sourceSidePlantLoc.loop.glycol.getSpecificHeat(
            state, state.dataLoopNodes.Node[inletChWReturnNodeNum].Temp, "EvaluateChillerHeaterChangeoverOpScheme")
        var CW_Qdot: Float64 = CW_RetMdot * CpCW * (self.Setpoint.SecCW - state.dataLoopNodes.Node[inletChWReturnNodeNum].Temp)
        var CpHW: Float64 = self.DedicatedHR_CoolingPLHP.sourceSidePlantLoc.loop.glycol.getSpecificHeat(
            state, state.dataLoopNodes.Node[inletHWReturnNodeNum].Temp, "EvaluateChillerHeaterChangeoverOpScheme")
        var HW_Qdot: Float64 = HW_RetMdot * CpHW * (self.Setpoint.SecHW - state.dataLoopNodes.Node[inletHWReturnNodeNum].Temp)

        self.Report.SecondaryPlantCoolingLoad = CW_Qdot
        self.Report.SecondaryPlantHeatingLoad = HW_Qdot

        var CoolLedNeed: Bool = False
        var HeatLedNeed: Bool = False

        if self.PlantOps.AirSourcePlantHeatingOnly and (CW_Qdot < state.constant_minusone * state.HVAC_SmallLoad) and flowInEach:
            CoolLedNeed = True

        if self.PlantOps.AirSourcePlantCoolingOnly and (HW_Qdot > state.HVAC_SmallLoad) and flowInEach:
            HeatLedNeed = True

        if self.PlantOps.AirSourcePlantSimultaneousHeatingAndCooling and self.PlantOps.SimultaneousHeatingCoolingWithHeatingDominant and flowInEach:
            HeatLedNeed = True

        if self.PlantOps.AirSourcePlantSimultaneousHeatingAndCooling and self.PlantOps.SimultaneousHeatingCoolingWithCoolingDominant and flowInEach:
            CoolLedNeed = True

        self.Report.DedicHR_OpMode = 0
        if CoolLedNeed:
            self.Report.DedicHR_OpMode = 2
            self.DedicatedHR_CoolingPLHP.loadSidePlantLoc.comp.Available = True
            self.DedicatedHR_CoolingPLHP.loadSidePlantLoc.comp.ON = True
            self.DedicatedHR_CoolingPLHP.loadSidePlantLoc.comp.CurOpSchemeType = self.Type
            self.DedicatedHR_CoolingPLHP.loadSidePlantLoc.comp.MyLoad = CW_Qdot

            var OutletChWReturnNodeNum: Int = self.DedicatedHR_CoolingPLHP.loadSidePlantLoc.comp.NodeNumOut
            state.dataLoopNodes.Node[OutletChWReturnNodeNum].TempSetPoint = self.Setpoint.SecCW
            state.dataLoopNodes.Node[self.DedicatedHR_CoolingPLHP.loadSidePlantLoc.loop.TempSetPointNodeNum].TempSetPoint = self.Setpoint.SecCW

            if self.DedicatedHR_CoolingPLHP.loadSidePlantLoc.loopNum == self.SecondaryPlantLoopIndicesBeingSupervised[self.DedicatedHR_CoolingPLHP.loadSidePlantLoc.loopNum]:
                for HXnum in range(self.PlantOps.numPlantHXs):
                    if self.PlantHXComps[HXnum].loopNum == self.DedicatedHR_CoolingPLHP.loadSidePlantLoc.loopNum:
                        var outletnode: Int = state.dataPlnt.PlantLoop[self.PlantHXComps[HXnum].loopNum].LoopSide[self.PlantHXComps[HXnum].loopSideNum].Branch[self.PlantHXComps[HXnum].branchNum].Comp[self.PlantHXComps[HXnum].compNum].NodeNumOut
                        state.dataLoopNodes.Node[outletnode].TempSetPoint = self.Setpoint.SecCW

        elif HeatLedNeed:
            self.Report.DedicHR_OpMode = 1
            self.DedicatedHR_HeatingPLHP.loadSidePlantLoc.comp.Available = True
            self.DedicatedHR_HeatingPLHP.loadSidePlantLoc.comp.ON = True
            self.DedicatedHR_HeatingPLHP.loadSidePlantLoc.comp.CurOpSchemeType = self.Type
            self.DedicatedHR_HeatingPLHP.loadSidePlantLoc.comp.MyLoad = HW_Qdot

            var OutletHWReturnNodeNum: Int = self.DedicatedHR_HeatingPLHP.loadSidePlantLoc.comp.NodeNumOut
            state.dataLoopNodes.Node[OutletHWReturnNodeNum].TempSetPoint = self.Setpoint.SecHW
            state.dataLoopNodes.Node[self.DedicatedHR_HeatingPLHP.loadSidePlantLoc.loop.TempSetPointNodeNum].TempSetPoint = self.Setpoint.SecHW

            if self.DedicatedHR_HeatingPLHP.loadSidePlantLoc.loopNum == self.SecondaryPlantLoopIndicesBeingSupervised[self.DedicatedHR_HeatingPLHP.loadSidePlantLoc.loopNum]:
                for HXnum in range(self.PlantOps.numPlantHXs):
                    if self.PlantHXComps[HXnum].loopNum == self.DedicatedHR_HeatingPLHP.loadSidePlantLoc.loopNum:
                        var outletnode: Int = self.PlantHXComps[HXnum].comp.NodeNumOut
                        state.dataLoopNodes.Node[outletnode].TempSetPoint = min(self.Setpoint.SecHW, self.DetermineHWSetpointOARest(state))

    fn ProcessAndSetAuxilBoiler(inout self, state: AnyType) -> None:
        self.Report.BoilerAux_OpMode = 0
        if self.PlantOps.numBoilers <= 0:
            return

        if self.PlantOps.numBoilers > 0:
            for BoilerNum in range(self.PlantOps.numBoilers):
                self.PlantBoilerComps[BoilerNum].comp.Available = False
                self.PlantBoilerComps[BoilerNum].comp.ON = False
                self.PlantBoilerComps[BoilerNum].comp.MyLoad = 0.0

        if self.PlantOps.numBoilers > 0:
            var LowOAAuxiliaryNeeded: Bool = False
            if state.dataEnvrn.OutDryBulbTemp < self.TempReset.LowOutdoorTemp:
                LowOAAuxiliaryNeeded = True
            for BoilerNum in range(self.PlantOps.numBoilers):
                var HWsetpt: Float64 = 0.0
                if self.SecondaryPlantLoopIndicesBeingSupervised[self.PlantBoilerComps[BoilerNum].loopNum] > 0:
                    HWsetpt = min(self.Setpoint.SecHW, self.DetermineHWSetpointOARest(state))
                else:
                    HWsetpt = self.DetermineHWSetpointOARest(state)

                HWsetpt = HWsetpt - self.TempReset.BoilerTemperatureOffset

                var inletBoilerNodeNum: Int = self.PlantBoilerComps[BoilerNum].comp.NodeNumIn
                var Tin: Float64 = state.dataLoopNodes.Node[inletBoilerNodeNum].Temp
                var Mdot: Float64 = state.dataLoopNodes.Node[inletBoilerNodeNum].MassFlowRate

                var CpHW: Float64 = self.PlantBoilerComps[BoilerNum].loop.glycol.getSpecificHeat(
                    state, Tin, "ChillerHeaterSupervisoryOperationData::ProcessAndSetAuxilBoiler")
                var LoadToSetpoint: Float64 = max(0.0, Mdot * CpHW * (HWsetpt - Tin))
                var pltSizNum: Int = self.PlantBoilerComps[BoilerNum].loop.PlantSizNum
                var thresholdPlantLoad: Float64 = 0.001 * state.dataSize.PlantSizData[pltSizNum].DesCapacity

                if ((LoadToSetpoint > thresholdPlantLoad and
                     ((self.Report.AirSourcePlant_OpMode == 0) or LowOAAuxiliaryNeeded)) or
                    ((LoadToSetpoint > thresholdPlantLoad) and (self.Report.AirSourcePlant_OpMode == 2))):
                    self.PlantBoilerComps[BoilerNum].comp.Available = True
                    self.PlantBoilerComps[BoilerNum].comp.ON = True
                    self.PlantBoilerComps[BoilerNum].comp.CurOpSchemeType = self.Type
                    self.PlantBoilerComps[BoilerNum].comp.MyLoad = LoadToSetpoint
                    var OutletBoilerNodeNum: Int = self.PlantBoilerComps[BoilerNum].comp.NodeNumOut
                    state.dataLoopNodes.Node[OutletBoilerNodeNum].TempSetPoint = HWsetpt
                    state.dataLoopNodes.Node[self.PlantBoilerComps[BoilerNum].loop.TempSetPointNodeNum].TempSetPoint = HWsetpt
                    self.Report.BoilerAux_OpMode = 1
                else:
                    var OutletBoilerNodeNum: Int = self.PlantBoilerComps[BoilerNum].comp.NodeNumOut
                    state.dataLoopNodes.Node[OutletBoilerNodeNum].TempSetPoint = HWsetpt
                    state.dataLoopNodes.Node[self.PlantBoilerComps[BoilerNum].loop.TempSetPointNodeNum].TempSetPoint = HWsetpt

    fn DetermineHWSetpointOARest(self, state: AnyType) -> Float64:
        var HWSetpoint: Float64 = 0.0

        if ((self.TempReset.LowOutdoorTemp == self.TempReset.BackupLowOutdoorTemp) and
            (self.Setpoint.PrimHW_Low == self.Setpoint.PrimHW_BackupLow)):

            if self.TempReset.LowOutdoorTemp < self.TempReset.HighOutdoorTemp:
                if state.dataEnvrn.OutDryBulbTemp <= self.TempReset.LowOutdoorTemp:
                    HWSetpoint = self.Setpoint.PrimHW_Low
                elif state.dataEnvrn.OutDryBulbTemp >= self.TempReset.HighOutdoorTemp:
                    HWSetpoint = self.Setpoint.PrimHW_High
                else:
                    HWSetpoint = self.Setpoint.PrimHW_Low - ((state.dataEnvrn.OutDryBulbTemp - self.TempReset.LowOutdoorTemp) /
                                                              (self.TempReset.HighOutdoorTemp - self.TempReset.LowOutdoorTemp)) *\
                                                                 (self.Setpoint.PrimHW_Low - self.Setpoint.PrimHW_High)
                    HWSetpoint = min(HWSetpoint, self.Setpoint.PrimHW_High)

            else:
                HWSetpoint = 0.5 * (self.Setpoint.PrimHW_Low + self.Setpoint.PrimHW_High)
        else:
            if ((self.TempReset.LowOutdoorTemp < self.TempReset.HighOutdoorTemp) and
                (self.TempReset.BackupLowOutdoorTemp < self.TempReset.LowOutdoorTemp)):

                if state.dataEnvrn.OutDryBulbTemp <= self.TempReset.BackupLowOutdoorTemp:
                    HWSetpoint = self.Setpoint.PrimHW_BackupLow
                elif state.dataEnvrn.OutDryBulbTemp >= self.TempReset.HighOutdoorTemp:
                    HWSetpoint = self.Setpoint.PrimHW_High
                elif ((state.dataEnvrn.OutDryBulbTemp >= self.TempReset.LowOutdoorTemp) and
                      (state.dataEnvrn.OutDryBulbTemp < self.TempReset.HighOutdoorTemp)):
                    HWSetpoint = self.Setpoint.PrimHW_Low - ((state.dataEnvrn.OutDryBulbTemp - self.TempReset.LowOutdoorTemp) /
                                                              (self.TempReset.HighOutdoorTemp - self.TempReset.LowOutdoorTemp)) *\
                                                                 (self.Setpoint.PrimHW_Low - self.Setpoint.PrimHW_High)
                    HWSetpoint = min(HWSetpoint, self.Setpoint.PrimHW_High)
                elif ((state.dataEnvrn.OutDryBulbTemp > self.TempReset.BackupLowOutdoorTemp) and
                      (state.dataEnvrn.OutDryBulbTemp < self.TempReset.LowOutdoorTemp)):
                    HWSetpoint = self.Setpoint.PrimHW_BackupLow - ((state.dataEnvrn.OutDryBulbTemp - self.TempReset.BackupLowOutdoorTemp) /
                                                                    (self.TempReset.LowOutdoorTemp - self.TempReset.BackupLowOutdoorTemp)) *\
                                                                       (self.Setpoint.PrimHW_BackupLow - self.Setpoint.PrimHW_Low)
                    HWSetpoint = min(HWSetpoint, self.Setpoint.PrimHW_BackupLow)
                    HWSetpoint = max(HWSetpoint, self.Setpoint.PrimHW_Low)
            else:
                HWSetpoint = (self.Setpoint.PrimHW_Low + self.Setpoint.PrimHW_High + self.Setpoint.PrimHW_BackupLow) / 3.0
        return HWSetpoint


