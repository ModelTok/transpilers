    fn EvaluateChillerHeaterChangeoverOpScheme(inout self, state: AnyType) -> None:
        self.DetermineCurrentBuildingLoads(state)
        self.DetermineCurrentPlantLoads(state)
        self.ProcessSupervisoryControlLogicForAirSourcePlants(state)
        self.InitAirSourcePlantEquipmentOff(state)
        self.ProcessAndSetAirSourcePlantEquipLists(state)
        self.ProcessAndSetDedicatedHeatRecovWWHP(state)
        self.ProcessAndSetAuxilBoiler(state)

    fn DetermineCurrentBuildingLoads(inout self, state: AnyType) -> None:
        var sumZonePredictedHeatingLoad: Float64 = 0.0
        var sumZonePredictedCoolingLoad: Float64 = 0.0
        for zoneIndexinList in range(self.PlantOps.NumOfZones):
            var thisZoneIndex: Int = self.ZonePtrs[zoneIndexinList]
            var ZoneMult: Float64 = state.dataHeatBal.Zone[thisZoneIndex].Multiplier * state.dataHeatBal.Zone[thisZoneIndex].ListMultiplier
            sumZonePredictedCoolingLoad += min(0.0, state.dataZoneEnergyDemand.ZoneSysEnergyDemand[thisZoneIndex].OutputRequiredToCoolingSP * ZoneMult)
            sumZonePredictedHeatingLoad += max(0.0, state.dataZoneEnergyDemand.ZoneSysEnergyDemand[thisZoneIndex].OutputRequiredToHeatingSP * ZoneMult)

        var sumAirSysVentHeatingLoad: Float64 = 0.0
        var sumAirSysVentCoolingLoad: Float64 = 0.0

        for airLoopsServedIndex in range(self.PlantOps.NumOfAirLoops):
            var AirLoopNum: Int = self.AirLoopPtrs[airLoopsServedIndex]
            var outAir_H: Float64 = state.dataEnvrn.OutEnthalpy
            var outAirMdot: Float64 = state.dataAirLoop.AirLoopFlow[AirLoopNum].OAFlow
            var retAir_Tdb: Float64 = state.dataLoopNodes.Node[state.dataAirLoop.AirToZoneNodeInfo[AirLoopNum].AirLoopReturnNodeNum[0]].Temp
            var retAir_w: Float64 = state.dataLoopNodes.Node[state.dataAirLoop.AirToZoneNodeInfo[AirLoopNum].AirLoopReturnNodeNum[0]].HumRat
            var ventLoad: Float64 = outAirMdot * (state.Psychrometrics_PsyHFnTdbW(retAir_Tdb, retAir_w) - outAir_H)
            if ventLoad > state.HVAC_SmallLoad:
                sumAirSysVentHeatingLoad += ventLoad
            elif ventLoad < state.constant_minusone * state.HVAC_SmallLoad:
                sumAirSysVentCoolingLoad += ventLoad

        var sumLoadProfileHeatingLoad: Float64 = 0.0
        var sumLoadProfileCoolingLoad: Float64 = 0.0
        for NumProcLoad in range(self.PlantOps.numPlantLoadProfiles):
            var load: Float64 = 0.0
            var comp: AnyType = state.CompData_getPlantComponent(state, self.PlantLoadProfileComps[NumProcLoad]).compPtr
            comp.getCurrentPower(state, load)
            if load > 0.0:
                sumLoadProfileHeatingLoad += load
            else:
                sumLoadProfileCoolingLoad += load

        self.Report.BuildingPolledCoolingLoad = sumZonePredictedCoolingLoad + sumAirSysVentCoolingLoad + sumLoadProfileCoolingLoad
        self.Report.BuildingPolledHeatingLoad = sumZonePredictedHeatingLoad + sumAirSysVentHeatingLoad + sumLoadProfileHeatingLoad

    fn DetermineCurrentPlantLoads(inout self, state: AnyType) -> None:
        var CW_RetMdot: Float64 = state.dataLoopNodes.Node[self.PlantOps.PrimaryChWLoopSupInletNode].MassFlowRate
        var CpCW: Float64 = state.dataPlnt.PlantLoop[self.PlantOps.PrimaryChWLoopIndex].glycol.getSpecificHeat(
            state, state.dataLoopNodes.Node[self.PlantOps.PrimaryChWLoopSupInletNode].Temp, "DetermineCurrentPlantLoads")
        var CW_Qdot: Float64 = min(0.0, CW_RetMdot * CpCW * (self.Setpoint.PrimCW - state.dataLoopNodes.Node[self.PlantOps.PrimaryChWLoopSupInletNode].Temp))
        self.Report.PrimaryPlantCoolingLoad = CW_Qdot

        var HW_RetMdot: Float64 = state.dataLoopNodes.Node[self.PlantOps.PrimaryHWLoopSupInletNode].MassFlowRate
        var CpHW: Float64 = state.dataPlnt.PlantLoop[self.PlantOps.PrimaryHWLoopIndex].glycol.getSpecificHeat(
            state, state.dataLoopNodes.Node[self.PlantOps.PrimaryHWLoopSupInletNode].Temp, "DetermineCurrentPlantLoads")
        var HW_Qdot: Float64 = max(0.0, HW_RetMdot * CpHW * (self.DetermineHWSetpointOARest(state) - state.dataLoopNodes.Node[self.PlantOps.PrimaryHWLoopSupInletNode].Temp))
        self.Report.PrimaryPlantHeatingLoad = HW_Qdot

    fn ProcessSupervisoryControlLogicForAirSourcePlants(inout self, state: AnyType) -> None:
        self.PlantOps.AirSourcePlantCoolingOnly = False
        self.PlantOps.AirSourcePlantHeatingOnly = False
        self.PlantOps.AirSourcePlantSimultaneousHeatingAndCooling = False
        self.PlantOps.SimultaneousHeatingCoolingWithCoolingDominant = False
        self.PlantOps.SimultaneousHeatingCoolingWithHeatingDominant = False

        if self.Report.BuildingPolledHeatingLoad < state.HVAC_SmallLoad and self.Report.BuildingPolledCoolingLoad < state.constant_minusone * state.HVAC_SmallLoad:
            self.PlantOps.AirSourcePlantCoolingOnly = True
        elif self.Report.BuildingPolledCoolingLoad > state.constant_minusone * state.HVAC_SmallLoad and self.Report.BuildingPolledHeatingLoad > state.HVAC_SmallLoad:
            self.PlantOps.AirSourcePlantHeatingOnly = True
            if state.dataEnvrn.OutDryBulbTemp < self.TempReset.LowOutdoorTemp:
                self.PlantOps.AirSourcePlantHeatingOnly = False
        elif self.Report.BuildingPolledCoolingLoad < state.constant_minusone * state.HVAC_SmallLoad and self.Report.BuildingPolledHeatingLoad > state.HVAC_SmallLoad:
            self.PlantOps.AirSourcePlantSimultaneousHeatingAndCooling = True
            if self.Report.BuildingPolledHeatingLoad > abs(self.Report.BuildingPolledCoolingLoad):
                self.PlantOps.SimultaneousHeatingCoolingWithHeatingDominant = True
                if self.PlantOps.SimultHeatCoolOpAvailable:
                    self.PlantOps.AirSourcePlantSimultaneousHeatingAndCooling = True
                else:
                    self.PlantOps.AirSourcePlantHeatingOnly = True
                    self.PlantOps.AirSourcePlantSimultaneousHeatingAndCooling = False
            elif abs(self.Report.BuildingPolledCoolingLoad) > self.Report.BuildingPolledHeatingLoad:
                self.PlantOps.SimultaneousHeatingCoolingWithCoolingDominant = True
                if self.PlantOps.SimultHeatCoolOpAvailable:
                    self.PlantOps.AirSourcePlantSimultaneousHeatingAndCooling = True
                else:
                    self.PlantOps.AirSourcePlantCoolingOnly = True
                    self.PlantOps.AirSourcePlantSimultaneousHeatingAndCooling = False
            if state.dataEnvrn.OutDryBulbTemp < self.TempReset.LowOutdoorTemp:
                self.PlantOps.AirSourcePlantSimultaneousHeatingAndCooling = False
                self.PlantOps.AirSourcePlantCoolingOnly = True

        if self.PlantOps.AirSourcePlantHeatingOnly and self.Report.PrimaryPlantCoolingLoad < state.constant_minusone * state.HVAC_SmallLoad:
            if self.PlantOps.SimultHeatCoolOpAvailable:
                self.PlantOps.AirSourcePlantSimultaneousHeatingAndCooling = True
                self.PlantOps.SimultaneousHeatingCoolingWithHeatingDominant = True
                self.PlantOps.AirSourcePlantHeatingOnly = False

        if self.PlantOps.AirSourcePlantCoolingOnly and self.Report.PrimaryPlantHeatingLoad > state.HVAC_SmallLoad and state.dataEnvrn.OutDryBulbTemp >= self.TempReset.LowOutdoorTemp:
            if self.PlantOps.SimultHeatCoolOpAvailable:
                self.PlantOps.AirSourcePlantSimultaneousHeatingAndCooling = True
                self.PlantOps.SimultaneousHeatingCoolingWithCoolingDominant = True
                self.PlantOps.AirSourcePlantCoolingOnly = False

        if not self.PlantOps.AirSourcePlantCoolingOnly and not self.PlantOps.AirSourcePlantHeatingOnly and not self.PlantOps.AirSourcePlantSimultaneousHeatingAndCooling:
            if self.Report.PrimaryPlantCoolingLoad < state.constant_minusone * state.HVAC_SmallLoad:
                self.PlantOps.AirSourcePlantCoolingOnly = True

        if not self.PlantOps.AirSourcePlantCoolingOnly and self.PlantOps.AirSourcePlantHeatingOnly and not self.PlantOps.AirSourcePlantSimultaneousHeatingAndCooling:
            if abs(self.Report.PrimaryPlantCoolingLoad) > self.Report.PrimaryPlantHeatingLoad and self.Report.PrimaryPlantHeatingLoad < state.HVAC_SmallLoad:
                self.PlantOps.AirSourcePlantCoolingOnly = True
                self.PlantOps.AirSourcePlantHeatingOnly = False

        if self.PlantOps.AirSourcePlantCoolingOnly and not self.PlantOps.AirSourcePlantHeatingOnly and not self.PlantOps.AirSourcePlantSimultaneousHeatingAndCooling:
            if self.Report.PrimaryPlantHeatingLoad > abs(self.Report.PrimaryPlantCoolingLoad) and self.Report.PrimaryPlantCoolingLoad > state.constant_minusone * state.HVAC_SmallLoad:
                self.PlantOps.AirSourcePlantHeatingOnly = True
                self.PlantOps.AirSourcePlantCoolingOnly = False

        if not self.PlantOps.AirSourcePlantCoolingOnly and not self.PlantOps.AirSourcePlantHeatingOnly and not self.PlantOps.AirSourcePlantSimultaneousHeatingAndCooling:
            if self.Report.PrimaryPlantHeatingLoad > state.HVAC_SmallLoad and state.dataEnvrn.OutDryBulbTemp >= self.TempReset.LowOutdoorTemp:
                self.PlantOps.AirSourcePlantHeatingOnly = True

        if self.PlantOps.AirSourcePlantHeatingOnly:
            self.Report.AirSourcePlant_OpMode = 1
        elif self.PlantOps.AirSourcePlantCoolingOnly:
            self.Report.AirSourcePlant_OpMode = 2
        elif self.PlantOps.AirSourcePlantSimultaneousHeatingAndCooling:
            self.Report.AirSourcePlant_OpMode = 3
        else:
            self.Report.AirSourcePlant_OpMode = 0

