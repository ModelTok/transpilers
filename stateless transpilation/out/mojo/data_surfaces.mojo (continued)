fn azimuth_to_compass4(azimuth: Float64) -> Int:
    debug_assert(azimuth >= 0.0 and azimuth < 360.0)
    var compass4_azimuth_lo = InlineArray[Float64, 4](315.0, 45.0, 135.0, 225.0)
    var compass4_azimuth_hi = InlineArray[Float64, 4](45.0, 135.0, 225.0, 315.0)
    
    for c4 in range(int(Compass4Num)):
        var lo = compass4_azimuth_lo[c4]
        var hi = compass4_azimuth_hi[c4]
        if lo > hi:
            if azimuth >= lo or azimuth < hi:
                return c4
        else:
            if azimuth >= lo and azimuth < hi:
                return c4
    debug_assert(False)
    return Compass4Invalid

fn azimuth_to_compass8(azimuth: Float64) -> Int:
    debug_assert(azimuth >= 0.0 and azimuth < 360.0)
    var compass8_azimuth_lo = InlineArray[Float64, 8](337.5, 22.5, 67.5, 112.5, 157.5, 202.5, 247.5, 292.5)
    var compass8_azimuth_hi = InlineArray[Float64, 8](22.5, 67.5, 112.5, 157.5, 202.5, 247.5, 292.5, 337.5)
    
    for c8 in range(int(Compass8Num)):
        var lo = compass8_azimuth_lo[c8]
        var hi = compass8_azimuth_hi[c8]
        if lo > hi:
            if azimuth >= lo or azimuth < hi:
                return c8
        else:
            if azimuth >= lo and azimuth < hi:
                return c8
    debug_assert(False)
    return Compass8Invalid

