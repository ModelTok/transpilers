fn not_shaded(shading_flag: Int) -> Bool:
    return shading_flag == WinShadingTypeNoShade or shading_flag == WinShadingTypeShadeOff

fn is_shaded(shading_flag: Int) -> Bool:
    return not not_shaded(shading_flag)

fn is_shaded_no_glare_ctrl(shading_flag: Int) -> Bool:
    return (shading_flag == WinShadingTypeIntShade or 
            shading_flag == WinShadingTypeSwitchableGlazing or
            shading_flag == WinShadingTypeExtShade or 
            shading_flag == WinShadingTypeExtScreen or 
            shading_flag == WinShadingTypeIntBlind or
            shading_flag == WinShadingTypeExtBlind or 
            shading_flag == WinShadingTypeBGShade or 
            shading_flag == WinShadingTypeBGBlind)

fn any_shade(shading_flag: Int) -> Bool:
    return (shading_flag == WinShadingTypeIntShade or 
            shading_flag == WinShadingTypeExtShade or 
            shading_flag == WinShadingTypeBGShade)

fn any_shade_screen(shading_flag: Int) -> Bool:
    return (shading_flag == WinShadingTypeIntShade or 
            shading_flag == WinShadingTypeExtShade or 
            shading_flag == WinShadingTypeBGShade or
            shading_flag == WinShadingTypeExtScreen)

fn any_blind(shading_flag: Int) -> Bool:
    return (shading_flag == WinShadingTypeIntBlind or 
            shading_flag == WinShadingTypeExtBlind or 
            shading_flag == WinShadingTypeBGBlind)

fn any_interior_shade_blind(shading_flag: Int) -> Bool:
    return (shading_flag == WinShadingTypeIntShade or 
            shading_flag == WinShadingTypeIntBlind)

fn any_exterior_shade_blind_screen(shading_flag: Int) -> Bool:
    return (shading_flag == WinShadingTypeExtShade or 
            shading_flag == WinShadingTypeExtBlind or 
            shading_flag == WinShadingTypeExtScreen)

fn any_betweenglass_shade_blind(shading_flag: Int) -> Bool:
    return (shading_flag == WinShadingTypeBGShade or 
            shading_flag == WinShadingTypeBGBlind)

