fn GetAirMassFlowRateIHP(state: Any, DXCoilNum: Int32, SpeedNum: Int32, SpeedRatio: Float64, IsCallbyWH: Bool) -> Float64:
    """Get air mass flow rate."""
    var ihp = _get_ihp_ref(state, DXCoilNum)
    
    if not ihp.IHPCoilsSized:
