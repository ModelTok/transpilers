    if ihp.CurMode == IHPOperationMode.Idle or ihp.CurMode == IHPOperationMode.SpaceClg or ihp.CurMode == IHPOperationMode.SpaceHtg or ihp.CurMode == IHPOperationMode.DedicatedWaterHtg:
