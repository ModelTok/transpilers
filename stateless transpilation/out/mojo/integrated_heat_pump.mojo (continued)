    if ihp.CurMode == IHPOperationMode.Idle:
        IHPCoilIndex = ihp.SCCoilIndex
        AirMassFlowRate = 0.0
    elif ihp.CurMode == IHPOperationMode.SpaceClg:
        IHPCoilIndex = ihp.SCCoilIndex
        if not IsCallbyWH:
            FlowScale = ihp.CoolVolFlowScale
        else:
            IsResultFlow = True
            AirMassFlowRate = ihp.AirFlowSavInAirLoop
    elif ihp.CurMode == IHPOperationMode.SpaceHtg:
        IHPCoilIndex = ihp.SHCoilIndex
        if not IsCallbyWH:
            FlowScale = ihp.HeatVolFlowScale
        else:
            IsResultFlow = True
            AirMassFlowRate = ihp.AirFlowSavInAirLoop
    elif ihp.CurMode == IHPOperationMode.DedicatedWaterHtg:
        IHPCoilIndex = ihp.DWHCoilIndex
        FlowScale = 1.0
    elif ihp.CurMode == IHPOperationMode.SCWHMatchSC:
        IHPCoilIndex = ihp.SCWHCoilIndex
        FlowScale = ihp.CoolVolFlowScale
        _set_node_mass_flow_rate(state, ihp.WaterInletNodeNum, GetWaterVolFlowRateIHP(state, DXCoilNum, SpeedNum, SpeedRatio) * WaterDensity)
        if IsCallbyWH:
            IsResultFlow = True
            AirMassFlowRate = ihp.AirFlowSavInAirLoop
    elif ihp.CurMode == IHPOperationMode.SCWHMatchWH:
        IHPCoilIndex = ihp.SCWHCoilIndex
        FlowScale = ihp.CoolVolFlowScale
        if not IsCallbyWH:
            IsResultFlow = True
            AirMassFlowRate = ihp.AirFlowSavInWaterLoop
    elif ihp.CurMode == IHPOperationMode.SpaceClgDedicatedWaterHtg:
        IHPCoilIndex = ihp.SCDWHCoolCoilIndex
        FlowScale = ihp.CoolVolFlowScale
        _set_node_mass_flow_rate(state, ihp.WaterInletNodeNum, GetWaterVolFlowRateIHP(state, DXCoilNum, SpeedNum, SpeedRatio) * WaterDensity)
        if IsCallbyWH:
            IsResultFlow = True
            AirMassFlowRate = ihp.AirFlowSavInAirLoop
    elif ihp.CurMode == IHPOperationMode.SHDWHElecHeatOff or ihp.CurMode == IHPOperationMode.SHDWHElecHeatOn:
        IHPCoilIndex = ihp.SHDWHHeatCoilIndex
        FlowScale = ihp.HeatVolFlowScale
        _set_node_mass_flow_rate(state, ihp.WaterInletNodeNum, GetWaterVolFlowRateIHP(state, DXCoilNum, SpeedNum, SpeedRatio) * WaterDensity)
        if IsCallbyWH:
            IsResultFlow = True
            AirMassFlowRate = ihp.AirFlowSavInAirLoop
    else:
        IHPCoilIndex = ihp.SCCoilIndex
        FlowScale = 0.0
    
    if not IsResultFlow:
        if SpeedNum == 1:
            AirMassFlowRate = _get_coil_rated_value(state, IHPCoilIndex, "MSRatedAirMassFlowRate", SpeedNum)
        else:
            AirMassFlowRate = (SpeedRatio * _get_coil_rated_value(state, IHPCoilIndex, "MSRatedAirMassFlowRate", SpeedNum) +
                              (1.0 - SpeedRatio) * _get_coil_rated_value(state, IHPCoilIndex, "MSRatedAirMassFlowRate", SpeedNum - 1))
        
        AirMassFlowRate = AirMassFlowRate * FlowScale
    
    if AirMassFlowRate > ihp.MaxCoolAirMassFlow:
        AirMassFlowRate = ihp.MaxCoolAirMassFlow
    if AirMassFlowRate > ihp.MaxHeatAirMassFlow:
        AirMassFlowRate = ihp.MaxHeatAirMassFlow
    
    _set_node_mass_flow_rate_max(state, ihp.AirCoolInletNodeNum, AirMassFlowRate)
    _set_node_mass_flow_rate_max(state, ihp.AirHeatInletNodeNum, AirMassFlowRate)
    _set_node_mass_flow_rate_max(state, ihp.AirOutletNodeNum, AirMassFlowRate)
    
    return AirMassFlowRate


