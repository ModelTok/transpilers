fn GetAirVolFlowRateIHP(state: Any, DXCoilNum: Int32, SpeedNum: Int32, SpeedRatio: Float64, IsCallbyWH: Bool) -> Float64:
    """Get air volume flow rate."""
    var ihp = _get_ihp_ref(state, DXCoilNum)
    
    if not ihp.IHPCoilsSized:
        SizeIHP(state, DXCoilNum)
    
    var IHPCoilIndex: Int32 = 0
    var AirVolFlowRate: Float64 = 0.0
    var FlowScale: Float64 = 0.0
    var IsResultFlow: Bool = False
    
    if ihp.CurMode == IHPOperationMode.Idle:
        IHPCoilIndex = ihp.SCCoilIndex
    elif ihp.CurMode == IHPOperationMode.SpaceClg:
        IHPCoilIndex = ihp.SCCoilIndex
        if not IsCallbyWH:
            FlowScale = ihp.CoolVolFlowScale
    elif ihp.CurMode == IHPOperationMode.SpaceHtg:
        IHPCoilIndex = ihp.SHCoilIndex
        if not IsCallbyWH:
            FlowScale = ihp.HeatVolFlowScale
    elif ihp.CurMode == IHPOperationMode.DedicatedWaterHtg:
        IHPCoilIndex = ihp.DWHCoilIndex
        FlowScale = 1.0
    elif ihp.CurMode == IHPOperationMode.SCWHMatchSC:
        IHPCoilIndex = ihp.SCWHCoilIndex
        FlowScale = ihp.CoolVolFlowScale
        if IsCallbyWH:
            IsResultFlow = True
            AirVolFlowRate = _get_coil_value(state, ihp.SCWHCoilIndex, "AirVolFlowRate")
    elif ihp.CurMode == IHPOperationMode.SCWHMatchWH:
        IHPCoilIndex = ihp.SCWHCoilIndex
        FlowScale = ihp.CoolVolFlowScale
        if not IsCallbyWH:
            IsResultFlow = True
            AirVolFlowRate = _get_coil_value(state, ihp.SCWHCoilIndex, "AirVolFlowRate")
    elif ihp.CurMode == IHPOperationMode.SpaceClgDedicatedWaterHtg:
        IHPCoilIndex = ihp.SCDWHCoolCoilIndex
        FlowScale = ihp.CoolVolFlowScale
        if IsCallbyWH:
            IsResultFlow = True
            AirVolFlowRate = _get_coil_value(state, ihp.SCDWHCoolCoilIndex, "AirVolFlowRate")
    elif ihp.CurMode == IHPOperationMode.SHDWHElecHeatOff or ihp.CurMode == IHPOperationMode.SHDWHElecHeatOn:
        IHPCoilIndex = ihp.SHDWHHeatCoilIndex
        FlowScale = ihp.HeatVolFlowScale
        if IsCallbyWH:
            IsResultFlow = True
            AirVolFlowRate = _get_coil_value(state, ihp.SHDWHHeatCoilIndex, "AirVolFlowRate")
    else:
        IHPCoilIndex = ihp.SCCoilIndex
        FlowScale = 0.0
    
    if not IsResultFlow:
        if SpeedNum == 1:
            AirVolFlowRate = _get_coil_rated_value(state, IHPCoilIndex, "MSRatedAirVolFlowRate", SpeedNum)
        else:
            AirVolFlowRate = (SpeedRatio * _get_coil_rated_value(state, IHPCoilIndex, "MSRatedAirVolFlowRate", SpeedNum) +
                             (1.0 - SpeedRatio) * _get_coil_rated_value(state, IHPCoilIndex, "MSRatedAirVolFlowRate", SpeedNum - 1))
        
        AirVolFlowRate = AirVolFlowRate * FlowScale
    
    if AirVolFlowRate > ihp.MaxCoolAirVolFlow:
        AirVolFlowRate = ihp.MaxCoolAirVolFlow
    if AirVolFlowRate > ihp.MaxHeatAirVolFlow:
        AirVolFlowRate = ihp.MaxHeatAirVolFlow
    
    return AirVolFlowRate


