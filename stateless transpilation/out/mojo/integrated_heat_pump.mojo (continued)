fn UpdateIHP(state: Any, DXCoilNum: Int32):
    """Update IHP."""
    var time_step_sys_sec: Float64 = _get_time_step_sys_sec(state)
    var ihp = _get_ihp_ref(state, DXCoilNum)
    
    if ihp.CurMode == IHPOperationMode.SpaceClg:
        ihp.TotalCoolingRate = _get_coil_value(state, ihp.SCCoilIndex, "QLoadTotal")
        ihp.TotalWaterHeatingRate = 0.0
        ihp.TotalSpaceHeatingRate = 0.0
        ihp.TotalPower = _get_coil_value(state, ihp.SCCoilIndex, "Power")
        ihp.TotalLatentLoad = _get_coil_value(state, ihp.SCCoilIndex, "QLatent")
        ihp.Qsource = _get_coil_value(state, ihp.SCCoilIndex, "QSource")
    elif ihp.CurMode == IHPOperationMode.SpaceHtg:
        ihp.TotalCoolingRate = 0.0
        ihp.TotalWaterHeatingRate = 0.0
        ihp.TotalSpaceHeatingRate = _get_coil_value(state, ihp.SHCoilIndex, "QLoadTotal")
        ihp.TotalPower = _get_coil_value(state, ihp.SHCoilIndex, "Power")
        ihp.TotalLatentLoad = 0.0
        ihp.Qsource = _get_coil_value(state, ihp.SHCoilIndex, "QSource")
    elif ihp.CurMode == IHPOperationMode.DedicatedWaterHtg:
        ihp.TotalCoolingRate = 0.0
        ihp.TotalWaterHeatingRate = _get_coil_value(state, ihp.DWHCoilIndex, "QSource")
        ihp.TotalSpaceHeatingRate = 0.0
        ihp.TotalPower = _get_coil_value(state, ihp.DWHCoilIndex, "Power")
        ihp.TotalLatentLoad = 0.0
        ihp.Qsource = _get_coil_value(state, ihp.DWHCoilIndex, "QLoadTotal")
    elif ihp.CurMode == IHPOperationMode.SCWHMatchSC or ihp.CurMode == IHPOperationMode.SCWHMatchWH:
        ihp.TotalCoolingRate = _get_coil_value(state, ihp.SCWHCoilIndex, "QLoadTotal")
        ihp.TotalWaterHeatingRate = _get_coil_value(state, ihp.SCWHCoilIndex, "QSource")
        ihp.TotalSpaceHeatingRate = 0.0
        ihp.TotalPower = _get_coil_value(state, ihp.SCWHCoilIndex, "Power")
        ihp.TotalLatentLoad = _get_coil_value(state, ihp.SCWHCoilIndex, "QLatent")
        ihp.Qsource = 0.0
    elif ihp.CurMode == IHPOperationMode.SpaceClgDedicatedWaterHtg:
        ihp.TotalCoolingRate = _get_coil_value(state, ihp.SCDWHCoolCoilIndex, "QLoadTotal")
        ihp.TotalSpaceHeatingRate = 0.0
        ihp.TotalPower = _get_coil_value(state, ihp.SCDWHCoolCoilIndex, "Power")
        ihp.TotalLatentLoad = _get_coil_value(state, ihp.SCDWHCoolCoilIndex, "QLatent")
        ihp.Qsource = _get_coil_value(state, ihp.SCDWHCoolCoilIndex, "QSource")
        ihp.TotalWaterHeatingRate = _get_coil_value(state, ihp.SCDWHWHCoilIndex, "QSource")
    elif ihp.CurMode == IHPOperationMode.SHDWHElecHeatOff or ihp.CurMode == IHPOperationMode.SHDWHElecHeatOn:
        ihp.TotalCoolingRate = 0.0
        ihp.TotalSpaceHeatingRate = _get_coil_value(state, ihp.SHDWHHeatCoilIndex, "QLoadTotal")
        ihp.TotalPower = _get_coil_value(state, ihp.SHDWHHeatCoilIndex, "Power")
        ihp.TotalLatentLoad = 0.0
        ihp.Qsource = _get_coil_value(state, ihp.SHDWHHeatCoilIndex, "QSource")
        ihp.TotalWaterHeatingRate = _get_coil_value(state, ihp.SHDWHWHCoilIndex, "QSource")
    
    ihp.Energy = ihp.TotalPower * time_step_sys_sec
    ihp.EnergyLoadTotalCooling = ihp.TotalCoolingRate * time_step_sys_sec
    ihp.EnergyLoadTotalHeating = ihp.TotalSpaceHeatingRate * time_step_sys_sec
    ihp.EnergyLoadTotalWaterHeating = ihp.TotalWaterHeatingRate * time_step_sys_sec
    ihp.EnergyLatent = ihp.TotalLatentLoad * time_step_sys_sec
    ihp.EnergySource = ihp.Qsource * time_step_sys_sec
    
    if ihp.TotalPower > 0.0:
        var total_delivery: Float64 = ihp.TotalCoolingRate + ihp.TotalSpaceHeatingRate + ihp.TotalWaterHeatingRate
        ihp.TotalCOP = total_delivery / ihp.TotalPower


fn DecideWorkMode(state: Any, DXCoilNum: Int32, SensLoad: Float64, LatentLoad: Float64):
    """Decide work mode."""
    var time_step_sys_sec: Float64 = _get_time_step_sys_sec(state)
    var ihp = _get_ihp_ref(state, DXCoilNum)
    
    if not ihp.IHPCoilsSized:
        SizeIHP(state, DXCoilNum)
    
    var small_load: Float64 = 1e-5
    ihp.IsWHCallAvail = False
    ihp.CheckWHCall = True
    
    if ihp.WHtankID == 0:
        ihp.IsWHCallAvail = False
    else:
        _set_node_mass_flow_rate(state, ihp.WaterInletNodeNum, GetWaterVolFlowRateIHP(state, DXCoilNum, 1, 1.0) * WaterDensity)
        _set_node_temp(state, ihp.WaterOutletNodeNum, _get_node_temp(state, ihp.WaterInletNodeNum))
    
    ihp.CheckWHCall = False
    
    var wh_heat_time_sav: Float64 = ihp.SHDWHRunTime
    var wh_heat_vol_save: Float64 = 0.0
    if ihp.CurMode == IHPOperationMode.SpaceClgDedicatedWaterHtg:
        wh_heat_vol_save = ihp.WaterFlowAccumVol + _get_node_mass_flow_rate(state, ihp.WaterTankoutNod) / 983.0 * time_step_sys_sec
    else:
        wh_heat_vol_save = 0.0
    
    ihp.SHDWHRunTime = 0.0
    ihp.WaterFlowAccumVol = 0.0
    
    if not ihp.IsWHCallAvail:
        if (SensLoad < (-1.0 * small_load)) or (LatentLoad < (-1.0 * small_load)):
            ihp.CurMode = IHPOperationMode.SpaceClg
        elif SensLoad > small_load:
            var out_dry_bulb: Float64 = _get_outdoor_dry_bulb(state)
            if ((ihp.ControlledZoneTemp > ihp.TindoorOverCoolAllow) and
                (out_dry_bulb > ihp.TambientOverCoolAllow)):
                ihp.CurMode = IHPOperationMode.Idle
            else:
                ihp.CurMode = IHPOperationMode.SpaceHtg
        else:
            ihp.CurMode = IHPOperationMode.Idle
    elif (SensLoad < (-1.0 * small_load)) or (LatentLoad < (-1.0 * small_load)):
        if wh_heat_vol_save < ihp.WaterVolSCDWH:
            ihp.CurMode = IHPOperationMode.SpaceClgDedicatedWaterHtg
            ihp.WaterFlowAccumVol = wh_heat_vol_save
        else:
            if 1 == ihp.ModeMatchSCWH:
                ihp.CurMode = IHPOperationMode.SCWHMatchWH
            else:
                ihp.CurMode = IHPOperationMode.SCWHMatchSC
    else:
        var out_dry_bulb: Float64 = _get_outdoor_dry_bulb(state)
        if ((ihp.ControlledZoneTemp > ihp.TindoorOverCoolAllow) and
            (out_dry_bulb > ihp.TambientOverCoolAllow)):
            ihp.CurMode = IHPOperationMode.SCWHMatchWH
        elif ((ihp.ControlledZoneTemp > ihp.TindoorWHHighPriority) and
              (out_dry_bulb > ihp.TambientWHHighPriority)):
            ihp.CurMode = IHPOperationMode.DedicatedWaterHtg
        elif SensLoad > small_load:
            ihp.SHDWHRunTime = wh_heat_time_sav + time_step_sys_sec
            if wh_heat_time_sav > ihp.TimeLimitSHDWH:
                ihp.CurMode = IHPOperationMode.SHDWHElecHeatOn
            else:
                ihp.CurMode = IHPOperationMode.SHDWHElecHeatOff
        else:
            ihp.CurMode = IHPOperationMode.DedicatedWaterHtg
    
    ClearCoils(state, DXCoilNum)


