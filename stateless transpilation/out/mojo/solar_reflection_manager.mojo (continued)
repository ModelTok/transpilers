                                hitObs = PierceSurface(state, ObsSurfNum, HitPntRefl, URay, HitPntObs)
                                if hitObs:
                                    break
                            
                            if hitObs:
                                continue
                            
                            dReflSkyGnd += CosIncAngRayToSky * dOmega / Constant.Pi
                    
                    ReflSkySolGnd[iRecPtNum] += \
                        dReflSkyGnd * \
                        state.dataSolarReflectionManager.SolReflRecSurf[iRecSurfNum].dOmegaRay[iRayNum] * \
                        state.dataSolarReflectionManager.SolReflRecSurf[iRecSurfNum].CosIncAngRay[iRayNum] / \
                        Constant.Pi
        
        state.dataSurface.SurfReflFacSkySolObs[iSurfNum] = 0.0
        state.dataSurface.SurfReflFacSkySolGnd[iSurfNum] = 0.0
        let iNumRecPts = state.dataSolarReflectionManager.SolReflRecSurf[iRecSurfNum].NumRecPts
        for iRecPtNum in range(iNumRecPts):
            state.dataSurface.SurfReflFacSkySolObs[iSurfNum] += ReflSkySolObs[iRecPtNum]
            state.dataSurface.SurfReflFacSkySolGnd[iSurfNum] += ReflSkySolGnd[iRecPtNum]
        
        state.dataSurface.SurfReflFacSkySolObs[iSurfNum] /= Float64(iNumRecPts)
        state.dataSurface.SurfReflFacSkySolGnd[iSurfNum] /= Float64(iNumRecPts)
        
        state.dataSurface.SurfReflFacSkySolGnd[iSurfNum] = \
            min(0.5 * (1.0 - state.dataSurface.Surface[iSurfNum].CosTilt),
                state.dataSurface.SurfReflFacSkySolGnd[iSurfNum])
