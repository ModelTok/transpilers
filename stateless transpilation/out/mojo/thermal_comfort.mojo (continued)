fn DynamicClothingModel(state: object) -> None:
    """Calculate dynamic clothing value."""
    var tc = state.dataThermalComforts
    var comfort = tc.ThermalComfortData[tc.PeopleNum]
    
    if tc.TemporarySixAMTemperature < -5.0:
        comfort.ClothingValue = 1.0
    elif tc.TemporarySixAMTemperature < 5.0:
        comfort.ClothingValue = 0.818 - 0.0364 * tc.TemporarySixAMTemperature
    elif tc.TemporarySixAMTemperature < 26.0:
        var TemporaryVariable = -0.1635 - 0.0066 * tc.TemporarySixAMTemperature
        comfort.ClothingValue = pow(10.0, TemporaryVariable)
    else:
        comfort.ClothingValue = 0.46
