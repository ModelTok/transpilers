fn CalcSatVapPressFromTemp(Temp: Float64) -> Float64:
    """Calculate saturated vapor pressure from temperature."""
    var XT = Temp / 100.0
    return 6.16796 + 358.1855 * pow_2(XT) - 550.3543 * pow_3(XT) + 1048.8115 * pow_4(XT)


fn CalcSatVapPressFromTempTorr(Temp: Float64) -> Float64:
    """Calculate saturated vapor pressure in Torr."""
    return exp(18.6686 - 4030.183 / (Temp + 235.0))


