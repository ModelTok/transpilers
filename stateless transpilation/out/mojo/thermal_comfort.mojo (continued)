
    var CorrectedHC = 3.0 * pow(PInAtmospheres, 0.53)
    var ForcedHC = 8.600001 * pow((LocalAirVel * PInAtmospheres), 0.53)
    tc.Hc = max(CorrectedHC, ForcedHC)
    tc.Hr = 4.7
    tc.EvapHeatLoss = 0.1 * ActMet
    var RAir = 1.0 / (TotCloFac * (tc.Hc + tc.Hr))
    tc.OpTemp = ((tc.Hr * RadTemp + tc.Hc * AirTemp) / (tc.Hc + tc.Hr))
    var ActLevelStart = ActLevel
    var AvgBodyTempSet = SkinMassRatSet * SkinTempSet + (1.0 - SkinMassRatSet) * CoreTempSet
    
    for IterMin in range(1, 61):
        tc.CloSurfTemp = (RAir * tc.SkinTemp + RClo * tc.OpTemp) / (RAir + RClo)
        var converged = False
        while not converged:
            tc.Hr = (4.0 * StefanBoltz * pow((tc.CloSurfTemp + RadTemp) / 2.0 + 273.15, 3) * 0.72)
            RAir = 1.0 / (TotCloFac * (tc.Hc + tc.Hr))
            tc.OpTemp = ((tc.Hr * RadTemp + tc.Hc * AirTemp) / (tc.Hc + tc.Hr))
            var CloSurfTempNew = (RAir * tc.SkinTemp + RClo * tc.OpTemp) / (RAir + RClo)
            if abs(CloSurfTempNew - tc.CloSurfTemp) <= 0.01:
                converged = True
            tc.CloSurfTemp = CloSurfTempNew
        
        tc.H = tc.Hr + tc.Hc
        tc.DryHeatLoss = (tc.SkinTemp - tc.OpTemp) / (RAir + RClo)
        
        tc.LatRespHeatLoss = 0.0023 * ActLevel * (44.0 - tc.VapPress)
        tc.DryRespHeatLoss = 0.0014 * ActLevel * (34.0 - AirTemp)
        tc.RespHeatLoss = tc.LatRespHeatLoss + tc.DryRespHeatLoss
        
        tc.HeatFlow = ((tc.CoreTemp - tc.SkinTemp) * (5.28 + 1.163 * SkinBloodFlow))
        
        var CoreHeatStorage = ActLevel - tc.HeatFlow - tc.RespHeatLoss - WorkEff
        var SkinHeatStorage = tc.HeatFlow - tc.DryHeatLoss - tc.EvapHeatLoss
        
        tc.CoreThermCap = 0.97 * (1.0 - SkinMassRat) * BodyWeight
        tc.SkinThermCap = 0.97 * SkinMassRat * BodyWeight
        
        tc.CoreTempChange = (CoreHeatStorage * BodySurfAreaPierce / (tc.CoreThermCap * 60.0))
        tc.SkinTempChange = (SkinHeatStorage * BodySurfAreaPierce) / (tc.SkinThermCap * 60.0)
        
        tc.CoreTemp += tc.CoreTempChange
        tc.SkinTemp += tc.SkinTempChange
        tc.AvgBodyTemp = SkinMassRat * tc.SkinTemp + (1.0 - SkinMassRat) * tc.CoreTemp
        
        var SkinSignal = tc.SkinTemp - SkinTempSet
        var SkinThermSigWarm: Float64
        var SkinThermSigCold: Float64
        if SkinSignal > 0:
            SkinThermSigWarm = SkinSignal
            SkinThermSigCold = 0.0
        else:
            SkinThermSigCold = -SkinSignal
            SkinThermSigWarm = 0.0
        
        var CoreSignal = tc.CoreTemp - CoreTempSet
        var CoreThermSigWarm: Float64
        var CoreThermSigCold: Float64
        if CoreSignal > 0:
            CoreThermSigWarm = CoreSignal
            CoreThermSigCold = 0.0
        else:
            CoreThermSigCold = -CoreSignal
            CoreThermSigWarm = 0.0
        
        var BodySignal = tc.AvgBodyTemp - AvgBodyTempSet
        var BodyThermSigWarm: Float64
        if BodySignal > 0:
            BodyThermSigWarm = BodySignal
        else:
            BodyThermSigWarm = 0.0
        
        tc.VasodilationFac = DriCoeffVasodilation * CoreThermSigWarm
        tc.VasoconstrictFac = DriCoeffVasoconstriction * SkinThermSigCold
        SkinBloodFlow = ((SkinBloodFlowSet + tc.VasodilationFac) / (1.0 + tc.VasoconstrictFac))
        
        if SkinBloodFlow < MinSkinBloodFlow:
            SkinBloodFlow = MinSkinBloodFlow
        if SkinBloodFlow > MaxSkinBloodFlow:
            SkinBloodFlow = MaxSkinBloodFlow
        
        SkinMassRat = 0.0417737 + 0.7451832 / (SkinBloodFlow + 0.585417)
        
        var RegSweat = SweatContConst * BodyThermSigWarm * exp(SkinThermSigWarm / 10.7)
        if RegSweat > RegSweatMax:
            RegSweat = RegSweatMax
        tc.EvapHeatLossRegSweat = 0.68 * RegSweat
        
        tc.ShivResponse = 19.4 * SkinThermSigCold * CoreThermSigCold
        ActLevel = ActLevelStart + tc.ShivResponse
        
        var AirEvapHeatResist = 1.0 / (LewisRatio * TotCloFac * tc.Hc)
        var CloEvapHeatResist = RClo / (LewisRatio * tc.CloInsul)
        var TotEvapHeatResist = AirEvapHeatResist + CloEvapHeatResist
        tc.SatSkinVapPress = CalcSatVapPressFromTempTorr(tc.SkinTemp)
        tc.EvapHeatLossMax = ((tc.SatSkinVapPress - tc.VapPress) / TotEvapHeatResist)
        tc.SkinWetSweat = tc.EvapHeatLossRegSweat / tc.EvapHeatLossMax
        
        tc.SkinWetDiff = (1.0 - tc.SkinWetSweat) * 0.06
        tc.EvapHeatLossDiff = tc.SkinWetDiff * tc.EvapHeatLossMax
        tc.EvapHeatLoss = tc.EvapHeatLossRegSweat + tc.EvapHeatLossDiff
        tc.SkinWetTot = tc.EvapHeatLoss / tc.EvapHeatLossMax
        
        if tc.SkinWetTot >= EvapEff:
            tc.SkinWetTot = EvapEff
            tc.SkinWetSweat = EvapEff / 0.94
            tc.EvapHeatLossRegSweat = tc.SkinWetSweat * tc.EvapHeatLossMax
            tc.SkinWetDiff = (1.0 - tc.SkinWetSweat) * 0.06
            tc.EvapHeatLossDiff = tc.SkinWetDiff * tc.EvapHeatLossMax
            tc.EvapHeatLoss = tc.EvapHeatLossRegSweat + tc.EvapHeatLossDiff
        
        if tc.EvapHeatLossMax < 0.0:
            tc.SkinWetDiff = 0.0
            tc.EvapHeatLossDiff = 0.0
            tc.EvapHeatLoss = 0.0
            tc.SkinWetTot = EvapEff
            tc.SkinWetSweat = EvapEff
            tc.EvapHeatLossRegSweat = 0.0
        
        tc.SkinVapPress = (tc.SkinWetTot * tc.SatSkinVapPress + 
                          (1.0 - tc.SkinWetTot) * tc.VapPress)
    
    tc.EvapHeatLossMax *= EvapEff
    
    var EffectSkinHeatLoss = tc.DryHeatLoss + tc.EvapHeatLoss
    tc.CloBodyRat = 1.0 + CloFac * CloUnit
    var EffectCloUnit = (CloUnit - (tc.CloBodyRat - 1.0) / 
                     (0.155 * tc.CloBodyRat * tc.H))
    var EffectCloThermEff = 1.0 / (1.0 + 0.155 * tc.Hc * EffectCloUnit)
    tc.CloPermeatEff = 1.0 / (1.0 + (0.155 / tc.CloInsul) * tc.Hc * EffectCloUnit)
    
    var ET = tc.SkinTemp - EffectSkinHeatLoss / (tc.H * EffectCloThermEff)
    while True:
        var StdVapPressET = CalcSatVapPressFromTempTorr(ET)
        var EnergyBalErrET = (EffectSkinHeatLoss - tc.H * EffectCloThermEff * (tc.SkinTemp - ET) -
                         tc.SkinWetTot * LewisRatio * tc.Hc * tc.CloPermeatEff * 
                         (tc.SatSkinVapPress - StdVapPressET / 2.0))
        if EnergyBalErrET >= 0.0:
            break
        ET += 0.1
    
    tc.EffTemp = ET
    
    var StdHr = tc.Hr
    var StdHc: Float64
    if ActMet <= 0.85:
        StdHc = 3.0
    else:
        StdHc = 5.66 * pow(ActMet - 0.85, 0.39)
    if StdHc <= 3.0:
        StdHc = 3.0
    
    var StdH = StdHc + StdHr
    var StdCloUnit = 1.52 / (ActMet - WorkEff / ActLevelConv + 0.6944) - 0.1835
    var StdRClo = 0.155 * StdCloUnit
    var StdCloBodyRat = 1.0 + CloFac * StdCloUnit
    var StdEffectCloThermEff = 1.0 / (1.0 + 0.155 * StdCloBodyRat * StdH * StdCloUnit)
    var StdCloInsul = (tc.CloInsul * StdHc / StdH * (1.0 - StdEffectCloThermEff) /
                   (StdHc / StdH - tc.CloInsul * StdEffectCloThermEff))
    var StdREvap = 1.0 / (LewisRatio * StdCloBodyRat * StdHc)
    var StdREvapClo = StdRClo / (LewisRatio * StdCloInsul)
    var StdHEvap = 1.0 / (StdREvap + StdREvapClo)
    var StdRAir = 1.0 / (StdCloBodyRat * StdH)
    var StdHDry = 1.0 / (StdRAir + StdRClo)
    
    var StdEffectSkinHeatLoss = tc.DryHeatLoss + tc.EvapHeatLoss
    var OldSET = round((tc.SkinTemp - StdEffectSkinHeatLoss / StdHDry) * 100.0) / 100.0
    var delta = 0.0001
    var err = 100.0
    
    while abs(err) > 0.01:
        var StdVapPressSET_1 = CalcSatVapPressFromTempTorr(OldSET)
        var EnergyBalErrSET_1 = (StdEffectSkinHeatLoss - StdHDry * (tc.SkinTemp - OldSET) -
                            tc.SkinWetTot * StdHEvap * (tc.SatSkinVapPress - StdVapPressSET_1 / 2.0))
        var StdVapPressSET_2 = CalcSatVapPressFromTempTorr(OldSET + delta)
        var EnergyBalErrSET_2 = (StdEffectSkinHeatLoss - StdHDry * (tc.SkinTemp - (OldSET + delta)) -
                            tc.SkinWetTot * StdHEvap * (tc.SatSkinVapPress - StdVapPressSET_2 / 2.0))
        var NewSET = OldSET - delta * EnergyBalErrSET_1 / (EnergyBalErrSET_2 - EnergyBalErrSET_1)
        err = NewSET - OldSET
        OldSET = NewSET
    
    var SET = OldSET
    tc.DryHeatLossET = StdH * StdEffectCloThermEff * (tc.SkinTemp - ET)
    tc.DryHeatLossSET = StdH * StdEffectCloThermEff * (tc.SkinTemp - SET)
    
    return SET


fn CalcThermalComfortPierceASHRAE(state: object) -> None:
    """Calculate Pierce ASHRAE thermal comfort model."""
    var tc = state.dataThermalComforts
    
    for people_idx in range(state.dataHeatBal.TotPeople):
        tc.PeopleNum = Int32(people_idx)
        var people = state.dataHeatBal.People[people_idx]
        
        if not people.Pierce:
            continue
        
        var comfort = tc.ThermalComfortData[people_idx]
        
        GetThermalComfortInputsASHRAE(state)
        
        var SET = CalcStandardEffectiveTemp(
            state, tc.AirTemp, tc.RadTemp, tc.RelHum, tc.AirVel, 
            tc.ActMet, tc.CloUnit, tc.WorkEff
        )
        
        tc.ThermSensTransCoef = 0.303 * exp(-0.036 * tc.ActLevel) + 0.028
        tc.EvapHeatLossRegComf = (tc.IntHeatProd - ActLevelConv) * 0.42
        
        comfort.PiercePMVET = (tc.ThermSensTransCoef * 
                              (tc.IntHeatProd - tc.RespHeatLoss - tc.DryHeatLossET - 
                               tc.EvapHeatLossDiff - tc.EvapHeatLossRegComf))
        comfort.PiercePMVSET = (tc.ThermSensTransCoef * 
                               (tc.IntHeatProd - tc.RespHeatLoss - tc.DryHeatLossSET - 
                                tc.EvapHeatLossDiff - tc.EvapHeatLossRegComf))
        
        comfort.PierceDISC = (5.0 * (tc.EvapHeatLossRegSweat - tc.EvapHeatLossRegComf) /
                             (tc.EvapHeatLossMax - tc.EvapHeatLossRegComf - tc.EvapHeatLossDiff))
        
        var AvgBodyTempLow = (0.185 / ActLevelConv) * (tc.ActLevel - tc.WorkEff) + 36.313
        var AvgBodyTempHigh = (0.359 / ActLevelConv) * (tc.ActLevel - tc.WorkEff) + 36.664
        
        if tc.AvgBodyTemp > AvgBodyTempLow:
            comfort.PierceTSENS = (4.7 * (tc.AvgBodyTemp - AvgBodyTempLow) / 
                                  (AvgBodyTempHigh - AvgBodyTempLow))
        else:
            comfort.PierceTSENS = 0.68175 * (tc.AvgBodyTemp - AvgBodyTempLow)
            comfort.PierceDISC = comfort.PierceTSENS
        
        comfort.ThermalComfortMRT = tc.RadTemp
        comfort.ThermalComfortOpTemp = (tc.RadTemp + tc.AirTemp) / 2.0
        comfort.ClothingValue = tc.CloUnit
        comfort.PierceSET = SET


