fn CalcCoolingEffectAdjustedPMV(state: object, CoolingEffect: Pointer[Float64], CoolingEffectAdjustedPMV: Pointer[Float64]) -> None:
    """Calculate cooling effect adjusted PMV."""
    var tc = state.dataThermalComforts
    var people = state.dataHeatBal.People[tc.PeopleNum]
    
    var RelAirVel = CalcRelativeAirVelocity(tc.AirVel, tc.ActMet)
    var SET = CalcStandardEffectiveTemp(
        state, tc.AirTemp, tc.RadTemp, tc.RelHum, RelAirVel, 
        tc.ActMet, tc.CloUnit, tc.WorkEff
    )
    
    var ASHRAE55PMV = CalcFangerPMV(
        state, tc.AirTemp, tc.RadTemp, tc.RelHum, RelAirVel, 
        tc.ActLevel, tc.CloUnit, tc.WorkEff
    )
    
    var StillAirVel = 0.1
    var ce_result = 0.0
    
    var lowerBound = 0.0
    var upperBound = 50.0
    
    ce_result = 0
    CoolingEffect.store(ce_result)
    
    if ce_result > 0:
        var adjPMV = CalcFangerPMV(
            state, tc.AirTemp - ce_result, tc.RadTemp - ce_result, 
            tc.RelHum, StillAirVel, tc.ActLevel, tc.CloUnit, tc.WorkEff
        )
        CoolingEffectAdjustedPMV.store(adjPMV)
    else:
        CoolingEffectAdjustedPMV.store(ASHRAE55PMV)


fn CalcThermalComfortAnkleDraftASH(state: object) -> None:
    """Calculate ASHRAE ankle draft PPD."""
    var tc = state.dataThermalComforts
    
    for people_idx in range(state.dataHeatBal.TotPeople):
        tc.PeopleNum = Int32(people_idx)
        var people = state.dataHeatBal.People[people_idx]
        
        if not people.AnkleDraftASH55:
            continue
        
        var comfort = tc.ThermalComfortData[people_idx]
        GetThermalComfortInputsASHRAE(state)
        var RelAirVel = CalcRelativeAirVelocity(tc.AirVel, tc.ActMet)
        var PPD_AD = -1.0
        
        if tc.ActMet < 1.3 and tc.CloUnit < 0.7 and RelAirVel < 0.2:
            var AnkleAirVel = people.ankleAirVelocitySched.getCurrentVal()
            var PMV = CalcFangerPMV(
                state, tc.AirTemp, tc.RadTemp, tc.RelHum, RelAirVel, 
                tc.ActLevel, tc.CloUnit, tc.WorkEff
            )
            PPD_AD = ((exp(-2.58 + 3.05 * AnkleAirVel - 1.06 * PMV) / 
                      (1.0 + exp(-2.58 + 3.05 * AnkleAirVel - 1.06 * PMV))) * 100.0)
        
        comfort.AnkleDraftPPDASH55 = PPD_AD


