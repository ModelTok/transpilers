@test
def test_VentilatedSlab_CalcVentilatedSlabCoilOutputTest():
    state = EnergyPlusFixture.state
    state.dataGlobal.BeginEnvrnFlag = False
    var PowerMet: Real64 = 0.0
    var LatOutputProvided: Real64 = 0.0
    state.dataVentilatedSlab.NumOfVentSlabs = 1
    state.dataVentilatedSlab.VentSlab.allocate(state.dataVentilatedSlab.NumOfVentSlabs)
    var Item: int = 0  # 1-based in C++ becomes 0-based in Mojo
    var FanOutletNode: int = 0
    var OutletNode: int = 1
    state.dataVentilatedSlab.VentSlab[Item].FanOutletNode = FanOutletNode
    state.dataVentilatedSlab.VentSlab[Item].RadInNode = OutletNode
    state.dataLoopNodes.Node.allocate(2)
    state.dataLoopNodes.Node[OutletNode].MassFlowRate = 0.5
    state.dataLoopNodes.Node[FanOutletNode].Temp = 15.0
    state.dataLoopNodes.Node[FanOutletNode].HumRat = 0.003
    state.dataLoopNodes.Node[OutletNode].Temp = 20.0
    state.dataLoopNodes.Node[OutletNode].HumRat = 0.003
    CalcVentilatedSlabCoilOutput(state, Item, PowerMet, LatOutputProvided)
    assert_true(state.dataVentilatedSlab.VentSlab[Item].HeatCoilPower > 0.0)
    assert_true(state.dataVentilatedSlab.VentSlab[Item].SensCoolCoilPower == 0.0)
    assert_true(state.dataVentilatedSlab.VentSlab[Item].TotCoolCoilPower == 0.0)
    assert_true(state.dataVentilatedSlab.VentSlab[Item].LateCoolCoilPower == 0.0)
    assert_true(LatOutputProvided == 0.0)
    assert_true(PowerMet > 0.0)
    state.dataLoopNodes.Node[FanOutletNode].Temp = 25.0
    state.dataLoopNodes.Node[FanOutletNode].HumRat = 0.003
    state.dataLoopNodes.Node[OutletNode].Temp = 20.0
    state.dataLoopNodes.Node[OutletNode].HumRat = 0.003
    CalcVentilatedSlabCoilOutput(state, Item, PowerMet, LatOutputProvided)
    assert_true(state.dataVentilatedSlab.VentSlab[Item].HeatCoilPower == 0.0)
    assert_true(state.dataVentilatedSlab.VentSlab[Item].SensCoolCoilPower > 0.0)
    assert_true(state.dataVentilatedSlab.VentSlab[Item].TotCoolCoilPower == state.dataVentilatedSlab.VentSlab[Item].SensCoolCoilPower)
    assert_true(state.dataVentilatedSlab.VentSlab[Item].LateCoolCoilPower == 0.0)
    assert_true(LatOutputProvided == 0.0)
    assert_true(PowerMet < 0.0)
    state.dataLoopNodes.Node[FanOutletNode].Temp = 25.0
    state.dataLoopNodes.Node[FanOutletNode].HumRat = 0.008
    state.dataLoopNodes.Node[OutletNode].Temp = 20.0
    state.dataLoopNodes.Node[OutletNode].HumRat = 0.003
    CalcVentilatedSlabCoilOutput(state, Item, PowerMet, LatOutputProvided)
    assert_true(state.dataVentilatedSlab.VentSlab[Item].HeatCoilPower == 0.0)
    assert_true(state.dataVentilatedSlab.VentSlab[Item].SensCoolCoilPower > 0.0)
    assert_true(state.dataVentilatedSlab.VentSlab[Item].TotCoolCoilPower > state.dataVentilatedSlab.VentSlab[Item].SensCoolCoilPower)
    assert_true(state.dataVentilatedSlab.VentSlab[Item].LateCoolCoilPower > 0.0)
    assert_true(LatOutputProvided < 0.0)
    assert_true(PowerMet < 0.0)

