def TestDoublePaneAbsorptances():
    ScopedTrace("Begin Test: Test layer absroptances.")
    var MultiLayerOptics = getMultiLayerOptics()
    var correctAbs: List[Float64] = List[Float64]()
    correctAbs.append(0.860835761)
    correctAbs.append(0.813548561)
    correctAbs.append(0.762759679)
    correctAbs.append(0.710460061)
    correctAbs.append(0.655884150)
    correctAbs.append(0.597817313)
    correctAbs.append(0.536862648)
    correctAbs.append(0.475253771)
    correctAbs.append(0.420616132)
    correctAbs.append(0.375436233)
    correctAbs.append(0.334943510)
    correctAbs.append(0.289351814)
    correctAbs.append(0.244245498)
    correctAbs.append(0.207375484)
    correctAbs.append(0.179613906)
    var abs: CSeries = MultiLayerOptics.getLayerAbsorptances(1)
    EXPECT_EQ(abs.size(), correctAbs.size())
    for i in range(abs.size()):
        EXPECT_NEAR(correctAbs[i], abs[i].value(), 1e-6)
    correctAbs.clear()
    correctAbs.append(0.068952518)
    correctAbs.append(0.085208275)
    correctAbs.append(0.088007015)
    correctAbs.append(0.080385689)
    correctAbs.append(0.067190541)
    correctAbs.append(0.054854806)
    correctAbs.append(0.044434083)
    correctAbs.append(0.037835438)
    correctAbs.append(0.036729145)
    correctAbs.append(0.045616344)
    correctAbs.append(0.053510261)
    correctAbs.append(0.046110336)
    correctAbs.append(0.034787506)
    correctAbs.append(0.027361056)
    correctAbs.append(0.024199766)
    abs = MultiLayerOptics.getLayerAbsorptances(2)
    EXPECT_EQ(abs.size(), correctAbs.size())
    for i in range(abs.size()):
        EXPECT_NEAR(correctAbs[i], abs[i].value(), 1e-6)