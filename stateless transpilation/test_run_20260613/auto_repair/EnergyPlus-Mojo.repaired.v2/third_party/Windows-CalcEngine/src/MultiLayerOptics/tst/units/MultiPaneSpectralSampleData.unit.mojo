def TestDoublePaneResults():
    ScopedTrace("Begin Test: Test simple double pane calculations (T, Rf, Rb and equivalent absorptances).")
    var MultiLayerOptics = getMultiLayerOptics()
    var correctT: List[Float64] = List[Float64]()
    correctT.append(0.013877236)
    correctT.append(0.038129730)
    correctT.append(0.075706822)
    correctT.append(0.122307257)
    correctT.append(0.173403282)
    correctT.append(0.224241626)
    correctT.append(0.273149050)
    correctT.append(0.317354388)
    correctT.append(0.351248832)
    correctT.append(0.369898865)
    correctT.append(0.386516080)
    correctT.append(0.420060093)
    correctT.append(0.456519123)
    correctT.append(0.484681565)
    correctT.append(0.504161785)
    var transmittances: CSeries = MultiLayerOptics.properties(Property.T, Side.Front)
    EXPECT_EQ(transmittances.size(), correctT.size())
    for i in range(transmittances.size()):
        EXPECT_NEAR(correctT[i], transmittances[i].value(), 1e-6)
    var correctRf: List[Float64] = List[Float64]()
    correctRf.append(0.056334485)
