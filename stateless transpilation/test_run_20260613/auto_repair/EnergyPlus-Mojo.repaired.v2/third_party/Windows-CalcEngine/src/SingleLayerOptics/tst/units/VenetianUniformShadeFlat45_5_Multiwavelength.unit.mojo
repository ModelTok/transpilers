from WCECommon import *
from WCESingleLayerOptics import *
from memory import Pointer
from math import abs

class TestVenetianUniformShadeFlat45_5_Multiwavelength:
    var m_Layer: Pointer[CBSDFLayer]

    def __init__(inout self):
        self.m_Layer = Pointer[CBSDFLayer]()

    def SetUp(inout self):
        let Tsol = 0.1
        let Rfsol = 0.7
        let Rbsol = 0.7
        let Tvis = 0.2
        let Rfvis = 0.6
        let Rbvis = 0.6
        let aMaterial = Material.dualBandMaterial(Tsol, Tsol, Rfsol, Rbsol, Tvis, Tvis, Rfvis, Rbvis)
        let slatWidth = 0.016
        let slatSpacing = 0.012
        let slatTiltAngle = 45
        let curvatureRadius = 0
        let numOfSlatSegments: Int = 5
        let aBSDF = CBSDFHemisphere.create(BSDFBasis.Quarter)
        self.m_Layer = CBSDFLayerMaker.getVenetianLayer(aMaterial, aBSDF, slatWidth, slatSpacing, slatTiltAngle, curvatureRadius, numOfSlatSegments, DistributionMethod.UniformDiffuse, True)

    def getLayer(self) -> Pointer[CBSDFLayer]:
        return self.m_Layer

def TestVenetianMultiWavelength():
