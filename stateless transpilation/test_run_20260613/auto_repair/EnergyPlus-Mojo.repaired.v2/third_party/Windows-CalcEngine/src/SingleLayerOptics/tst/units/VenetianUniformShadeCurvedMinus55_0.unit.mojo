from WCECommon import Material, CBSDFHemisphere, CBSDFIntegrator, Side, PropertySimple
from WCESingleLayerOptics import CBSDFLayer, CBSDFLayerMaker, DistributionMethod
from memory import Owned

def EXPECT_NEAR(actual: Float64, expected: Float64, tolerance: Float64):
    assert(abs(actual - expected) <= tolerance, "Expected " + str(expected) + " ± " + str(tolerance) + ", got " + str(actual))

def SCOPED_TRACE(message: String):
    print(message)

struct TestVenetianUniformShadeCurvedMinus55_0:
    var m_Shade: Owned[CBSDFLayer]

    def __init__(inout self):
        self.m_Shade = Owned[CBSDFLayer]()

    def SetUp(inout self):
        let Tmat: Float64 = 0.15
        let Rfmat: Float64 = 0.2
        let Rbmat: Float64 = 0.5
        let minLambda: Float64 = 0.3
        let maxLambda: Float64 = 2.5
        let aMaterial = Material.singleBandMaterial(Tmat, Tmat, Rfmat, Rbmat, minLambda, maxLambda)
        let slatWidth: Float64 = 0.076200
        let slatSpacing: Float64 = 0.057150
        let slatTiltAngle: Float64 = -55.0
        let curvatureRadius: Float64 = 0.123967
        let numOfSlatSegments: Int = 2
        let aBSDF = CBSDFHemisphere.create(BSDFBasis.Quarter)
        self.m_Shade = CBSDFLayerMaker.getVenetianLayer(
            aMaterial,
            aBSDF,
            slatWidth,
            slatSpacing,
            slatTiltAngle,
            curvatureRadius,
            numOfSlatSegments,
            DistributionMethod.UniformDiffuse,
            True
        )

    def GetShade(self) -> Owned[CBSDFLayer]:
        return self.m_Shade

def TestVenetian1():
    SCOPED_TRACE("Begin Test: Venetian shade (Curved, -55 degrees slats).")
    var fixture = TestVenetianUniformShadeCurvedMinus55_0()
    fixture.SetUp()
    let aShade = fixture.GetShade()
    let aResults: Owned[CBSDFIntegrator] = aShade.getResults()
    let tauDiff: Float64 = aResults.DiffDiff(Side.Front, PropertySimple.T)
    EXPECT_NEAR(tauDiff, 0.232141, 1e-6)
    let RfDiff: Float64 = aResults.DiffDiff(Side.Front, PropertySimple.R)
    EXPECT_NEAR(RfDiff, 0.301555, 1e-6)
    let aT = aResults.getMatrix(Side.Front, PropertySimple.T)
    let size: Int = aT.size()
    var correctResults: List[Float64] = List[Float64]()
