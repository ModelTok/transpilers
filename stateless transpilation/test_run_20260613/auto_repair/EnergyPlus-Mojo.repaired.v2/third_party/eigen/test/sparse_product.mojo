def test_sparse_product() raises:
    for i in range(g_repeat):
        CALL_SUBTEST_1( sparse_product[SparseMatrix[Float64,ColMajor]]() )
        CALL_SUBTEST_1( sparse_product[SparseMatrix[Float64,RowMajor]]() )
        CALL_SUBTEST_1( bug_942[Float64]() )
        CALL_SUBTEST_2( sparse_product[SparseMatrix[Complex[Float64], ColMajor]]() )
        CALL_SUBTEST_2( sparse_product[SparseMatrix[Complex[Float64], RowMajor]]() )
        CALL_SUBTEST_3( sparse_product[SparseMatrix[Float32,ColMajor,Int]]() )
        CALL_SUBTEST_4( sparse_product_regression_test[SparseMatrix[Float64,RowMajor], Matrix[Float64, Dynamic, Dynamic, RowMajor]]() )
        CALL_SUBTEST_5( test_mixing_types[Float32]() )