from unsupported.Eigen.MatrixFunctions import MatrixXf

def main() raises:
    var A = MatrixXf.Random(3, 3)
    print("A = ")
    print(A)
    print()
    print()
    var sinhA = A.sinh()
    print("sinh(A) = ")
    print(sinhA)
    print()
    print()
    var coshA = A.cosh()
    print("cosh(A) = ")
    print(coshA)
    print()
    print()
    print("cosh^2(A) - sinh^2(A) = ")
    print(coshA * coshA - sinhA * sinhA)
    print()
    print()