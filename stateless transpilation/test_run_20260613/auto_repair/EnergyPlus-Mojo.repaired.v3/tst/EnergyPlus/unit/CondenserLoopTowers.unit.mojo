             "    TowerWaterSys Supply Outlet Node;  !- Outlet Node Name"
            })
        testing::assert_true(process_idf(idf_objects))
        var ErrorsFound: Bool = false
        state.dataGlobal.BeginSimFlag = true
        state.init_state(state)
        OutputProcessor.SetupTimePointers(
            state, OutputProcessor.TimeStepType.Zone, state.dataGlobal.TimeStepZone)
        OutputProcessor.SetupTimePointers(state, OutputProcessor.TimeStepType.System, state.dataHVACGlobal.TimeStepSys)
        createFacilityElectricPowerServiceObject(state)
        OutputProcessor.GetReportVariableInput(state)
        PlantManager.CheckIfAnyPlant(state)
        BranchInputManager.ManageBranchInput(state)
        state.dataGlobal.DoingSizing = false
        state.dataGlobal.KickOffSimulation = true
        Weather.ResetEnvironmentCounter(state)
        SimulationManager.SetupSimulation(state, ErrorsFound)
        CondenserLoopTowers.GetTowerInput(state)
        state.dataCondenserLoopTowers.towers[0].initialize(state)
        state.dataCondenserLoopTowers.towers[0].SizeVSMerkelTower(state)
        state.dataCondenserLoopTowers.towers[0].initialize(state)
        var MyLoad: Float64 = 0.0
        var RunFlag: Bool = false
        state.dataCondenserLoopTowers.towers[0].calculateMerkelVariableSpeedTower(state, MyLoad, RunFlag)
        state.dataCondenserLoopTowers.towers[0].update(state)
        state.dataCondenserLoopTowers.towers[0].report(state, true)
        testing::expect_eq(state.dataLoopNodes.Node[8].Temp, state.dataLoopNodes.Node[9].Temp)

    def CondenserLoopTowers_SingleSpeedSizing():
        let idf_objects = delimited_string({"  Site:Location,",
                                            "    USA IL-CHICAGO-OHARE,    !- Name",
                                            "    41.77,                   !- Latitude {deg}",
                                            "    -87.75,                  !- Longitude {deg}",
                                            "    -6.00,                   !- Time Zone {hr}",
                                            "    190;                     !- Elevation {m}",
                                            "  SizingPeriod:DesignDay,",
                                            "    CHICAGO Ann Htg 99.6% Condns DB,  !- Name",
                                            "    1,                       !- Month",
                                            "    21,                      !- Day of Month",
                                            "    WinterDesignDay,         !- Day Type",
                                            "    -20.6,                   !- Maximum Dry-Bulb Temperature {C}",
                                            "    0.0,                     !- Daily Dry-Bulb Temperature Range {deltaC}",
                                            "    ,                        !- Dry-Bulb Temperature Range Modifier Type",
                                            "    ,                        !- Dry-Bulb Temperature Range Modifier Day Schedule Name",
                                            "    Wetbulb,                 !- Humidity Condition Type",
                                            "    -20.6,                   !- Wetbulb or DewPoint at Maximum Dry-Bulb {C}",
                                            "    ,                        !- Humidity Condition Day Schedule Name",
                                            "    ,                        !- Humidity Ratio at Maximum Dry-Bulb {kgWater/kgDryAir}",
