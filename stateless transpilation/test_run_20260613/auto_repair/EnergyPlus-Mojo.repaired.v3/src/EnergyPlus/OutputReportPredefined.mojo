            state.dataOutRptPredefined.sizeCompSizeTableEntry *= 2
            state.dataOutRptPredefined.CompSizeTableEntry.reserve(state.dataOutRptPredefined.sizeCompSizeTableEntry)
    var idx = state.dataOutRptPredefined.numCompSizeTableEntry - 1
