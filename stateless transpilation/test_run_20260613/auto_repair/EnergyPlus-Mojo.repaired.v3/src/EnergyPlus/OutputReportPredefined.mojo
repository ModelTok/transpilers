# Constants
alias sizeIncrement = 100
alias recKindSurface = 1
alias recKindSubsurface = 2

var standard62RptSummaryName: StringLiteral = "Standard62.1Summary"

struct reportNameType:
    var name: String
    var namewithspaces: String
    var abrev: String
    var show: Bool

    def __init__(inout self):
        self.show = False
        self.name = String("")
        self.namewithspaces = String("")
        self.abrev = String("")

struct ColumnTagType:
    var heading: String
    var indexSubTable: Int

    def __init__(inout self):
        self.indexSubTable = 0
        self.heading = String("")

struct TableEntryType:
    var charEntry: String
    var objectName: String
    var indexColumn: Int
    var indexTable: Int
    var uniqueObjName: Int
    var origRealEntry: Float64
    var significantDigits: Int
    var origEntryIsReal: Bool

    def __init__(inout self):
        self.indexColumn = 0
        self.indexTable = 0
        self.uniqueObjName = 0
        self.origRealEntry = 0.0
        self.significantDigits = 0
        self.origEntryIsReal = False
        self.charEntry = String("")
        self.objectName = String("")

struct SubTableType:
    var name: String
    var indexReportName: Int
    var footnote: String
    var numEntries: Int
    var sizeEntries: Int
    var entries: List[TableEntryType]

    def __init__(inout self):
        self.indexReportName = 0
        self.numEntries = 0
        self.sizeEntries = 0
        self.name = String("")
        self.footnote = String("")
        self.entries = List[TableEntryType]()

struct CompSizeTableEntryType:
    var typeField: String
    var nameField: String
    var description: String
    var valField: Float64
    var strField: String
    var active: Bool
    var written: Bool

    def __init__(inout self):
        self.valField = 0.0
        self.active = False
        self.written = False
        self.typeField = String("")
        self.nameField = String("")
        self.description = String("")
        self.strField = String("")

struct ShadowRelateType:
    var castSurf: Int
    var recSurf: Int
    var recKind: Int

    def __init__(inout self):
        self.castSurf = 0
        self.recSurf = 0
        self.recKind = 0

