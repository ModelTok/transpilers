    s.pdchCO2OccupiedHourCaution = newPreDefColumn(state, s.pdstCO2OccupiedHours, "Caution (> 1000, <= 5000 ppm) [hr]")
    s.pdchCO2OccupiedHourHazard = newPreDefColumn(state, s.pdstCO2OccupiedHours, "Hazard (> 5000 ppm) [hr]")
    s.pdrVisualResilience = newPreDefReport(state, "VisualResilienceSummary", "VisualR", "Annual Visual Resilience Summary")
    s.pdstIllumHours = newPreDefSubTable(state, s.pdrVisualResilience, "Illuminance Level Hours")
    s.pdchIllumHourDark = newPreDefColumn(state, s.pdstIllumHours, "A Bit Dark (<= 100 lux) [hr]")
    s.pdchIllumHourDim = newPreDefColumn(state, s.pdstIllumHours, "Dim (> 100, <= 300 lux) [hr]")
    s.pdchIllumHourAdequate = newPreDefColumn(state, s.pdstIllumHours, "Adequate (> 300, <= 500 lux) [hr]")
    s.pdchIllumHourBright = newPreDefColumn(state, s.pdstIllumHours, "Bright (>500 lux) [hr]")
    s.pdstIllumOccuHours = newPreDefSubTable(state, s.pdrVisualResilience, "Illuminance Level OccupantHours")
    s.pdchIllumOccuHourDark = newPreDefColumn(state, s.pdstIllumOccuHours, "A Bit Dark (<= 100 lux) [hr]")
    s.pdchIllumOccuHourDim = newPreDefColumn(state, s.pdstIllumOccuHours, "Dim (> 100, <= 300 lux) [hr]")
    s.pdchIllumOccuHourAdequate = newPreDefColumn(state, s.pdstIllumOccuHours, "Adequate (> 300, <= 500 lux) [hr]")
    s.pdchIllumOccuHourBright = newPreDefColumn(state, s.pdstIllumOccuHours, "Bright (>500 lux) [hr]")
    s.pdstIllumOccupiedHours = newPreDefSubTable(state, s.pdrVisualResilience, "Illuminance Level OccupiedHours")
    s.pdchIllumOccupiedHourDark = newPreDefColumn(state, s.pdstIllumOccupiedHours, "A Bit Dark (<= 100 lux) [hr]")
    s.pdchIllumOccupiedHourDim = newPreDefColumn(state, s.pdstIllumOccupiedHours, "Dim (> 100, <= 300 lux) [hr]")
    s.pdchIllumOccupiedHourAdequate = newPreDefColumn(state, s.pdstIllumOccupiedHours, "Adequate (> 300, <= 500 lux) [hr]")
    s.pdchIllumOccupiedHourBright = newPreDefColumn(state, s.pdstIllumOccupiedHours, "Bright (>500 lux) [hr]")

def PreDefTableEntry(inout state: EnergyPlusData, columnIndex: Int, objName: StringLiteral, tableEntryReal: Float64, numSigDigits: Optional[Int] = Optional[Int]()):
    assert(columnIndex > 0 and columnIndex <= state.dataOutRptPredefined.numColumnTag)
    var column = state.dataOutRptPredefined.columnTag[columnIndex - 1]
    var table = state.dataOutRptPredefined.subTable[column.indexSubTable - 1]
    incrementTableEntry(state, column.indexSubTable)
    var entry = table.entries[table.numEntries - 1]
    var sigDigitCount: Int = 2
    if numSigDigits:
        if (numSigDigits.value() <= 9) and (numSigDigits.value() >= 0):
            sigDigitCount = numSigDigits.value()
    if abs(tableEntryReal) < 1e8:
        entry.charEntry = format("{:#11.{}F}", tableEntryReal, sigDigitCount)
    else:
        if sigDigitCount < 2:
            sigDigitCount = 2
        entry.charEntry = format("{:12.{}E}", tableEntryReal, sigDigitCount)
    if len(entry.charEntry) > 12:
        entry.charEntry = "  Too Big"
    entry.objectName = String(objName)
    entry.indexColumn = columnIndex
    entry.indexTable = column.indexSubTable
    entry.origRealEntry = tableEntryReal
    entry.significantDigits = sigDigitCount
    entry.origEntryIsReal = True

def PreDefTableEntry(inout state: EnergyPlusData, columnIndex: Int, objName: StringLiteral, tableEntryChar: StringLiteral):
    assert(columnIndex > 0 and columnIndex <= state.dataOutRptPredefined.numColumnTag)
    var column = state.dataOutRptPredefined.columnTag[columnIndex - 1]
    var table = state.dataOutRptPredefined.subTable[column.indexSubTable - 1]
    incrementTableEntry(state, column.indexSubTable)
    var entry = table.entries[table.numEntries - 1]
    entry.charEntry = String(tableEntryChar)
    entry.objectName = String(objName)
    entry.indexColumn = columnIndex
    entry.indexTable = column.indexSubTable

def PreDefTableEntry(inout state: EnergyPlusData, columnIndex: Int, objName: StringLiteral, tableEntryInt: Int):
    assert(columnIndex > 0 and columnIndex <= state.dataOutRptPredefined.numColumnTag)
    var column = state.dataOutRptPredefined.columnTag[columnIndex - 1]
    var table = state.dataOutRptPredefined.subTable[column.indexSubTable - 1]
    incrementTableEntry(state, column.indexSubTable)
    var entry = table.entries[table.numEntries - 1]
    entry.charEntry = format("{:12}", tableEntryInt)
    entry.objectName = String(objName)
    entry.indexColumn = columnIndex
    entry.indexTable = column.indexSubTable

def RetrievePreDefTableEntry(inout state: EnergyPlusData, columnIndex: Int, objName: StringLiteral) -> String:
    assert(columnIndex > 0 and columnIndex <= state.dataOutRptPredefined.numColumnTag)
    var column = state.dataOutRptPredefined.columnTag[columnIndex - 1]
    var table = state.dataOutRptPredefined.subTable[column.indexSubTable - 1]
    for i in range(table.numEntries):
        if (table.entries[i].indexColumn == columnIndex) and (table.entries[i].objectName == String(objName)):
            return table.entries[i].charEntry.strip()
    return "NOT FOUND"

def incrementTableEntry(inout state: EnergyPlusData, subTableNum: Int):
    assert(subTableNum > 0 and subTableNum <= state.dataOutRptPredefined.numSubTable)
    var table = state.dataOutRptPredefined.subTable[subTableNum - 1]
    if len(table.entries) == 0:
        table.entries = List[TableEntryType](capacity=sizeIncrement)
        table.sizeEntries = sizeIncrement
        table.numEntries = 1
    else:
        table.numEntries += 1
        if table.numEntries > table.sizeEntries:
            table.sizeEntries *= 2
            table.entries.reserve(table.sizeEntries)

def AddCompSizeTableEntry(inout state: EnergyPlusData, FieldType: StringLiteral, FieldName: StringLiteral, FieldDescription: StringLiteral, FieldValue: Float64):
    if len(state.dataOutRptPredefined.CompSizeTableEntry) == 0:
        state.dataOutRptPredefined.CompSizeTableEntry = List[CompSizeTableEntryType](capacity=sizeIncrement)
        state.dataOutRptPredefined.sizeCompSizeTableEntry = sizeIncrement
        state.dataOutRptPredefined.numCompSizeTableEntry = 1
    else:
        state.dataOutRptPredefined.numCompSizeTableEntry += 1
        if state.dataOutRptPredefined.numCompSizeTableEntry > state.dataOutRptPredefined.sizeCompSizeTableEntry:
            state.dataOutRptPredefined.sizeCompSizeTableEntry *= 2
            state.dataOutRptPredefined.CompSizeTableEntry.reserve(state.dataOutRptPredefined.sizeCompSizeTableEntry)
    var idx = state.dataOutRptPredefined.numCompSizeTableEntry - 1
    state.dataOutRptPredefined.CompSizeTableEntry[idx].typeField = String(FieldType)
    state.dataOutRptPredefined.CompSizeTableEntry[idx].nameField = String(FieldName)
    state.dataOutRptPredefined.CompSizeTableEntry[idx].description = String(FieldDescription)
    state.dataOutRptPredefined.CompSizeTableEntry[idx].valField = FieldValue

