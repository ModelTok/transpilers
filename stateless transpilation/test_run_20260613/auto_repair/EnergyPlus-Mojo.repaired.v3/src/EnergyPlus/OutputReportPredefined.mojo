    state.dataOutRptPredefined.CompSizeTableEntry[idx].nameField = String(FieldName)
    state.dataOutRptPredefined.CompSizeTableEntry[idx].description = String(FieldDescription)
    state.dataOutRptPredefined.CompSizeTableEntry[idx].strField = String(FieldValue)

def AddShadowRelateTableEntry(inout state: EnergyPlusData, castingField: Int, receivingField: Int, receivingKind: Int):
    if len(state.dataOutRptPredefined.ShadowRelate) == 0:
        state.dataOutRptPredefined.ShadowRelate = List[ShadowRelateType](capacity=sizeIncrement)
        state.dataOutRptPredefined.sizeShadowRelate = sizeIncrement
        state.dataOutRptPredefined.numShadowRelate = 1
    else:
        state.dataOutRptPredefined.numShadowRelate += 1
        if state.dataOutRptPredefined.numShadowRelate > state.dataOutRptPredefined.sizeShadowRelate:
            state.dataOutRptPredefined.sizeShadowRelate *= 2
            state.dataOutRptPredefined.ShadowRelate.reserve(state.dataOutRptPredefined.sizeShadowRelate)
    var idx = state.dataOutRptPredefined.numShadowRelate - 1
    state.dataOutRptPredefined.ShadowRelate[idx].castSurf = castingField
    state.dataOutRptPredefined.ShadowRelate[idx].recSurf = receivingField
    state.dataOutRptPredefined.ShadowRelate[idx].recKind = receivingKind

def newPreDefReport(inout state: EnergyPlusData, inReportName: StringLiteral, inReportAbrev: StringLiteral, inReportNamewithSpaces: StringLiteral) -> Int:
    var newPreDefReport: Int
    if len(state.dataOutRptPredefined.reportName) == 0:
        state.dataOutRptPredefined.reportName = List[reportNameType](capacity=sizeIncrement)
        state.dataOutRptPredefined.sizeReportName = sizeIncrement
        state.dataOutRptPredefined.numReportName = 1
    else:
        state.dataOutRptPredefined.numReportName += 1
        if state.dataOutRptPredefined.numReportName > state.dataOutRptPredefined.sizeReportName:
            state.dataOutRptPredefined.sizeReportName *= 2
            state.dataOutRptPredefined.reportName.reserve(state.dataOutRptPredefined.sizeReportName)
    var idx = state.dataOutRptPredefined.numReportName - 1
    state.dataOutRptPredefined.reportName[idx].name = String(inReportName)
    state.dataOutRptPredefined.reportName[idx].abrev = String(inReportAbrev)
    state.dataOutRptPredefined.reportName[idx].namewithspaces = String(inReportNamewithSpaces)
    state.dataOutRptPredefined.reportName[idx].show = False
    newPreDefReport = state.dataOutRptPredefined.numReportName
    return newPreDefReport

def newPreDefSubTable(inout state: EnergyPlusData, reportIndex: Int, subTableName: StringLiteral) -> Int:
    if len(state.dataOutRptPredefined.subTable) == 0:
        state.dataOutRptPredefined.subTable = List[SubTableType](capacity=sizeIncrement)
        state.dataOutRptPredefined.sizeSubTable = sizeIncrement
        state.dataOutRptPredefined.numSubTable = 1
    else:
        state.dataOutRptPredefined.numSubTable += 1
        if state.dataOutRptPredefined.numSubTable > state.dataOutRptPredefined.sizeSubTable:
            state.dataOutRptPredefined.sizeSubTable *= 2
            state.dataOutRptPredefined.subTable.reserve(state.dataOutRptPredefined.sizeSubTable)
    var idx = state.dataOutRptPredefined.numSubTable - 1
    state.dataOutRptPredefined.subTable[idx].name = String(subTableName)
    state.dataOutRptPredefined.subTable[idx].indexReportName = reportIndex
    return state.dataOutRptPredefined.numSubTable

def addFootNoteSubTable(inout state: EnergyPlusData, subTableIndex: Int, footnoteText: StringLiteral):
    if (subTableIndex >= 0) and (subTableIndex <= state.dataOutRptPredefined.numSubTable):
        state.dataOutRptPredefined.subTable[subTableIndex - 1].footnote = String(footnoteText)

def newPreDefColumn(inout state: EnergyPlusData, subTableIndex: Int, columnHeading: StringLiteral) -> Int:
    var newPreDefColumn: Int
    if len(state.dataOutRptPredefined.columnTag) == 0:
        state.dataOutRptPredefined.columnTag = List[ColumnTagType](capacity=sizeIncrement)
        state.dataOutRptPredefined.sizeColumnTag = sizeIncrement
        state.dataOutRptPredefined.numColumnTag = 1
    else:
        state.dataOutRptPredefined.numColumnTag += 1
        if state.dataOutRptPredefined.numColumnTag > state.dataOutRptPredefined.sizeColumnTag:
            state.dataOutRptPredefined.sizeColumnTag *= 2
            state.dataOutRptPredefined.columnTag.reserve(state.dataOutRptPredefined.sizeColumnTag)
    var idx = state.dataOutRptPredefined.numColumnTag - 1
    state.dataOutRptPredefined.columnTag[idx].heading = String(columnHeading)
    state.dataOutRptPredefined.columnTag[idx].indexSubTable = subTableIndex
    newPreDefColumn = state.dataOutRptPredefined.numColumnTag
    return newPreDefColumn