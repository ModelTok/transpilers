from testing import *
from ObjexxFCL.Array5D import Array5D
from ObjexxFCL.unit import *

def test_Array5Test_ConstructDefault():
    var A = Array5D[Int]()
    assert_equal(0, A.size())
    assert_equal(0, A.size1())
    assert_equal(0, A.size2())
    assert_equal(0, A.size3())
    assert_equal(0, A.size4())
    assert_equal(0, A.size5())
    assert_equal(1, A.l1())
    assert_equal(1, A.l2())
    assert_equal(1, A.l3())
    assert_equal(1, A.l4())
    assert_equal(1, A.l5())
    assert_equal(0, A.u1())
    assert_equal(0, A.u2())
    assert_equal(0, A.u3())
    assert_equal(0, A.u4())
    assert_equal(0, A.u5())
    assert_equal(Array5D[Int].IR(), A.I1())
    assert_equal(Array5D[Int].IR(), A.I2())
    assert_equal(Array5D[Int].IR(), A.I3())
    assert_equal(Array5D[Int].IR(), A.I4())
    assert_equal(Array5D[Int].IR(), A.I5())

def test_Array5Test_ConstructCopy():
    var A = Array5D[Int]()
    var B = Array5D[Int](A)
    assert_equal(A.size(), B.size())
    assert_equal(A.size1(), B.size1())
    assert_equal(A.size2(), B.size2())
    assert_equal(A.size3(), B.size3())
    assert_equal(A.size4(), B.size4())
    assert_equal(A.size5(), B.size5())
    assert_equal(A.l1(), B.l1())
    assert_equal(A.l2(), B.l2())
    assert_equal(A.l3(), B.l3())
    assert_equal(A.l4(), B.l4())
    assert_equal(A.l5(), B.l5())
    assert_equal(A.u1(), B.u1())
    assert_equal(A.u2(), B.u2())
    assert_equal(A.u3(), B.u3())
    assert_equal(A.u4(), B.u4())
    assert_equal(A.u5(), B.u5())
    assert_equal(A.I1(), B.I1())
    assert_equal(A.I2(), B.I2())
    assert_equal(A.I3(), B.I3())
    assert_equal(A.I4(), B.I4())
    assert_equal(A.I5(), B.I5())
    assert_true(conformable(A, B))
    assert_true(equal_dimensions(A, B))
    assert_true(eq(A, B))

def test_Array5Test_ConstructIndexes():
    var A = Array5D[Int]()
    A.allocate(3, 3, 3, 3, 3)
    assert_equal(243, A.size())
    assert_equal(3, A.size1())
    assert_equal(3, A.size2())
    assert_equal(3, A.size3())
    assert_equal(3, A.size4())
    assert_equal(3, A.size5())
    assert_equal(1, A.l1())
    assert_equal(1, A.l2())
    assert_equal(1, A.l3())
    assert_equal(1, A.l4())
    assert_equal(1, A.l5())
    assert_equal(3, A.u1())
    assert_equal(3, A.u2())
    assert_equal(3, A.u3())
    assert_equal(3, A.u4())
    assert_equal(3, A.u5())
    assert_equal(Array5D[Int].IR(1, 3), A.I1())
    assert_equal(Array5D[Int].IR(1, 3), A.I2())
    assert_equal(Array5D[Int].IR(1, 3), A.I3())
    assert_equal(Array5D[Int].IR(1, 3), A.I4())
    assert_equal(Array5D[Int].IR(1, 3), A.I5())

def test_Array5Test_RangeBasedFor():
    var A = Array5D[Int]()
    A.allocate(2, 2, 2, 2, 2)
    var v: Int = 0
    for e in A:
        e = v + 1
        v = v + 1
        assert_equal(v, e)

def test_Array5Test_Predicates():
    var A1 = Array5D[Int]()
    assert_false(A1.active())
    assert_false(A1.allocated())
    assert_true(A1.empty())
    assert_true(A1.size_bounded())
    assert_true(A1.owner())
    assert_false(A1.proxy())
    var A2 = Array5D[Int]()
    A2.allocate(2, 3, 2, 2, 3)
    assert_true(A2.active())
    assert_true(A2.allocated())
    assert_false(A2.empty())
    assert_true(A2.owner())
    assert_false(A2.proxy())

def test_Array5Test_PredicateComparisonsValues():
    var A1 = Array5D[Int]()
    assert_true(eq(A1, 0) and eq(0, A1))