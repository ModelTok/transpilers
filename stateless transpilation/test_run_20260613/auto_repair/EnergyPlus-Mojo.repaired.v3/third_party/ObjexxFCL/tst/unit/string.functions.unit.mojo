from testing import expect_true, expect_false, expect_equal
from ObjexxFCL.string.functions import *

@test
def Predicate():
    expect_true(empty(String("")))
    expect_false(empty(String("X")))
    expect_true(is_blank(String("")))
    expect_true(is_blank(String(" ")))
    expect_true(is_blank(String("  ")))
    expect_false(is_blank(String("x")))
    expect_true(not_blank(String("x")))
    expect_true(is_whitespace(String(" ")))
    expect_true(is_whitespace(String("\t")))
    expect_false(is_whitespace(String("x")))
    expect_true(is_digit(String("4")))
    expect_false(is_digit(String("P")))
    expect_true(is_lower(String("e")))
    expect_false(is_lower(String("E")))
    expect_true(is_upper(String("B")))
    expect_false(is_upper(String("b")))
    expect_true(has_lower(String("eYe")))
    expect_false(has_lower(String("EXO")))
    expect_true(has_upper(String("Boo")))
    expect_false(has_upper(String("boo")))
    expect_true(has(String("cake"), String("ak")))
    expect_true(has(String("cake"), "ak"))
    expect_true(has(String("cake"), 'a'))
    expect_true(hasi(String("cake"), 'a'))
    expect_true(hasi(String("cake"), 'K'))
    expect_false(has(String("cake"), String("ax")))
    expect_false(has(String("cake"), "ax"))
    expect_false(has(String("cake"), 'M'))
    expect_false(hasi(String("cake"), 'Z'))
    expect_true(has_any_of(String("x"), String("xyz")))
    expect_true(has_any_of(String("x"), "xyz"))
    expect_false(has_any_of(String("b"), String("xyz")))
    expect_false(has_any_of(String("b"), "xyz"))
    expect_true(has_prefix(String("Cat and Dog"), String("Cat")))
    expect_true(has_prefix(String("Cat and Dog"), "Cat"))
    expect_true(has_prefix(String("Cat and Dog"), 'C'))
    expect_false(has_prefix(String("Cat and Dog"), String("Bat")))
    expect_false(has_prefix(String("Cat and Dog"), "Bat"))
    expect_false(has_prefix(String("Cat and Dog"), 'B'))
    expect_true(has_prefixi(String("Cat and Dog"), "CAT"))
    expect_false(has_prefixi(String("Cat and Dog"), "BAT"))
    let s = String("Fish Tank")
    expect_true(has_prefix(s, "Fi"))
    expect_true(has_prefixi(s, "FIsh"))
    expect_false(has_prefix(s, "Fin"))
    expect_false(has_prefixi(s, "Fin"))
    let t = String("A cat is a cat")
    expect_true(is_type[Int32](String("123")))
    expect_false(is_type[Int32](String("Fish")))
    expect_true(is_type[Int16](String("123")))
    expect_true(is_type[Int64](String("123")))
    expect_true(is_type[Float32](String("123")))
    expect_false(is_type[Float32](String("123Go")))
    expect_true(is_type[Float64](String("123")))
    expect_true(is_type[Float32](String("123.456")))
    expect_true(is_type[Float64](String("123.456")))
    expect_true(is_type[Float64](String("123.456e2")))
    expect_true(is_type[Bool](String("0")))
    expect_true(is_type[Bool](String("00")))
    expect_true(is_type[Bool](String("1")))
    expect_true(is_type[Bool](String("01")))
    expect_false(is_type[Bool](String("11")))
    expect_true(is_type[Bool](String("T")))
    expect_true(is_type[Bool](String("t")))
    expect_true(is_type[Bool](String("F")))
    expect_true(is_type[Bool](String("f")))
    expect_true(is_type[Bool](String("true")))
    expect_false(is_type[Bool](String("true X")))
    expect_true(is_type[Bool](String("false")))
    expect_false(is_type[Bool](String("false X")))
    expect_false(is_type[Bool](String("X")))
    expect_true(is_type[UInt8](String("F")))
    expect_false(is_type[UInt8](String("Foo")))
    expect_true(is_decimal(String("123")))
    expect_false(is_decimal(String("123Hats")))
    expect_false(is_decimal(String("123 Hats")))
    expect_true(is_binary(String("101100")))
    expect_false(is_binary(String("123")))
    expect_true(is_type[Bool]("0"))
    expect_true(is_type[Bool]("00"))
    expect_true(is_type[Bool]("1"))
    expect_true(is_type[Bool]("01"))
    expect_false(is_type[Bool]("11"))
    expect_true(is_type[Bool]("T"))
    expect_true(is_type[Bool]("t"))
    expect_true(is_type[Bool]("F"))
    expect_true(is_type[Bool]("f"))
    expect_true(is_type[Bool]("true"))
    expect_false(is_type[Bool]("true X"))
    expect_true(is_type[Bool]("false"))
    expect_false(is_type[Bool]("false X"))
    expect_false(is_type[Bool]("X"))
    expect_true(is_type[Int16]("123"))
    expect_true(is_type[Int32]("123"))
    expect_false(is_type[Int32]("Fish"))
    expect_true(is_type[Int64]("123"))
    expect_true(is_type[Float32]("123"))
    expect_false(is_type[Float32]("123Go"))
    expect_true(is_type[Float64]("123"))
    expect_true(is_type[Float64]("123"))
    expect_true(is_type[Float32]("123.456"))
    expect_true(is_type[Float64]("123.456"))
    expect_true(is_type[Float64]("123.456e2"))
    expect_true(is_type[Float64]("123.456"))
    expect_true(is_type[Float64]("123.456e2"))
    expect_true(is_type[UInt8]("F"))
    expect_false(is_type[UInt8]("Foo"))
    expect_true(is_bool("0"))
    expect_true(is_bool("00"))
    expect_true(is_bool("1"))
    expect_true(is_bool("01"))
    expect_false(is_bool("11"))
    expect_true(is_bool("T"))
    expect_true(is_bool("t"))
    expect_true(is_bool("F"))
    expect_true(is_bool("f"))
    expect_true(is_bool("true"))
    expect_false(is_bool("true X"))
    expect_true(is_bool("false"))
    expect_false(is_bool("false X"))
    expect_false(is_bool("X"))
    expect_true(is_short("123"))
    expect_true(is_int("123"))
    expect_false(is_int("Fish"))
    expect_true(is_float("123"))
    expect_false(is_float("123Go"))
    expect_true(is_double("123"))
    expect_true(is_float("123.456"))
    expect_true(is_double("123.456"))
    expect_true(is_double("123.456e2"))
    expect_true(is_char("F"))
    expect_false(is_char("Foo"))
    expect_true(is_decimal("123"))
    expect_false(is_decimal("123Hats"))
    expect_false(is_decimal("123 Hats"))
    expect_true(is_binary("101100"))
    expect_false(is_binary("123"))

@test
def Comparison():
    expect_true(equali(String("a"), "A"))
    expect_false(equali(String("a"), "X"))
    expect_true(equal(String("a"), "a"))
    expect_true(equal("a", String("a"), True))
    expect_false(equal("a", "A"))
    expect_true(equal(String("a"), "A", False))
    expect_true(lessthan(String("a"), "b"))
    expect_true(lessthan("a", String("b"), True))
    expect_false(lessthan("a", String("B"), True))
    expect_true(lessthan(String("A"), "b", False))
    expect_false(lessthan("b", String("A"), False))
    expect_true(lessthani(String("a"), "b"))
    expect_true(lessthani("a", String("B")))
    expect_true(lessthani(String("A"), "b"))
    var s = String("Fish")
    var t = String("FishY")
    expect_equal(String("Fish"), s)
    expect_true(equali(s, "fiSh"))
    expect_false(equali(s, "fiShY"))
    expect_false(equali(s, t))
    expect_true(equali("fiSh", s))
    expect_false(equali("fiShY", s))
    expect_true(equali("FISH", "fiSh"))
    expect_false(equali("FISH", "fiShY"))
    expect_true(equali("FISH ", "fiSh "))
    expect_false(equali("FISH", "fiSh "))
    expect_false(equali("FISH ", "fiSh"))
    expect_true(equal(s, "fiSh", False))
    expect_true(equal(s, "Fish"))
    expect_true(equal(s, "FiSh", False))
    expect_false(equal(s, "fiSh"))
    expect_false(equal(s, "fiSh", True))
    lowercase(s)
    expect_equal(String("fish"), s)
    uppercase(s)
    expect_equal(String("FISH"), s)
    expect_equal(String("fish"), lowercased(s))
    expect_equal(String("FISH"), uppercased(s))
    expect_true(lessthani(s, "fiShY"))
    expect_false(lessthani(s, "fiSh"))
    expect_true(lessthani(s, "GISH"))
    expect_true(lessthani("aaa", "Z"))
    expect_true(llt(String("a"), String("b")))
    expect_false(llt(String("a"), String("a")))
    expect_false(llt("b", String("a")))
    expect_true(lle(String("a"), String("b")))
    expect_true(lle(String("a"), String("a")))
    expect_false(lle("b", String("a")))
    expect_false(lgt(String("a"), String("b")))
    expect_false(lgt(String("a"), String("a")))
    expect_true(lgt("b", String("a")))
    expect_false(lge(String("a"), String("b")))
    expect_true(lge(String("a"), String("a")))
    expect_true(lge("b", String("a")))

@test
def Inspector():
    expect_equal(7, len(String("Zip Cat")))
    expect_equal(4, len(String("Zip ")))
    expect_equal(3, len_trim(String("Zip ")))
    expect_equal(1, index(String("Cat in Hat"), "at"))
    expect_equal(8, index(String("Cat in Hat"), "at", True))
    expect_equal(8, rindex(String("Cat in Hat"), "at"))
    expect_equal(1, indexi(String("Cat in Hat"), "AT"))
    expect_equal(8, indexi(String("Cat in Hat"), "AT", True))
    expect_equal(1, scan(String("Cat in Hat"), "XaBt"))
    expect_equal(9, scan(String("Cat in Hat"), "XaBt", True))
    expect_equal(2, verify(String("Cat in Hat"), "CaBo"))
    expect_equal(7, verify(String("Cat in Hat"), "XaBt", True))
    expect_equal(7, len("Zip Cat"))
    expect_equal(4, len("Zip "))
    expect_equal(3, len_trim("Zip "))
    expect_equal(1, index("Cat in Hat", "at"))
    expect_equal(8, index("Cat in Hat", "at", True))
    expect_equal(8, rindex("Cat in Hat", "at"))
    expect_equal(1, indexi("Cat in Hat", "AT"))
    expect_equal(8, indexi("Cat in Hat", "AT", True))
    expect_equal(1, scan("Cat in Hat", "XaBt"))
    expect_equal(9, scan("Cat in Hat", "XaBt", True))
    expect_equal(2, verify("Cat in Hat", "CaBo"))
    expect_equal(7, verify("Cat in Hat", "XaBt", True))

@test
def Conversion():
    expect_equal(99, ichar(String("c")))
    expect_equal(99, ichar("c"))
    expect_equal(String("c"), achar(99))

@test
def ConversionTo():
    expect_false(type_of[Bool](String("0")))
    expect_true(type_of[Bool](String("1")))
    expect_false(type_of[Bool](String("F")))
    expect_true(type_of[Bool](String("T")))
    expect_false(type_of[Bool](String("false")))
    expect_true(type_of[Bool](String("true")))
    expect_equal(123, type_of[Int32](String("123")))
    expect_equal(Int16(123), type_of[Int16](String("123")))
    expect_equal(Int64(123), type_of[Int64](String("123")))
    expect_equal(UInt32(123), type_of[UInt32](String("123")))
    expect_equal(Float32(123.0), type_of[Float32](String("123")))
    expect_equal(Float32(123.75), type_of[Float32](String("123.75")))
    expect_equal(Float64(123.0), type_of[Float64](String("123")))
    expect_equal(Float64(123.75), type_of[Float64](String("123.75")))
    expect_equal('X', type_of[UInt8](String("X")))
    expect_false(type_of[Bool]("0"))
    expect_true(type_of[Bool]("1"))
    expect_false(type_of[Bool]("F"))
    expect_true(type_of[Bool]("T"))
    expect_false(type_of[Bool]("false"))
    expect_true(type_of[Bool]("true"))
    expect_equal(123, type_of[Int32]("123"))
    expect_equal(Int16(123), type_of[Int16]("123"))
    expect_equal(Int64(123), type_of[Int64]("123"))
    expect_equal(UInt32(123), type_of[UInt32]("123"))
    expect_equal(Float32(123.0), type_of[Float32]("123"))
    expect_equal(Float32(123.75), type_of[Float32]("123.75"))
    expect_equal(Float64(123.0), type_of[Float64]("123"))
    expect_equal(Float64(123.75), type_of[Float64]("123.75"))
    expect_equal('X', type_of[UInt8]("X"))

@test
def Modifier():
    var s = String("Big Dog")
    lowercase(s)
    expect_equal(String("big dog"), s)
    uppercase(s)
    expect_equal(String("big dog"), lowercase(s))
    uppercase(s)
    expect_equal(String("BIG DOG"), s)
    s = String("Dog  ")
    expect_equal(String("Dog"), trim(s))
    s = String("aBana")
    expect_equal(String("B"), strip(s, "an"))
    s = String("aBana")
    expect_equal(String("Bana"), lstrip(s, "an"))
    s = String("aBana")
    expect_equal(String("aB"), rstrip(s, "an"))
    s = String(" Dog   ")
    expect_equal(String("Dog"), strip(s))
    s = String(" Dog   ")
    expect_equal(String("Dog   "), lstrip(s))
    s = String(" Dog   ")
    expect_equal(String(" Dog"), rstrip(s))
    s = String("Dog")
    expect_equal(String("Dog   "), pad(s, 6))
    s = String("Dog")
    expect_equal(String("   Dog"), lpad(s, 6))
    s = String("Dog")
    expect_equal(String("Dog   "), rpad(s, 6))
    s = String("Doggy")
    expect_equal(String("Dog"), pare(s, 3))
    s = String("a Dog")
    expect_equal(String("Dog"), lpare(s, 3))
    s = String("Doggy")
    expect_equal(String("Dog"), rpare(s, 3))
    s = String("A long story")
    expect_equal(String("A lo"), size(s, 4))
    s = String("A long story")
    expect_equal(String("tory"), lsize(s, 4))
    s = String("A long story")
    expect_equal(String("A lo"), rsize(s, 4))
    s = String("   Center Me     ")
    expect_equal(String("    Center Me    "), center(s))
    s = String("   Center Me     ")
    expect_equal(String("      Center Me      "), center(s, 21))
    s = String("   Center Me     ")
    expect_equal(String("Center Me"), center(s, 9))
    s = String("   Center Me     ")
    expect_equal(String("enter M"), center(s, 7))
    s = String("   Center Me     ")
    expect_equal(String("nter "), center(s, 5))
    s = String("   Center Me     ")
    expect_equal(String("ter"), center(s, 3))
    s = String("Banana")
    expect_equal(String("Ban"), unique(s))
    s = String("Banana")
    expect_equal(String("Bonono"), replace(s, "a", "o"))
    s = String("Banana")
    expect_equal(String("Bonona"), replace(s, "an", "on"))
    s = String("Bat")
    expect_equal(String("\"Bat\""), quote(s))
    s = String("Cat")
    expect_equal(String("Dog"), overlay(s, "Dog"))
    s = String("Cat and Dog")
    expect_equal(String("Cat Hat Dog"), overlay(s, "Hat", 4))
    s = String("Cat and Dog")
    expect_equal(String("Cat and Gator"), overlay(s, "Gator", 8))

@test
def Generator():
    expect_equal(String("     "), blank(5))
    expect_equal(String("big dog"), lowercased(String("Big Dog")))
    expect_equal(String("BIG DOG"), uppercased(String("Big Dog")))
    expect_equal(String("Dog  "), ljustified(String("  Dog")))
    expect_equal(String("  Dog"), rjustified(String("Dog  ")))
    expect_equal(String("Dog"), trimmed(String("Dog  ")))
    expect_equal(String("Dog"), trimmed_whitespace(String("Dog \t \0  ")))
    expect_equal(String("B"), stripped(String("aBana"), "an"))
    expect_equal(String("Bana"), lstripped(String("aBana"), "an"))
    expect_equal(String("aB"), rstripped(String("aBana"), "an"))
    expect_equal(String("Dog"), stripped(String(" Dog   ")))
    expect_equal(String("Dog   "), lstripped(String(" Dog   ")))
    expect_equal(String(" Dog"), rstripped(String(" Dog   ")))
    expect_equal(String("Dog"), stripped_whitespace(String(" Dog \t ")))
    expect_equal(String("Cat  "), padded(String("Cat"), 5))
    expect_equal(String("  Cat"), lpadded(String("Cat"), 5))
    expect_equal(String("Cat  "), rpadded(String("Cat"), 5))
    expect_equal(String("Dog"), pared(String("Doggy"), 3))
    expect_equal(String("Dog"), lpared(String("a Dog"), 3))
    expect_equal(String("Dog"), rpared(String("Doggy"), 3))
    expect_equal(String("A lo"), sized(String("A long story"), 4))
    expect_equal(String("tory"), lsized(String("A long story"), 4))
    expect_equal(String("A lo"), rsized(String("A long story"), 4))
    expect_equal(String("    Center Me    "), centered(String("   Center Me     ")))
    expect_equal(String("      Center Me      "), centered(String("   Center Me     "), 21))
    expect_equal(String("Center Me"), centered(String("   Center Me     "), 9))
    expect_equal(String("enter M"), centered(String("   Center Me     "), 7))
    expect_equal(String("nter "), centered(String("   Center Me     "), 5))
    expect_equal(String("ter"), centered(String("   Center Me     "), 3))
    expect_equal(String("Ban"), uniqued(String("Banana")))
    expect_equal(String("Bonono"), replaced(String("Banana"), "a", "o"))
    expect_equal(String("Bonona"), replaced(String("Banana"), "an", "on"))
    expect_equal(String("Dog"), overlayed(String("Cat"), "Dog"))
    expect_equal(String("Cat Hat Dog"), overlayed(String("Cat and Dog"), "Hat", 4))
    expect_equal(String("Cat and Gator"), overlayed(String("Cat and Dog"), "Gator", 8))
    expect_equal(String("Dog"), overlaid(String("Cat"), "Dog"))
    expect_equal(String("Cat Hat Dog"), overlaid(String("Cat and Dog"), "Hat", 4))
    expect_equal(String("Cat and Gator"), overlaid(String("Cat and Dog"), "Gator", 8))
    expect_equal(String("HaHaHa"), repeated(String("Ha"), 3))
    expect_equal(String("HaHaHa"), repeat(String("Ha"), 3))
    expect_equal(String("Fish"), head(String("Fish gotta swim")))

@test
def ConversionToString():
    expect_equal(String("123"), string_of[Int32](123))
    expect_equal(String("123"), string_of(123))
    expect_equal(String("123.5"), string_of(123.5))
    expect_equal(String("123.125"), string_of(123.1251, 6))
    expect_equal(String("123  "), lstring_of(123, 5))
    expect_equal(String("123AA"), lstring_of(123, 5, 'A'))
    expect_equal(String("1.125"), general_string_of(1.1251, 5, 4))
    expect_equal(String("1.125"), fixed_string_of(1.1251, 5, 3))
    # // #if defined(__GNUC__) && defined(_WIN32) _set_output_format(_TWO_DIGIT_EXPONENT); #endif

@test
def StripSpace():
    var s = String("  Fish ")
    expect_equal(String("Fish"), stripped(s))
    expect_equal(String("Fish "), lstripped(s))
    expect_equal(String("  Fish"), rstripped(s))
    lstrip(s)
    expect_equal(String("Fish "), s)
    rstrip(s)
    expect_equal(String("Fish"), s)
    s = String("  Cow  ")
    strip(s)
    expect_equal(String("Cow"), s)

@test
def StripWhitespace():
    var s = String(" \0\0\t \t\0\t Fish \t\0 ")
    expect_equal(String("\0\0\t \t\0\t Fish \t\0"), stripped(s))
    expect_equal(String("Fish"), stripped_whitespace(s))

@test
def StripSpecifiedCharacters():
    var s = String("Fish")
    expect_equal(String("Fis"), stripped(s, "h"))
    expect_equal(String("ish"), stripped(s, "F"))
    expect_equal(String("is"), stripped(s, "Fh"))
    expect_equal(String("Fish"), lstripped(s, "xyz"))
    expect_equal(String("ish"), lstripped(s, "Fx"))
    expect_equal(String("Fish"), rstripped(s, "abc"))
    expect_equal(String("Fi"), rstripped(s, "asbch"))
    lstrip(s, "F")
    expect_equal(String("ish"), s)
    rstrip(s, "sh")
    expect_equal(String("i"), s)

@test
def Centering():
    var s = String("    Fish Tank")
    expect_equal(String("  Fish Tank  "), centered(s))
    expect_equal(String("  Fish Tank  "), center(s))
    expect_equal(String("  Fish Tank  "), s)

@test
def Replace():
    let s = String("Fish Tank")
    expect_equal(String("Dish Tank"), replaced(s, "F", "D"))
    expect_equal(String("Foolish Tank"), replaced(s, "ish", "oolish"))
    expect_equal(String("Fish Truck"), replaced(s, "ank", "ruck"))
    let t = String("A \\\"Fishy\\\" Story")
    let t2 = String("A \"Fishy\" Story")
    let slash = String("\\")
    let dslash = String("\\\\")
    let slash_dquote = String("\\\"")
    let dquote = String("\"")
    expect_equal(t2, replaced(replaced(t, dslash, slash), slash_dquote, dquote))

@test
def Repeated():
    let s = String("Fish")
    expect_equal(String("FishFishFish"), repeated(s, 3))

@test
def Pad():
    var s = String("Fish Tank")
    expect_equal(String("Fish Tank"), padded(s, 5))
    expect_equal(String("Fish Tank   "), padded(s, 12))
    expect_equal(String("Fish Tank"), pad(s, 5))
    expect_equal(String("Fish Tank   "), pad(s, 12))

@test
def Pare():
    var s = String("Fish Tank")
    expect_equal(String("Fish Tank"), pared(s, 12))
    expect_equal(String("Fish"), pared(s, 4))
    expect_equal(String("Fish Tank"), pare(s, 12))
    expect_equal(String("Fish"), pare(s, 4))