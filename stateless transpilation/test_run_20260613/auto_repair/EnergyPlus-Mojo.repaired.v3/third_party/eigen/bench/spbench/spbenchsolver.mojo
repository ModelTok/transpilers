# using namespace Eigen;
# using namespace std;

var EIGEN_UMFPACK: Int = 10
var EIGEN_SUPERLU: Int = 20
var EIGEN_PASTIX: Int = 30
var EIGEN_PARDISO: Int = 40
var EIGEN_SPARSELU_COLAMD: Int = 50
var EIGEN_SPARSELU_METIS: Int = 51
var EIGEN_BICGSTAB: Int = 60
var EIGEN_BICGSTAB_ILUT: Int = 61
var EIGEN_GMRES: Int = 70
var EIGEN_GMRES_ILUT: Int = 71
var EIGEN_SIMPLICIAL_LDLT: Int = 80
var EIGEN_CHOLMOD_LDLT: Int = 90
var EIGEN_PASTIX_LDLT: Int = 100
var EIGEN_PARDISO_LDLT: Int = 110
var EIGEN_SIMPLICIAL_LLT: Int = 120
var EIGEN_CHOLMOD_SUPERNODAL_LLT: Int = 130
var EIGEN_CHOLMOD_SIMPLICIAL_LLT: Int = 140
var EIGEN_PASTIX_LLT: Int = 150
var EIGEN_PARDISO_LLT: Int = 160
var EIGEN_CG: Int = 170
var EIGEN_CG_PRECOND: Int = 180

# Translating global variables
var MaximumIters: Int  # Maximum number of iterations
var RelErr: Float64  # Relative error of the computed solution
var best_time_val: Float64  # Current best time overall solvers
var best_time_id: Int  # id of the best solver for the current system

# Template specializations for test_precision - using overloaded functions
def test_precision(type: AnyType) -> Float64:
    return NumTraits[type].dummy_precision()  # placeholder

def test_precision[_type: Float32]() -> Float32:
    return 1e-3f

def test_precision[_type: Float64]() -> Float64:
    return 1e-6

def test_precision[_type: ComplexFloat32]() -> Float32:
    return test_precision[Float32]()

def test_precision[_type: ComplexFloat64]() -> Float64:
    return test_precision[Float64]()

def printStatheader(out: FileHandle):
    out.write("<?xml version='1.0' encoding='UTF-8'?> \n")
    out.write("<?xml-stylesheet type='text/xsl' href='#stylesheet' ?> \n")
    out.write("<!DOCTYPE BENCH  [\n<!ATTLIST xsl:stylesheet\n id\t ID  #REQUIRED>\n]>")
    out.write("\n\n<!-- Generated by the Eigen library -->\n")
    out.write("\n<BENCH> \n")
    printBenchStyle(out)
    out.write(" <AVAILSOLVER> \n")
    # EIGEN_UMFPACK_SUPPORT - assume true
    out.write("  <SOLVER ID='" + str(EIGEN_UMFPACK) + "'>\n")
    out.write("   <TYPE> LU </TYPE> \n")
    out.write("   <PACKAGE> UMFPACK </PACKAGE> \n")
    out.write("  </SOLVER> \n")
    # EIGEN_SUPERLU_SUPPORT
    out.write("  <SOLVER ID='" + str(EIGEN_SUPERLU) + "'>\n")
    out.write("   <TYPE> LU </TYPE> \n")
    out.write("   <PACKAGE> SUPERLU </PACKAGE> \n")
    out.write("  </SOLVER> \n")
    # EIGEN_CHOLMOD_SUPPORT
    out.write("  <SOLVER ID='" + str(EIGEN_CHOLMOD_SIMPLICIAL_LLT) + "'>\n")
    out.write("   <TYPE> LLT SP</TYPE> \n")
    out.write("   <PACKAGE> CHOLMOD </PACKAGE> \n")
    out.write("  </SOLVER> \n")
    out.write("  <SOLVER ID='" + str(EIGEN_CHOLMOD_SUPERNODAL_LLT) + "'>\n")
    out.write("   <TYPE> LLT</TYPE> \n")
    out.write("   <PACKAGE> CHOLMOD </PACKAGE> \n")
    out.write("  </SOLVER> \n")
    out.write("  <SOLVER ID='" + str(EIGEN_CHOLMOD_LDLT) + "'>\n")
    out.write("   <TYPE> LDLT </TYPE> \n")
    out.write("   <PACKAGE> CHOLMOD </PACKAGE> \n")
    out.write("  </SOLVER> \n")
    # EIGEN_PARDISO_SUPPORT
    out.write("  <SOLVER ID='" + str(EIGEN_PARDISO) + "'>\n")
    out.write("   <TYPE> LU </TYPE> \n")
    out.write("   <PACKAGE> PARDISO </PACKAGE> \n")
    out.write("  </SOLVER> \n")
    out.write("  <SOLVER ID='" + str(EIGEN_PARDISO_LLT) + "'>\n")
    out.write("   <TYPE> LLT </TYPE> \n")
    out.write("   <PACKAGE> PARDISO </PACKAGE> \n")
    out.write("  </SOLVER> \n")
    out.write("  <SOLVER ID='" + str(EIGEN_PARDISO_LDLT) + "'>\n")
    out.write("   <TYPE> LDLT </TYPE> \n")
    out.write("   <PACKAGE> PARDISO </PACKAGE> \n")
    out.write("  </SOLVER> \n")
    # EIGEN_PASTIX_SUPPORT
    out.write("  <SOLVER ID='" + str(EIGEN_PASTIX) + "'>\n")
    out.write("   <TYPE> LU </TYPE> \n")
    out.write("   <PACKAGE> PASTIX </PACKAGE> \n")
    out.write("  </SOLVER> \n")
    out.write("  <SOLVER ID='" + str(EIGEN_PASTIX_LLT) + "'>\n")
    out.write("   <TYPE> LLT </TYPE> \n")
    out.write("   <PACKAGE> PASTIX </PACKAGE> \n")
    out.write("  </SOLVER> \n")
    out.write("  <SOLVER ID='" + str(EIGEN_PASTIX_LDLT) + "'>\n")
    out.write("   <TYPE> LDLT </TYPE> \n")
    out.write("   <PACKAGE> PASTIX </PACKAGE> \n")
    out.write("  </SOLVER> \n")
    # Eigen iterative solvers
    out.write("  <SOLVER ID='" + str(EIGEN_BICGSTAB) + "'>\n")
    out.write("   <TYPE> BICGSTAB </TYPE> \n")
    out.write("   <PACKAGE> EIGEN </PACKAGE> \n")
    out.write("  </SOLVER> \n")
    out.write("  <SOLVER ID='" + str(EIGEN_BICGSTAB_ILUT) + "'>\n")
    out.write("   <TYPE> BICGSTAB_ILUT </TYPE> \n")
    out.write("   <PACKAGE> EIGEN </PACKAGE> \n")
    out.write("  </SOLVER> \n")
    out.write("  <SOLVER ID='" + str(EIGEN_GMRES_ILUT) + "'>\n")
    out.write("   <TYPE> GMRES_ILUT </TYPE> \n")
    out.write("   <PACKAGE> EIGEN </PACKAGE> \n")
    out.write("  </SOLVER> \n")
    out.write("  <SOLVER ID='" + str(EIGEN_SIMPLICIAL_LDLT) + "'>\n")
    out.write("   <TYPE> LDLT </TYPE> \n")
    out.write("   <PACKAGE> EIGEN </PACKAGE> \n")
    out.write("  </SOLVER> \n")
    out.write("  <SOLVER ID='" + str(EIGEN_SIMPLICIAL_LLT) + "'>\n")
    out.write("   <TYPE> LLT </TYPE> \n")
    out.write("   <PACKAGE> EIGEN </PACKAGE> \n")
    out.write("  </SOLVER> \n")
    out.write("  <SOLVER ID='" + str(EIGEN_CG) + "'>\n")
    out.write("   <TYPE> CG </TYPE> \n")
    out.write("   <PACKAGE> EIGEN </PACKAGE> \n")
    out.write("  </SOLVER> \n")
    out.write("  <SOLVER ID='" + str(EIGEN_SPARSELU_COLAMD) + "'>\n")
    out.write("   <TYPE> LU_COLAMD </TYPE> \n")
    out.write("   <PACKAGE> EIGEN </PACKAGE> \n")
    out.write("  </SOLVER> \n")
    # EIGEN_METIS_SUPPORT
    out.write("  <SOLVER ID='" + str(EIGEN_SPARSELU_METIS) + "'>\n")
    out.write("   <TYPE> LU_METIS </TYPE> \n")
    out.write("   <PACKAGE> EIGEN </PACKAGE> \n")
    out.write("  </SOLVER> \n")
    out.write(" </AVAILSOLVER> \n")

def call_solver[Solvertype: AnyType, Scalar: AnyType](
    solver: Solverptr,
    solver_id: Int,
    A: MatrixType,
    b: Matrix[Scalar, Dynamic, 1],
    refX: Matrix[Scalar, Dynamic, 1],
    statbuf: FileHandle):
    var total_time: Float64
    var compute_time: Float64
    var solve_time: Float64
    var rel_error: Float64
    var x: Matrix[Scalar, Dynamic, 1]
    var timer: BenchTimer
    timer.reset()
    timer.start()
    solver.compute(A)
    if solver.info() != Success:
        stderr.write("Solver failed ... \n")
        return
    timer.stop()
    compute_time = timer.value()
    statbuf.write("    <TIME>\n")
    statbuf.write("     <COMPUTE> " + str(timer.value()) + "</COMPUTE>\n")
    stdout.write("COMPUTE TIME : " + str(timer.value()) + "\n")
    timer.reset()
    timer.start()
    x = solver.solve(b)
    if solver.info() == NumericalIssue:
        stderr.write("Solver failed ... \n")
        return
    timer.stop()
    solve_time = timer.value()
    statbuf.write("     <SOLVE> " + str(timer.value()) + "</SOLVE>\n")
    stdout.write("SOLVE TIME : " + str(timer.value()) + "\n")
    total_time = solve_time + compute_time
    statbuf.write("     <TOTAL> " + str(total_time) + "</TOTAL>\n")
    stdout.write("TOTAL TIME : " + str(total_time) + "\n")
    statbuf.write("    </TIME>\n")
    if refX.size() != 0:
        rel_error = (refX - x).norm() / refX.norm()
    else:
        var temp: Matrix[Scalar, Dynamic, 1]
        temp = A * x
        rel_error = (b - temp).norm() / b.norm()
    statbuf.write("    <ERROR> " + str(rel_error) + "</ERROR>\n")
    stdout.write("REL. ERROR : " + str(rel_error) + "\n\n")
    if rel_error <= RelErr:
        if !best_time_val or (best_time_val > total_time):
            best_time_val = total_time
            best_time_id = solver_id

def call_directsolver[Solvertype: AnyType, Scalar: AnyType](
    solver: Solverptr,
    solver_id: Int,
    A: MatrixType,
    b: Matrix[Scalar, Dynamic, 1],
    refX: Matrix[Scalar, Dynamic, 1],
    statFile: String):
    var statbuf: FileHandle = open(statFile, "a")
    statbuf.write("   <SOLVER_STAT ID='" + str(solver_id) + "'>\n")
    call_solver(solver, solver_id, A, b, refX, statbuf)
    statbuf.write("   </SOLVER_STAT>\n")
    statbuf.close()

def call_itersolver[Solvertype: AnyType, Scalar: AnyType](
    solver: Solverptr,
    solver_id: Int,
    A: MatrixType,
    b: Matrix[Scalar, Dynamic, 1],
    refX: Matrix[Scalar, Dynamic, 1],
    statFile: String):
    solver.setTolerance(RelErr)
    solver.setMaxIterations(MaximumIters)
    var statbuf: FileHandle = open(statFile, "a")
    statbuf.write(" <SOLVER_STAT ID='" + str(solver_id) + "'>\n")
    call_solver(solver, solver_id, A, b, refX, statbuf)
    statbuf.write("   <ITER> " + str(solver.iterations()) + "</ITER>\n")
    statbuf.write(" </SOLVER_STAT>\n")
    stdout.write("ITERATIONS : " + str(solver.iterations()) + "\n\n\n")

def SelectSolvers[Scalar: AnyType](
    A: SparseMatrix[Scalar],
    sym: UInt,
    b: Matrix[Scalar, Dynamic, 1],
    refX: Matrix[Scalar, Dynamic, 1],
    statFile: String):
    type SpMat = SparseMatrix[Scalar, ColMajor]
    best_time_id = 0
    best_time_val = 0.0
    # EIGEN_UMFPACK_SUPPORT
    # (assumed true)
    var solver_umfpack: UmfPackLU[SpMat]
    stdout.write("Solving with UMFPACK LU ... \n")
    call_directsolver(solver_umfpack, EIGEN_UMFPACK, A, b, refX, statFile)
    # EIGEN_SUPERLU_SUPPORT
    var solver_superlu: SuperLU[SpMat]
    stdout.write("\nSolving with SUPERLU ... \n")
    call_directsolver(solver_superlu, EIGEN_SUPERLU, A, b, refX, statFile)
    # EIGEN_PASTIX_SUPPORT
    var solver_pastix_lu: PastixLU[SpMat]
    stdout.write("\nSolving with PASTIX LU ... \n")
    call_directsolver(solver_pastix_lu, EIGEN_PASTIX, A, b, refX, statFile)
    # EIGEN_PARDISO_SUPPORT
    var solver_pardiso_lu: PardisoLU[SpMat]
    stdout.write("\nSolving with PARDISO LU ... \n")
    call_directsolver(solver_pardiso_lu, EIGEN_PARDISO, A, b, refX, statFile)
    stdout.write("\n Solving with Sparse LU AND COLAMD ... \n")
    var solver_sparse_lu: SparseLU[SpMat, COLAMDOrdering[Int]]
    call_directsolver(solver_sparse_lu, EIGEN_SPARSELU_COLAMD, A, b, refX, statFile)
    # EIGEN_METIS_SUPPORT
    var solver_sparse_metis: SparseLU[SpMat, MetisOrdering[Int]]
    stdout.write("\n Solving with Sparse LU AND METIS ... \n")
    call_directsolver(solver_sparse_metis, EIGEN_SPARSELU_METIS, A, b, refX, statFile)
    # BiCGSTAB
    var solver_bicgstab: BiCGSTAB[SpMat]
    stdout.write("\nSolving with BiCGSTAB ... \n")
    call_itersolver(solver_bicgstab, EIGEN_BICGSTAB, A, b, refX, statFile)
    # BiCGSTAB + ILUT
    var solver_bicgstab_ilut: BiCGSTAB[SpMat, IncompleteLUT[Scalar]]
    stdout.write("\nSolving with BiCGSTAB and ILUT ... \n")
    call_itersolver(solver_bicgstab_ilut, EIGEN_BICGSTAB_ILUT, A, b, refX, statFile)
    # GMRES + ILUT
    var solver_gmres_ilut: GMRES[SpMat, IncompleteLUT[Scalar]]
    stdout.write("\nSolving with GMRES and ILUT ... \n")
    call_itersolver(solver_gmres_ilut, EIGEN_GMRES_ILUT, A, b, refX, statFile)
    # Only if sym != NonSymmetric
    if sym != NonSymmetric:
        # Simplicial LDLT
        var solver_simplicial_ldlt: SimplicialLDLT[SpMat, Lower]
        stdout.write("\nSolving with Simplicial LDLT ... \n")
        call_directsolver(solver_simplicial_ldlt, EIGEN_SIMPLICIAL_LDLT, A, b, refX, statFile)
        # EIGEN_CHOLMOD_SUPPORT
        var solver_cholmod_ldlt: CholmodDecomposition[SpMat, Lower]
        solver_cholmod_ldlt.setMode(CholmodLDLt)
        stdout.write("\nSolving with CHOLMOD LDLT ... \n")
        call_directsolver(solver_cholmod_ldlt, EIGEN_CHOLMOD_LDLT, A, b, refX, statFile)
        # EIGEN_PASTIX_SUPPORT
        var solver_pastix_ldlt: PastixLDLT[SpMat, Lower]
        stdout.write("\nSolving with PASTIX LDLT ... \n")
        call_directsolver(solver_pastix_ldlt, EIGEN_PASTIX_LDLT, A, b, refX, statFile)
        # EIGEN_PARDISO_SUPPORT
        var solver_pardiso_ldlt: PardisoLDLT[SpMat, Lower]
        stdout.write("\nSolving with PARDISO LDLT ... \n")
        call_directsolver(solver_pardiso_ldlt, EIGEN_PARDISO_LDLT, A, b, refX, statFile)
    # Only if sym == SPD
    if sym == SPD:
        # Simplicial LLT
        var solver_simplicial_llt: SimplicialLLT[SpMat, Lower]
        stdout.write("\nSolving with SIMPLICIAL LLT ... \n")
        call_directsolver(solver_simplicial_llt, EIGEN_SIMPLICIAL_LLT, A, b, refX, statFile)
        # EIGEN_CHOLMOD_SUPPORT
        var solver_cholmod_supernodal: CholmodDecomposition[SpMat, Lower]
        solver_cholmod_supernodal.setMode(CholmodSupernodalLLt)
        stdout.write("\nSolving with CHOLMOD LLT (Supernodal)... \n")
        call_directsolver(solver_cholmod_supernodal, EIGEN_CHOLMOD_SUPERNODAL_LLT, A, b, refX, statFile)
        stdout.write("\nSolving with CHOLMOD LLT (Simplicial) ... \n")
        var solver_cholmod_simplicial: CholmodDecomposition[SpMat, Lower]
        solver_cholmod_simplicial.setMode(CholmodSimplicialLLt)
        call_directsolver(solver_cholmod_simplicial, EIGEN_CHOLMOD_SIMPLICIAL_LLT, A, b, refX, statFile)
        # EIGEN_PASTIX_SUPPORT
        var solver_pastix_llt: PastixLLT[SpMat, Lower]
        stdout.write("\nSolving with PASTIX LLT ... \n")
        call_directsolver(solver_pastix_llt, EIGEN_PASTIX_LLT, A, b, refX, statFile)
        # EIGEN_PARDISO_SUPPORT
        var solver_pardiso_llt: PardisoLLT[SpMat, Lower]
        stdout.write("\nSolving with PARDISO LLT ... \n")
        call_directsolver(solver_pardiso_llt, EIGEN_PARDISO_LLT, A, b, refX, statFile)
        # CG
        var solver_cg: ConjugateGradient[SpMat, Lower]
        stdout.write("\nSolving with CG ... \n")
        call_itersolver(solver_cg, EIGEN_CG, A, b, refX, statFile)

def Browse_Matrices[Scalar: AnyType](
    folder: String,
    statFileExists: Bool,
    statFile: String,
    maxiters: Int,
    tol: Float64):
    MaximumIters = maxiters
    RelErr = tol
    var it: MatrixMarketIterator[Scalar] = MatrixMarketIterator[Scalar](folder)
    while it:
        if statFileExists:
            var statbuf: FileHandle = open(statFile, "a")
            statbuf.write("<LINEARSYSTEM> \n")
            statbuf.write("   <MATRIX> \n")
            statbuf.write("     <NAME> " + it.matname() + " </NAME>\n")
            statbuf.write("     <SIZE> " + str(it.matrix().rows()) + " </SIZE>\n")
            statbuf.write("     <ENTRIES> " + str(it.matrix().nonZeros()) + "</ENTRIES>\n")
            if it.sym() != NonSymmetric:
                statbuf.write("     <SYMMETRY> Symmetric </SYMMETRY>\n")
                if it.sym() == SPD:
                    statbuf.write("     <POSDEF> YES </POSDEF>\n")
                else:
                    statbuf.write("     <POSDEF> NO </POSDEF>\n")
            else:
                statbuf.write("     <SYMMETRY> NonSymmetric </SYMMETRY>\n")
                statbuf.write("     <POSDEF> NO </POSDEF>\n")
            statbuf.write("   </MATRIX> \n")
            statbuf.close()
        stdout.write("\n\n===================================================== \n")
        stdout.write(" ======  SOLVING WITH MATRIX " + it.matname() + " ====\n")
        stdout.write(" =================================================== \n\n")
        var refX: Matrix[Scalar, Dynamic, 1]
        if it.hasrefX():
            refX = it.refX()
        SelectSolvers[Scalar](it.matrix(), it.sym(), it.rhs(), refX, statFile)
        if statFileExists:
            var statbuf: FileHandle = open(statFile, "a")
            statbuf.write("  <BEST_SOLVER ID='" + str(best_time_id) + "'></BEST_SOLVER>\n")
            statbuf.write(" </LINEARSYSTEM> \n")
            statbuf.close()
        it.next()

# get_options function - no change
def get_options(argc: Int, args: String[], option: String, value: String | None = None) -> Bool:
    var idx: Int = 1
    var found: Bool = False
    while idx < argc and not found:
        if option == args[idx]:
            found = True
            if value:
                value = args[idx + 1]
        idx += 2
    return found

# Body from spbenchsolver.cpp
def bench_printhelp():
    stdout.write(" \nbenchsolver : performs a benchmark of all the solvers available in Eigen \n\n")
    stdout.write(" MATRIX FOLDER : \n")
    stdout.write(" The matrices for the benchmark should be collected in a folder specified with an environment variable EIGEN_MATRIXDIR \n")
    stdout.write(" The matrices are stored using the matrix market coordinate format \n")
    stdout.write(" The matrix and associated right-hand side (rhs) files are named respectively \n")
    stdout.write(" as MatrixName.mtx and MatrixName_b.mtx. If the rhs does not exist, a random one is generated. \n")
    stdout.write(" If a matrix is SPD, the matrix should be named as MatrixName_SPD.mtx \n")
    stdout.write(" If a true solution exists, it should be named as MatrixName_x.mtx; \n")
    stdout.write(" it will be used to compute the norm of the error relative to the computed solutions\n\n")
    stdout.write(" OPTIONS : \n")
    stdout.write(" -h or --help \n    print this help and return\n\n")
    stdout.write(" -d matrixdir \n    Use matrixdir as the matrix folder instead of the one specified in the environment variable EIGEN_MATRIXDIR\n\n")
    stdout.write(" -o outputfile.xml \n    Output the statistics to a xml file \n\n")
    stdout.write(" --eps <RelErr> Sets the relative tolerance for iterative solvers (default 1e-08) \n\n")
    stdout.write(" --maxits <MaxIts> Sets the maximum number of iterations (default 1000) \n\n")

def main(argc: Int, args: String[]):
    var help: Bool = get_options(argc, args, "-h") or get_options(argc, args, "--help")
    if help:
        bench_printhelp()
        return
    var matrix_dir: String
    if not get_options(argc, args, "-d", matrix_dir):
        var env_var: String? = os.environ().get("EIGEN_MATRIXDIR")
        if env_var is None:
            stderr.write("Please, specify the location of the matrices with -d mat_folder or the environment variable EIGEN_MATRIXDIR \n")
            stderr.write(" Run with --help to see the list of all the available options \n")
            return
        matrix_dir = env_var.value()
    # No need for ofstream; we'll use string for file
    var statFile: String
    var statFileExists: Bool = get_options(argc, args, "-o", statFile)
    if statFileExists:
        var statbuf: FileHandle = open(statFile, "w")
        if statbuf.is_open():
            statFileExists = True
            printStatheader(statbuf)
            statbuf.close()
        else:
            stderr.write("Unable to open the provided file for writting... \n")
    var maxiters: Int = 1000
    var tol: Float64 = 1e-08
    var inval: String
    if get_options(argc, args, "--eps", inval):
        tol = atof(inval)
    if get_options(argc, args, "--maxits", inval):
        maxiters = atoi(inval)
    # Browse_Matrices<double> and <complex<double>>
    Browse_Matrices[Float64](matrix_dir, statFileExists, statFile, maxiters, tol)
    Browse_Matrices[ComplexFloat64](matrix_dir, statFileExists, statFile, maxiters, tol)
    if statFileExists:
        var statbuf: FileHandle = open(statFile, "a")
        statbuf.write("</BENCH> \n")
        stdout.write("\n Output written in " + statFile + " ...\n")
        statbuf.close()
    return