from memory import Pointer
from testing import test, Assert
from ......SingleLayerOptics.WCESingleLayerOptics import *
from ......Common.WCECommon import *

struct TestCircularPerforatedShade1:
    var m_Shade: Pointer[CBSDFLayer]

    def SetUp(inout self):
        let Tmat = 0.2
        let Rfmat = 0.75
        let Rbmat = 0.66
        let minLambda = 0.3
        let maxLambda = 2.5
        let aMaterial = Material.singleBandMaterial(Tmat, Tmat, Rfmat, Rbmat, minLambda, maxLambda)
        let x = 0.0225          # m
        let y = 0.0381          # m
        let thickness = 0.005   # m
        let radius = 0.00835    # m
        let aBSDF = CBSDFHemisphere.create(BSDFBasis.Quarter)
        self.m_Shade = CBSDFLayerMaker.getCircularPerforatedLayer(aMaterial, aBSDF, x, y, thickness, radius)

    def GetShade(self) -> Pointer[CBSDFLayer]:
        return self.m_Shade

@test
def TestSolarProperties():
    # SCOPED_TRACE("Begin Test: Circular perforated cell - Solar properties.")
    var aShade = TestCircularPerforatedShade1()
    aShade.SetUp()
    var aShadePtr = aShade.GetShade()
    var aResults = aShadePtr[].getResults()
    let tauDiff = aResults.DiffDiff(Side.Front, PropertySimple.T)
    Assert.is_close(tauDiff, 0.32084455059221467, 1e-6)
    let RfDiff = aResults.DiffDiff(Side.Front, PropertySimple.R)
    Assert.is_close(RfDiff, 0.63670823381979202, 1e-6)
    let RbDiff = aResults.DiffDiff(Side.Back, PropertySimple.R)
    Assert.is_close(RbDiff, 0.56030324576141499, 1e-6)
    var aT = aResults.getMatrix(Side.Front, PropertySimple.T)
    var size = aT.size()
    var correctResults = List[Float64]()
    correctResults.append(3.370933)
    correctResults.append(3.282731)
