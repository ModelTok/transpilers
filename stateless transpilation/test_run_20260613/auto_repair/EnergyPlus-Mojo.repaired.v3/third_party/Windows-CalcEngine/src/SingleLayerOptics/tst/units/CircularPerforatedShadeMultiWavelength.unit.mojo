from testing import assert_equal, assert_almost_equal
from WCECommon import CBSDFLayer, CBSDFHemisphere, CBSDFIntegrator, Material, BSDFBasis, Side, PropertySimple
from WCESingleLayerOptics import CBSDFLayerMaker
from SpectralAveraging import SpectralAveraging
from memory import shared_ptr, make_shared

struct TestCircularPerforatedShadeMultiWavelength:
    private var m_Layer: shared_ptr[CBSDFLayer]

    def SetUp(inout self):
        let Tsol = 0.1
        let Rfsol = 0.7
        let Rbsol = 0.7
        let Tvis = 0.2
        let Rfvis = 0.6
        let Rbvis = 0.6
        let ratio = 0.49
        let aMaterial = Material.dualBandMaterial(Tsol, Tsol, Rfsol, Rbsol, Tvis, Tvis, Rfvis, Rbvis, ratio)
        let x = 22.5  # mm
        let y = 38.1  # mm
        let thickness = 5  # mm
        let radius = 8.35  # mm
        let aBSDF = CBSDFHemisphere.create(BSDFBasis.Quarter)
        self.m_Layer = CBSDFLayerMaker.getCircularPerforatedLayer(aMaterial, aBSDF, x, y, thickness, radius)

    def getLayer(inout self) -> shared_ptr[CBSDFLayer]:
        return self.m_Layer

@test
def TestCircularPerforatedMultiWavelength():
    # SCOPED_TRACE("Begin Test: Perforated layer (multi range) - BSDF.")
    var fixture = TestCircularPerforatedShadeMultiWavelength()
    fixture.SetUp()
    var aLayer = fixture.getLayer()
    var aResults = aLayer.getWavelengthResults()
    var correctSize: Int = 4
    assert_equal(correctSize, len(aResults))

    # First wavelength block (index 0)
