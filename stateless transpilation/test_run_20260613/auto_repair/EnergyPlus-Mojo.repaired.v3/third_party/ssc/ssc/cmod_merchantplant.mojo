from common_financial import *
from lib_financial import *
from cmod_merchantplant_eqns import *
from lib_util import *
from sscapi import *

using libfin

var _cm_vtab_merchantplant: StaticArray[var_info, 0] = []
#   VARTYPE           DATATYPE         NAME                                      LABEL                                                            UNITS              META                      GROUP                       REQUIRED_IF                 CONSTRAINTS                      UI_HINTS
_cm_vtab_merchantplant.append(var_info(SSC_INPUT, SSC_NUMBER, "en_batt", "Enable battery storage model", "0/1", "", "BatterySystem", "?=0", "", ""))
_cm_vtab_merchantplant.append(var_info(SSC_INPUT, SSC_NUMBER, "batt_meter_position", "Position of battery relative to electric meter", "", "", "BatterySystem", "", "", ""))
_cm_vtab_merchantplant.append(var_info(SSC_INPUT, SSC_ARRAY, "grid_to_batt", "Electricity to battery from grid", "kW", "", "BatterySystem", "", "", ""))
_cm_vtab_merchantplant.append(var_info(SSC_OUTPUT, SSC_ARRAY, "revenue_gen", "Electricity used to calculate PPA revenue", "kW", "", "System Output", "", "", ""))
_cm_vtab_merchantplant.append(var_info(SSC_INPUT, SSC_ARRAY, "gen", "Power generated by renewable resource", "kW", "", "System Output", "*", "", ""))
_cm_vtab_merchantplant.append(var_info(SSC_INPUT, SSC_ARRAY, "degradation", "Annual energy degradation", "", "", "System Output", "*", "", ""))
_cm_vtab_merchantplant.append(var_info(SSC_INPUT, SSC_NUMBER, "system_capacity", "System nameplate capacity", "kW", "", "System Output", "*", "MIN=1e-3", ""))
# PPA Buy Rate values
_cm_vtab_merchantplant.append(var_info(SSC_INPUT, SSC_ARRAY, "utility_bill_w_sys", "Electricity bill with system", "$", "", "Utility Bill", "", "", ""))
_cm_vtab_merchantplant.append(var_info(SSC_OUTPUT, SSC_ARRAY, "cf_utility_bill", "Electricity purchase", "$", "", "", "", "LENGTH_EQUAL=cf_length", ""))
# return on equity from SAM for India
_cm_vtab_merchantplant.append(var_info(SSC_INPUT, SSC_ARRAY, "roe_input", "Return on equity", "", "", "Financial Parameters", "?=20", "", ""))
_cm_vtab_merchantplant.append(var_info(SSC_OUTPUT, SSC_ARRAY, "cf_return_on_equity", "Return on equity", "$/kWh", "", "Return on Equity", "*", "LENGTH_EQUAL=cf_length", ""))
_cm_vtab_merchantplant.append(var_info(SSC_OUTPUT, SSC_ARRAY, "cf_return_on_equity_input", "Return on equity input", "%", "", "Return on Equity", "*", "LENGTH_EQUAL=cf_length", ""))
_cm_vtab_merchantplant.append(var_info(SSC_OUTPUT, SSC_ARRAY, "cf_return_on_equity_dollars", "Return on equity dollars", "$", "", "Return on Equity", "*", "LENGTH_EQUAL=cf_length", ""))
_cm_vtab_merchantplant.append(var_info(SSC_OUTPUT, SSC_ARRAY, "cf_lcog_costs", "Total LCOG costs", "$", "", "Return on Equity", "*", "LENGTH_EQUAL=cf_length", ""))
_cm_vtab_merchantplant.append(var_info(SSC_OUTPUT, SSC_NUMBER, "lcog_om", "LCOG O and M", "cents/kWh", "", "Return on Equity", "*", "", ""))
_cm_vtab_merchantplant.append(var_info(SSC_OUTPUT, SSC_NUMBER, "lcog_depr", "LCOG depreciation", "cents/kWh", "", "Return on Equity", "*", "", ""))
_cm_vtab_merchantplant.append(var_info(SSC_OUTPUT, SSC_NUMBER, "lcog_loan_int", "LCOG loan interest", "cents/kWh", "", "Return on Equity", "*", "", ""))
_cm_vtab_merchantplant.append(var_info(SSC_OUTPUT, SSC_NUMBER, "lcog_wc_int", "LCOG working capital interest", "cents/kWh", "", "Return on Equity", "*", "", ""))
_cm_vtab_merchantplant.append(var_info(SSC_OUTPUT, SSC_NUMBER, "lcog_roe", "LCOG return on equity", "cents/kWh", "", "Return on Equity", "*", "", ""))
_cm_vtab_merchantplant.append(var_info(SSC_OUTPUT, SSC_NUMBER, "lcog", "LCOG Levelized cost of generation", "cents/kWh", "", "Return on Equity", "*", "", ""))
#loan moratorium from Sara for India Documentation\India\Loan Moratorum
#assumptions:
#1) moratorium period begins at beginning of loan term 
#2) moratorium affects principal payment and not interest
#3) loan term remains the same
#4) payments increase after moratorium period
_cm_vtab_merchantplant.append(var_info(SSC_INPUT, SSC_NUMBER, "loan_moratorium", "Loan moratorium period", "years", "", "Financial Parameters", "?=0", "INTEGER,MIN=0", ""))
# Recapitalization
_cm_vtab_merchantplant.append(var_info(SSC_INOUT, SSC_NUMBER, "system_use_recapitalization", "Recapitalization expenses", "0/1", "0=None,1=Recapitalize", "System Costs", "?=0", "INTEGER,MIN=0", ""))
_cm_vtab_merchantplant.append(var_info(SSC_INPUT, SSC_NUMBER, "system_recapitalization_cost", "Recapitalization cost", "$", "", "System Costs", "?=0", "", ""))
_cm_vtab_merchantplant.append(var_info(SSC_INPUT, SSC_NUMBER, "system_recapitalization_escalation", "Recapitalization escalation (above inflation)", "%", "", "System Costs", "?=0", "MIN=0,MAX=100", ""))
_cm_vtab_merchantplant.append(var_info(SSC_INPUT, SSC_ARRAY, "system_lifetime_recapitalize", "Recapitalization boolean", "", "", "System Costs", "?=0", "", ""))
_cm_vtab_merchantplant.append(var_info(SSC_OUTPUT, SSC_ARRAY, "cf_recapitalization", "Recapitalization operating expense", "$", "", "Recapitalization", "*", "LENGTH_EQUAL=cf_length", ""))
# Dispatch
_cm_vtab_merchantplant.append(var_info(SSC_INPUT, SSC_NUMBER, "system_use_lifetime_output", "Lifetime hourly system outputs", "0/1", "0=hourly first year,1=hourly lifetime", "Lifetime", "*", "INTEGER,MIN=0", ""))
# inputs in model not currently in M 11/15/10
_cm_vtab_merchantplant.append(var_info(SSC_INPUT, SSC_NUMBER, "total_installed_cost", "Installed cost", "$", "", "System Costs", "*", "", ""))
