from runtime import Builtin
from memory import alloc, free, UnsafePointer
from ...ssc.common import var_data, var_table, SSC_TABLE

def create_winddata_array(intervalsPerHour: Int, nMeasurementHeights: Int) -> UnsafePointer[var_data]:
    var timeLength: Int = 8760 * intervalsPerHour
    var year_data: UnsafePointer[Float64] = alloc[Float64](4 * timeLength * nMeasurementHeights)
    for i in range(timeLength):
        for j in range(nMeasurementHeights):
            var index: Int = i * 4 * nMeasurementHeights + j * 4
            year_data[index] = Float64(50 + 5 * j)
            year_data[index + 1] = Float64(0.95 + 0.05 * j)
            year_data[index + 2] = Float64(5 * (Float64(i) / Float64(timeLength)) + 5 * j)
            year_data[index + 3] = Float64(180 + 20 * j)
    var height: UnsafePointer[Float64] = alloc[Float64](4 * nMeasurementHeights)
    var fields: UnsafePointer[Float64] = alloc[Float64](4 * nMeasurementHeights)
    for i in range(nMeasurementHeights):
        for j in range(4):
            height[i * 4 + j] = Float64(80 + i * 10)
            fields[i * 4 + j] = Float64(j + 1)
    var data_vd = var_data(year_data, Int32(timeLength), Int32(4 * nMeasurementHeights))
    var height_vd = var_data(height, Int32(4 * nMeasurementHeights))
    var fields_vd = var_data(fields, Int32(4 * nMeasurementHeights))
    var vt: var_table = var_table()
    vt.assign("heights", height_vd)
    vt.assign("data", data_vd)
    vt.assign("fields", fields_vd)
    var input: UnsafePointer[var_data] = alloc[var_data]()
    input[].type = SSC_TABLE
    input[].table = vt
    return input

def free_winddata_array(data: UnsafePointer[var_data]):
    data[].table.unassign("heights")
    data[].table.unassign("data")
    data[].table.unassign("fields")

def free_weatherdata_array(data: UnsafePointer[var_data]):
    data[].table.unassign("lat")
    data[].table.unassign("lon")
    data[].table.unassign("tz")
    data[].table.unassign("elev")
    data[].table.unassign("year")
    data[].table.unassign("month")
    data[].table.unassign("day")
    data[].table.unassign("hour")
    data[].table.unassign("dn")
    data[].table.unassign("df")
    data[].table.unassign("tdry")
    data[].table.unassign("tdew")
    data[].table.unassign("rhum")
    data[].table.unassign("pres")
    data[].table.unassign("wdir")
    data[].table.unassign("wspd")
    data[].table.unassign("aod")
    data[].table.unassign("pwp")
    data[].table.unassign("alb")

