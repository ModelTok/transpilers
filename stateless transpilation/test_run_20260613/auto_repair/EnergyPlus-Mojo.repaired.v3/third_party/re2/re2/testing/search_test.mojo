def SearchTests():
    var failures: Int = 0
    for i in range(arraysize(simple_tests)):
        var t = simple_tests[i]
        if not TestRegexpOnText(t.regexp, t.text):
            failures += 1
        if LOGGING:
            var atom = List[String]()
            var alpha = List[String]()
            var ops = List[String]()
            atom.append(t.regexp)
            alpha.append(t.text)
            ExhaustiveTest(1, 0, atom, ops, 1, alpha, "", "")
    EXPECT_EQ(failures, 0)

def main():
    SearchTests()