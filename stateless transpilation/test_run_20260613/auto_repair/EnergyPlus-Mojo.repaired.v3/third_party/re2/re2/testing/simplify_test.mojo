from util.test import Test, ASSERT_TRUE, EXPECT_EQ, arraysize
from util.logging import VLOG
from ..regexp import Regexp, RegexpStatus

struct Test:
    var regexp: String
    var simplified: String

    def __init__(inout self, regexp: String, simplified: String):
        self.regexp = regexp
        self.simplified = simplified

