    Test("\\d*\\D*", "[0-9]*[^0-9]*"),
    Test("a+b", "a+b"),
    Test("\\d+\\D", "[0-9]+[^0-9]"),
    Test("a?bb", "a?bb"),
    Test("(a*)a*", "(a*)a*"),
    Test("a+(a)", "a+(a)"),
    Test("(a?)(aa)", "(a?)(aa)"),
    Test("aa*aa+aa?aa{2}aaa{2,}aaa{2,3}a", "aaaaaaaaaaaaaaaa+"),
