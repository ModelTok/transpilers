    Test("(?i)a+(?-i)A+", "[Aa]+A+"),
    Test("a*?a*?", "a*?"),
    Test("a+?a+?", "aa+?"),
    Test("a*?a*", "a*?a*"),
    Test("a+a+?", "a+a+?"),
    Test("a*a", "a+"),
    Test("\\d*\\d", "[0-9]+"),
    Test(".*.", ".+"),
    Test("\\C*\\C", "\\C+"),
    Test("(?i)A*a", "[Aa]+"),
    Test("(?i)a+A", "[Aa][Aa]+"),
    Test("(?i)A*(?-i)a", "[Aa]*a"),
    Test("(?i)a+(?-i)A", "[Aa]+A"),
    Test("a*aa", "aa+"),
    Test("a*aab", "aa+b"),
    Test("(?i)a*aa", "[Aa][Aa]+"),
    Test("(?i)a*aab", "[Aa][Aa]+[Bb]"),
    Test("(?i)a*(?-i)aa", "[Aa]*aa"),
    Test("(?i)a*(?-i)aab", "[Aa]*aab"),
