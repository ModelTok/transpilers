    Test("(?:(?:a){0,1}){1,}", "a*"),
)

def TestSimplify_SimpleRegexps():
    for i in range(len(tests)):
        var status = RegexpStatus()
        VLOG(1, "Testing " + tests[i].regexp)
        var re = Regexp.Parse(tests[i].regexp,
                              Regexp.MatchNL | (Regexp.LikePerl & ~Regexp.OneLine),
                              &status)
        ASSERT_TRUE(re != None, " " + tests[i].regexp + " " + status.Text())
        var sre = re.Simplify()
        ASSERT_TRUE(sre != None)
        if tests[i].regexp == tests[i].simplified:
            ASSERT_TRUE(re == sre, " " + tests[i].regexp + " " + re.ToString() + " " + sre.ToString())
        EXPECT_EQ(tests[i].simplified, sre.ToString(), " " + tests[i].regexp + " " + sre.Dump())
        re.Decref()
        sre.Decref()

TestSimplify_SimpleRegexps()