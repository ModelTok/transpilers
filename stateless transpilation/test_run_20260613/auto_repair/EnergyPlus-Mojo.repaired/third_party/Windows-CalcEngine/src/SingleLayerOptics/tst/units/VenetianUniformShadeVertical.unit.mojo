from WCECommon import SquareMatrix, Side, PropertySimple
from WCESingleLayerOptics import CBSDFLayer, Material, CBSDFHemisphere, CBSDFLayerMaker, DistributionMethod

struct TestVenetianUniformShadeMatrixVertical:
    var m_Shade: CBSDFLayer

    def SetUp(inout self):
        let Tmat = 0.1
        let Rfmat = 0.7
        let Rbmat = 0.7
        let minLambda = 0.3
        let maxLambda = 2.5
        let aMaterial = Material.singleBandMaterial(
            Tmat, Tmat, Rfmat, Rbmat, minLambda, maxLambda
        )
        let slatWidth = 0.010
        let slatSpacing = 0.010
        let slatTiltAngle = 45
        let curvatureRadius = 0
        let numOfSlatSegments: Int = 5
        let aBSDF = CBSDFHemisphere.create(BSDFBasis.Quarter)
        let isHorizontalVenetian: Bool = False
        self.m_Shade = CBSDFLayerMaker.getVenetianLayer(
            aMaterial,
            aBSDF,
            slatWidth,
            slatSpacing,
            slatTiltAngle,
            curvatureRadius,
            numOfSlatSegments,
            DistributionMethod.UniformDiffuse,
            isHorizontalVenetian
        )

    def GetShade(self) -> CBSDFLayer:
        return self.m_Shade

def TestVenetianMatrix():
    # SCOPED_TRACE("Begin Test: Venetian layer test quarter basis matrix.")
    var testFixture = TestVenetianUniformShadeMatrixVertical()
    testFixture.SetUp()
    var aShade = testFixture.GetShade()
