from memory import SharedPtr
import testing
from WCECommon import *
from WCESingleLayerOptics import *

@value
class TestVenetianUniformShadeMatrix(testing.Test):
    var m_Shade: SharedPtr[SingleLayerOptics.CBSDFLayer]

    def SetUp(inout self):
        const Tmat = 0.1
        const Rfmat = 0.7
        const Rbmat = 0.7
        const minLambda = 0.3
        const maxLambda = 2.5
        const aMaterial = SingleLayerOptics.Material.singleBandMaterial(
            Tmat, Tmat, Rfmat, Rbmat, minLambda, maxLambda)
        const slatWidth = 0.010
        const slatSpacing = 0.010
        const slatTiltAngle = 45
        const curvatureRadius = 0
        const numOfSlatSegments = 5
        const aBSDF = SingleLayerOptics.CBSDFHemisphere.create(SingleLayerOptics.BSDFBasis.Quarter)
        self.m_Shade = SingleLayerOptics.CBSDFLayerMaker.getVenetianLayer(
            aMaterial,
            aBSDF,
            slatWidth,
            slatSpacing,
            slatTiltAngle,
            curvatureRadius,
            numOfSlatSegments,
            SingleLayerOptics.DistributionMethod.UniformDiffuse)

    def GetShade(inout self) -> SingleLayerOptics.CBSDFLayer:
        return self.m_Shade[]

def TestVenetianMatrix():
    testing.scoped_trace("Begin Test: Venetian layer test quarter basis matrix.")
    var aShade = TestVenetianUniformShadeMatrix().GetShade()
    var aResults = aShade.getResults()
    var aT = aResults.getMatrix(FenestrationCommon.Side.Front, FenestrationCommon.PropertySimple.T)
