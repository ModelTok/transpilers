// Mojo translation of lib_battery_powerflow.cpp
// Includes adapted from C++ headers
from lib_battery_dispatch import dispatch_t
from lib_shared_inverter import SharedInverter
from lib_power_electronics import ChargeController

from math import fabs, fmin, fmax, isnan

struct BatteryPower:
    """
    * \struct BatteryPower
    *
    * \brief
    *
    *  The BatteryPower structure contains all of the power flow components for a battery simulation
    *  The structure also contains information about the single point efficiecies required to convert power from one form to another
    *  Power quantities in BatteryPower are either all AC or all DC depending on which part of the controller is looking at it
    """
    enum CONNECTION: Int32:
        DC_CONNECTED = 0
        AC_CONNECTED = 1

    var dtHour: Float64  # The timestep in hours, used for accumulated power losses
    var powerSystem: Float64  # < The power production of the renewable system (PV array) (kW)
    var powerSystemThroughSharedInverter: Float64  # < The power going through the shared inverter (kW)
    var powerLoad: Float64  # < The power required by the electric load (kW)
    var powerBatteryDC: Float64  # < The power flow to and from the battery (> 0, discharging, < 0 charging) (kWdc)
    var powerBatteryAC: Float64  # < The power flow to and from the battery (> 0, discharging, < 0 charging) (kWac)
    var powerBatteryTarget: Float64  # < A user specified or algorithm calculated target dispatch power (kW)
    var powerGrid: Float64  # < The power flow to and from the grid (> 0, to grid, < 0 from grid) (kW)
    var powerGeneratedBySystem: Float64  # The power generated by the combined power generator and battery (kW)
    var powerSystemToLoad: Float64  # < The power from the renewable system to the electric load (kW)
    var powerSystemToBattery: Float64  # < The power from renewable system to the battery (kW)
    var powerSystemToGrid: Float64  # < The power from renewable system to the grid (kW)
    var powerSystemClipped: Float64  # < The power from renewable system that will be clipped if not used in the battery (kW)
    var powerClippedToBattery: Float64  # < The power from that would otherwise have been clipped to the battery (kW)
    var powerGridToBattery: Float64  # < The power from the grid to the battery (kW)
    var powerGridToLoad: Float64  # < The power from the grid to the electric load (kW)
    var powerBatteryToLoad: Float64  # < The power from the battery to the electric load (kW)
    var powerBatteryToGrid: Float64  # < The power from the battery to the grid (kW)
    var powerFuelCell: Float64  # < The power from the fuelcell (kW)
    var powerFuelCellToGrid: Float64  # < The power from the fuelcell to the grid (kW)
    var powerFuelCellToLoad: Float64  # < The power from the fuelcell to the load (kW)
    var powerFuelCellToBattery: Float64  # < The power from the fuelcell to the battery (kW)
    var powerPVInverterDraw: Float64  # < The power draw from the PV inverter (kW)
    var powerBatteryChargeMaxDC: Float64  # < The maximum sustained power the battery can charge (kWdc)
    var powerBatteryDischargeMaxDC: Float64  # < The maximum sustained power the battery can discharge (kWdc)
    var powerBatteryChargeMaxAC: Float64  # < The maximum sustained power the battery can charge (kWac)
    var powerBatteryDischargeMaxAC: Float64  # < The maximum sustained power the battery can discharge (kWac)
    var powerSystemLoss: Float64  # < The auxiliary power loss in the system (kW)
    var powerConversionLoss: Float64  # < The power loss due to conversions in the battery power electronics (kW)
    var voltageSystem: Float64  # < The system voltage
    var connectionMode: Int32  # 0 if DC-connected, 1 if AC-connected
    var meterPosition: Int32  # 0 if behind-the-meter, 1 if front-of-meter
    var singlePointEfficiencyACToDC: Float64  # < The conversion efficiency from AC power to DC power within the battery microinverter (0 - 1)
    var singlePointEfficiencyDCToAC: Float64  # < The conversion efficiency from DC power to AC power within the battery microinverter (0 - 1)
    var singlePointEfficiencyDCToDC: Float64  # < The conversion efficiency from DC power to DC power within the battery management system (0 - 1)
    var sharedInverter: Pointer[SharedInverter]  # < The shared inverter between the PV and battery for a DC-connected system
    var inverterEfficiencyCutoff: Float64  # < The shared inverter efficiency at which to stop charging or discharging due to inefficient operation (0-1)
    var canSystemCharge: Bool  # < A boolean specifying whether the battery is allowed to charge from PV in the timestep
    var canClipCharge: Bool  # < A boolean specifying whether the battery is allowed to charge from otherwise clipped PV in the timestep
    var canGridCharge: Bool  # < A boolean specifying whether the battery is allowed to charge from the Grid in the timestep
    var canDischarge: Bool  # < A boolean specifying whether the battery is allowed to discharge in the timestep
    var canFuelCellCharge: Bool  # < A boolean specifying whether the battery is allowed to charge from the fuel cell
    var stateOfChargeMax: Float64  # < The maximum state of charge (0-100)
    var stateOfChargeMin: Float64  # < The minimum state of charge (0-100)
    var depthOfDischargeMax: Float64  # < The maximum depth of discharge (0-100)
    var currentChargeMax: Float64  # < The maximum sustained current for charging [A]
    var currentDischargeMax: Float64  # < The maximum sustained current for discharging [A]
    var tolerance: Float64  # < A numerical tolerance. Below this value, zero out the power flow

    def __init__(inout self, dtHour: Float64):
        self.dtHour = dtHour
        self.powerSystem = 0.0
        self.powerSystemThroughSharedInverter = 0.0
        self.powerLoad = 0.0
        self.powerBatteryDC = 0.0
        self.powerBatteryAC = 0.0
        self.powerBatteryTarget = 0.0
        self.powerGrid = 0.0
        self.powerGeneratedBySystem = 0.0
        self.powerSystemToLoad = 0.0
        self.powerSystemToBattery = 0.0
        self.powerSystemToGrid = 0.0
        self.powerSystemClipped = 0.0
        self.powerClippedToBattery = 0.0
        self.powerGridToBattery = 0.0
        self.powerGridToLoad = 0.0
        self.powerBatteryToLoad = 0.0
        self.powerBatteryToGrid = 0.0
        self.powerFuelCell = 0.0
        self.powerFuelCellToGrid = 0.0
        self.powerFuelCellToLoad = 0.0
        self.powerFuelCellToBattery = 0.0
        self.powerPVInverterDraw = 0.0
        self.powerBatteryChargeMaxDC = 0.0
        self.powerBatteryDischargeMaxDC = 0.0
        self.powerBatteryChargeMaxAC = 0.0
        self.powerBatteryDischargeMaxAC = 0.0
        self.powerSystemLoss = 0.0
        self.powerConversionLoss = 0.0
        self.connectionMode = 0
        self.singlePointEfficiencyACToDC = 0.96
        self.singlePointEfficiencyDCToAC = 0.96
        self.singlePointEfficiencyDCToDC = 0.99
        self.inverterEfficiencyCutoff = 5.0
        self.canSystemCharge = False
        self.canClipCharge = False
        self.canGridCharge = False
        self.canDischarge = False
        self.canFuelCellCharge = False
        self.stateOfChargeMax = 1.0
        self.stateOfChargeMin = 0.0
        self.depthOfDischargeMax = 1.0
        self.tolerance = 0.001

    def __copyinit__(inout self, other: Self):
        self.sharedInverter = other.sharedInverter
        self.dtHour = other.dtHour
        self.powerSystem = other.powerSystem
        self.powerSystemThroughSharedInverter = other.powerSystemThroughSharedInverter
        self.powerLoad = other.powerLoad
        self.powerBatteryDC = other.powerBatteryDC
        self.powerBatteryAC = other.powerBatteryAC
        self.powerBatteryTarget = other.powerBatteryTarget
        self.powerGrid = other.powerGrid
        self.powerGeneratedBySystem = other.powerGeneratedBySystem
        self.powerSystemToLoad = other.powerSystemToLoad
        self.powerSystemToBattery = other.powerSystemToBattery
        self.powerSystemToGrid = other.powerSystemToGrid
        self.powerSystemClipped = other.powerSystemClipped
        self.powerClippedToBattery = other.powerClippedToBattery
        self.powerGridToBattery = other.powerGridToBattery
        self.powerGridToLoad = other.powerGridToLoad
        self.powerBatteryToLoad = other.powerBatteryToLoad
        self.powerBatteryToGrid = other.powerBatteryToGrid
        self.powerFuelCell = other.powerFuelCell
        self.powerFuelCellToGrid = other.powerFuelCellToGrid
        self.powerFuelCellToLoad = other.powerFuelCellToLoad
        self.powerFuelCellToBattery = other.powerFuelCellToBattery
        self.powerPVInverterDraw = other.powerPVInverterDraw
        self.powerBatteryChargeMaxDC = other.powerBatteryChargeMaxDC
        self.powerBatteryDischargeMaxDC = other.powerBatteryDischargeMaxDC
        self.powerBatteryChargeMaxAC = other.powerBatteryChargeMaxAC
        self.powerBatteryDischargeMaxAC = other.powerBatteryDischargeMaxAC
        self.powerSystemLoss = other.powerSystemLoss
        self.powerConversionLoss = other.powerConversionLoss
        self.connectionMode = other.connectionMode
        self.singlePointEfficiencyACToDC = other.singlePointEfficiencyACToDC
        self.singlePointEfficiencyDCToAC = other.singlePointEfficiencyDCToAC
        self.singlePointEfficiencyDCToDC = other.singlePointEfficiencyDCToDC
        self.canSystemCharge = other.canSystemCharge
        self.canClipCharge = other.canClipCharge
        self.canGridCharge = other.canGridCharge
        self.canDischarge = other.canDischarge
        self.canFuelCellCharge = other.canFuelCellCharge
        self.stateOfChargeMax = other.stateOfChargeMax
        self.stateOfChargeMin = other.stateOfChargeMin
        self.depthOfDischargeMax = other.depthOfDischargeMax
        self.tolerance = other.tolerance

    def setSharedInverter(inout self, a_sharedInverter: Pointer[SharedInverter]):
        self.sharedInverter = a_sharedInverter

    def reset(inout self):
        self.powerFuelCell = 0.0
        self.powerFuelCellToGrid = 0.0
        self.powerFuelCellToLoad = 0.0
        self.powerFuelCellToBattery = 0.0
        self.powerBatteryDC = 0.0
        self.powerBatteryAC = 0.0
        self.powerBatteryTarget = 0.0
        self.powerBatteryToGrid = 0.0
        self.powerBatteryToLoad = 0.0
        self.powerClippedToBattery = 0.0
        self.powerConversionLoss = 0.0
        self.powerGeneratedBySystem = 0.0
        self.powerGrid = 0.0
        self.powerGridToBattery = 0.0
        self.powerGridToLoad = 0.0
        self.powerLoad = 0.0
        self.powerSystem = 0.0
        self.powerSystemThroughSharedInverter = 0.0
        self.powerSystemClipped = 0.0
        self.powerPVInverterDraw = 0.0
        self.powerSystemToBattery = 0.0
        self.powerSystemToGrid = 0.0
        self.powerSystemToLoad = 0.0
        self.voltageSystem = 0.0

    def adjustForACEfficiencies(self, power: Float64, loss: Float64) -> Float64:
        """
         * Multiply or divide by ac efficiency for discharging or charging
         * Auxiliary discharging losses are applied to the battery, charging and idle losses to PV or grid
        """
        if power > 0.0:
            return (power + loss) / self.singlePointEfficiencyDCToAC
        else:
            return power * self.singlePointEfficiencyACToDC

    def adjustForDCEfficiencies(self, power: Float64, loss: Float64) -> Float64:
        """
         * Multiply or divide by dc efficiency for discharging or charging
         * Auxiliary discharging losses are applied to the battery, chargingand idle losses to PV or grid
        """
        if power > 0.0:
            return (power + loss) / (self.singlePointEfficiencyDCToDC * self.singlePointEfficiencyACToDC)
        else:
            var ac_to_dc_eff: Float64 = self.singlePointEfficiencyACToDC
            if self.sharedInverter[].efficiencyAC > 5.0:  # 5% is the cutoff in lib_battery_powerflow
                ac_to_dc_eff = self.sharedInverter[].efficiencyAC * 0.01
            return power * self.singlePointEfficiencyDCToDC / ac_to_dc_eff

struct BatteryPowerFlow:
    """
    * \class BatteryPowerFlow
    *
    * \brief
    *
    *  The BatteryPowerFlow class provides the calculations for which components of the system power flow to/from the battery,
    *  which power components go to meet the electric load, and how the utility grid is used.  It is meant to be shared by
    *  the lib_power_electronics charge controllers, which require AC power calculations, and the battery dispatch model, 
    *  which require DC power calculations.  The interaction of this model with other's may seem complex, but the general
    *  design of the battery model is:
    *
    *  1. ChargeController - contains information about conversion efficiencies and configuration, which is passed to BatteryPowerFlow
    *  2. Dispatch - contains information about the dispatch strategy desired, and constraints around when the battery can
    *                charge or discharge, and constraints around the state-of-charge, power and current throughput limits
    *                Within the Dispatch, the following steps are taken:
    *                a) Calculate battery power given the dispatch strategy and contraints
    *                b) Dispatch the battery with that power (current)
    *                c) Iterate on the current (due to the nonlinear relationship in P = IV) until the constraints are met
    *                d) Calculate the final power flow for the time step.
    """
    var m_BatteryPower: BatteryPower  # A structure containing the AC power flow components

    def __init__(inout self, dtHour: Float64):
        self.m_BatteryPower = BatteryPower(dtHour)

    def __copyinit__(inout self, other: Self):
        self.m_BatteryPower = BatteryPower(other.m_BatteryPower)

    def getBatteryPower(inout self) -> Pointer[BatteryPower]:
        return Pointer.address_of(self.m_BatteryPower)

    def calculate(inout self):
        if self.m_BatteryPower.connectionMode == ChargeController.AC_CONNECTED:
            self.calculateACConnected()
        elif self.m_BatteryPower.connectionMode == ChargeController.DC_CONNECTED:
            self.calculateDCConnected()

    def initialize(inout self, stateOfCharge: Float64):
        if self.m_BatteryPower.canDischarge and stateOfCharge > self.m_BatteryPower.stateOfChargeMin + 1.0 and (self.m_BatteryPower.powerSystem < self.m_BatteryPower.powerLoad or self.m_BatteryPower.meterPosition == dispatch_t.FRONT):
            self.m_BatteryPower.powerBatteryDC = self.m_BatteryPower.powerBatteryDischargeMaxDC
        elif (self.m_BatteryPower.powerSystem > self.m_BatteryPower.powerLoad and self.m_BatteryPower.canSystemCharge) or self.m_BatteryPower.canGridCharge:
            if self.m_BatteryPower.canSystemCharge:
                self.m_BatteryPower.powerBatteryDC = -(self.m_BatteryPower.powerSystem - self.m_BatteryPower.powerLoad)
            if self.m_BatteryPower.canGridCharge:
                self.m_BatteryPower.powerBatteryDC = -self.m_BatteryPower.powerBatteryChargeMaxDC
        self.m_BatteryPower.powerBatteryTarget = self.m_BatteryPower.powerBatteryDC

    def reset(inout self):
        self.m_BatteryPower.reset()

    def calculateACConnected(inout self):
        """
        * \function calculateACConnected
        *
        * Calculate the power flow for an AC connected battery system.  This calculation respects basic constraints about whether
        * a battery is allowed to charge from PV, the Grid, and whether it is allowed to discharge.  The calculation also makes
        * the following assumptions.
        *
        *  0. The BatteryPower contains the powerBattery that the dispatch has determined best fits the constraints
        *  1. Battery is charged from PV before the Grid
        *  2. Battery is charged from the Grid for any remaining power, even if this violates grid charging constraint
        *  3. Battery discharges to the electric load first
        *  4. Any additional battery discharge goes to the Grid.
        *  5. In the event that the battery is allowed to charge and discharge, it will discharge.
        *
        """
        var P_battery_dc: Float64 = self.m_BatteryPower.powerBatteryDC
        var P_pv_ac: Float64 = self.m_BatteryPower.powerSystem
        var P_fuelcell_ac: Float64 = self.m_BatteryPower.powerFuelCell
        var P_inverter_draw_ac: Float64 = self.m_BatteryPower.powerPVInverterDraw
        var P_load_ac: Float64 = self.m_BatteryPower.powerLoad
        var P_system_loss_ac: Float64 = self.m_BatteryPower.powerSystemLoss
        var P_pv_to_batt_ac: Float64 = 0.0
        var P_grid_to_batt_ac: Float64 = 0.0
        var P_fuelcell_to_batt_ac: Float64 = 0.0
        var P_batt_to_load_ac: Float64 = 0.0
        var P_grid_to_load_ac: Float64 = 0.0
        var P_pv_to_load_ac: Float64 = 0.0
        var P_fuelcell_to_load_ac: Float64 = 0.0
        var P_available_pv: Float64 = 0.0
        var P_pv_to_grid_ac: Float64 = 0.0
        var P_batt_to_grid_ac: Float64 = 0.0
        var P_fuelcell_to_grid_ac: Float64 = 0.0
        var P_gen_ac: Float64 = 0.0
        var P_grid_ac: Float64 = 0.0
        var P_grid_to_batt_loss_ac: Float64 = 0.0
        var P_batt_to_load_loss_ac: Float64 = 0.0
        var P_batt_to_grid_loss_ac: Float64 = 0.0
        var P_pv_to_batt_loss_ac: Float64 = 0.0
        var P_batt_to_system_loss: Float64 = 0.0
        var P_batt_to_system_loss_conversion_loss: Float64 = 0.0

        var P_battery_ac: Float64 = 0.0
        if P_battery_dc < 0.0:
            P_battery_ac = P_battery_dc / self.m_BatteryPower.singlePointEfficiencyACToDC
        elif P_battery_dc > 0.0:
            P_battery_ac = P_battery_dc * self.m_BatteryPower.singlePointEfficiencyDCToAC

        if P_battery_ac <= 0.0:
            if not (self.m_BatteryPower.canSystemCharge or self.m_BatteryPower.canGridCharge or self.m_BatteryPower.canFuelCellCharge) and P_battery_ac < 0.0:
                P_pv_to_batt_ac = P_grid_to_batt_ac = P_fuelcell_to_batt_ac = 0.0
                P_battery_ac = 0.0
            P_pv_to_load_ac = P_pv_ac
            if P_pv_to_load_ac > P_load_ac:
                P_pv_to_load_ac = P_load_ac
            P_fuelcell_to_load_ac = fmin(P_load_ac - P_pv_to_load_ac, P_fuelcell_ac)
            if self.m_BatteryPower.canSystemCharge:
                P_pv_to_batt_ac = fabs(P_battery_ac)
                P_available_pv = P_pv_ac - P_pv_to_load_ac - P_system_loss_ac
                if P_pv_to_batt_ac > P_available_pv:
                    if P_available_pv < 0.0:
                        P_pv_to_batt_ac = 0.0
                    else:
                        P_pv_to_batt_ac = P_available_pv
            var pv_handles_losses: Bool = P_pv_to_batt_ac > 0.0 or P_available_pv > 0.0
            if self.m_BatteryPower.canFuelCellCharge:
                P_fuelcell_to_batt_ac = fmin(fmax(0.0, fabs(P_battery_ac) - P_pv_to_batt_ac), P_fuelcell_ac - P_fuelcell_to_load_ac)
            if self.m_BatteryPower.canGridCharge:
                P_grid_to_batt_ac = fmax(0.0, fabs(P_battery_ac) - P_pv_to_batt_ac - P_fuelcell_to_batt_ac)
            if pv_handles_losses:
                P_pv_to_grid_ac = P_pv_ac - P_pv_to_batt_ac - P_pv_to_load_ac - P_system_loss_ac
            else:
                P_pv_to_grid_ac = P_pv_ac - P_pv_to_batt_ac - P_pv_to_load_ac
            P_fuelcell_to_grid_ac = P_fuelcell_ac - P_fuelcell_to_load_ac - P_fuelcell_to_batt_ac
        else:
            if not self.m_BatteryPower.canDischarge and P_battery_ac > 0.0:
                P_batt_to_grid_ac = P_batt_to_load_ac = 0.0
                P_battery_ac = 0.0
            P_pv_to_load_ac = P_pv_ac
            if P_pv_ac >= P_load_ac:
                P_pv_to_load_ac = P_load_ac
                P_fuelcell_to_load_ac = 0.0
                P_batt_to_load_ac = 0.0
                P_pv_to_grid_ac = P_pv_ac - P_pv_to_load_ac
                P_fuelcell_to_grid_ac = P_fuelcell_ac
            else:
                P_fuelcell_to_load_ac = fmin(P_fuelcell_ac, P_load_ac - P_pv_to_load_ac)
                P_batt_to_load_ac = fmin(P_battery_ac - P_system_loss_ac, P_load_ac - P_pv_to_load_ac - P_fuelcell_to_load_ac)
            P_batt_to_grid_ac = P_battery_ac - P_system_loss_ac - P_batt_to_load_ac
            P_fuelcell_to_grid_ac = P_fuelcell_ac - P_fuelcell_to_load_ac
            P_batt_to_system_loss = P_system_loss_ac

        P_pv_to_batt_loss_ac = P_pv_to_batt_ac * (1.0 - self.m_BatteryPower.singlePointEfficiencyACToDC)
        P_grid_to_batt_loss_ac = P_grid_to_batt_ac * (1.0 - self.m_BatteryPower.singlePointEfficiencyACToDC)
        P_batt_to_load_loss_ac = P_batt_to_load_ac * (1.0 / self.m_BatteryPower.singlePointEfficiencyDCToAC - 1.0)
        P_batt_to_grid_loss_ac = P_batt_to_grid_ac * (1.0 / self.m_BatteryPower.singlePointEfficiencyDCToAC - 1.0)
        P_batt_to_system_loss_conversion_loss = P_batt_to_system_loss * (1.0 / self.m_BatteryPower.singlePointEfficiencyDCToAC - 1.0)

        P_grid_to_load_ac = P_load_ac - P_pv_to_load_ac - P_batt_to_load_ac - P_fuelcell_to_load_ac
        P_gen_ac = P_pv_ac + P_fuelcell_ac + P_inverter_draw_ac + P_battery_ac - P_system_loss_ac
        P_grid_ac = P_gen_ac - P_load_ac

        if not self.m_BatteryPower.canGridCharge and P_battery_ac < -self.m_BatteryPower.tolerance:
            if (fabs(P_grid_ac - P_grid_to_load_ac) > self.m_BatteryPower.tolerance) and (-P_grid_ac > P_grid_to_load_ac):
                P_battery_ac = P_pv_ac - P_pv_to_grid_ac - P_pv_to_load_ac - P_system_loss_ac
                P_battery_ac = P_battery_ac if P_battery_ac > 0.0 else 0.0
                self.m_BatteryPower.powerBatteryDC = -P_battery_ac * self.m_BatteryPower.singlePointEfficiencyACToDC
                self.calculateACConnected()
                return

        if fabs(P_grid_to_load_ac) < self.m_BatteryPower.tolerance:
            P_grid_to_load_ac = 0.0
        if fabs(P_grid_to_batt_ac) < self.m_BatteryPower.tolerance:
            P_grid_to_batt_ac = 0.0
        if fabs(P_grid_ac) < self.m_BatteryPower.tolerance:
            P_grid_ac = 0.0

        self.m_BatteryPower.powerBatteryAC = P_battery_ac
        self.m_BatteryPower.powerGrid = P_grid_ac
        self.m_BatteryPower.powerGeneratedBySystem = P_gen_ac
        self.m_BatteryPower.powerSystemToLoad = P_pv_to_load_ac
        self.m_BatteryPower.powerSystemToBattery = P_pv_to_batt_ac
        self.m_BatteryPower.powerSystemToGrid = P_pv_to_grid_ac
        self.m_BatteryPower.powerGridToBattery = P_grid_to_batt_ac
        self.m_BatteryPower.powerGridToLoad = P_grid_to_load_ac
        self.m_BatteryPower.powerBatteryToLoad = P_batt_to_load_ac
        self.m_BatteryPower.powerBatteryToGrid = P_batt_to_grid_ac
        self.m_BatteryPower.powerFuelCellToBattery = P_fuelcell_to_batt_ac
        self.m_BatteryPower.powerFuelCellToLoad = P_fuelcell_to_load_ac
        self.m_BatteryPower.powerFuelCellToGrid = P_fuelcell_to_grid_ac
        self.m_BatteryPower.powerConversionLoss = P_batt_to_load_loss_ac + P_batt_to_grid_loss_ac + P_grid_to_batt_loss_ac + P_pv_to_batt_loss_ac + P_batt_to_system_loss_conversion_loss

    def calculateDCConnected(inout self):
        """
        * \function calculateDCConnected
        *
        * Calculate the power flow for a DC connected battery system.
        """
        var P_load_ac: Float64 = self.m_BatteryPower.powerLoad
        var P_battery_ac: Float64 = 0.0
        var P_pv_ac: Float64 = 0.0
        var P_gen_ac: Float64 = 0.0
        var P_pv_to_batt_ac: Float64 = 0.0
        var P_grid_to_batt_ac: Float64 = 0.0
        var P_batt_to_load_ac: Float64 = 0.0
        var P_grid_to_load_ac: Float64 = 0.0
        var P_pv_to_load_ac: Float64 = 0.0
        var P_pv_to_grid_ac: Float64 = 0.0
        var P_batt_to_grid_ac: Float64 = 0.0
        var P_grid_ac: Float64 = 0.0
        var P_conversion_loss_ac: Float64 = 0.0

        var P_pv_to_batt_dc: Float64 = 0.0
        var P_grid_to_batt_dc: Float64 = 0.0
        var P_pv_to_inverter_dc: Float64 = 0.0

        var P_system_loss_dc: Float64 = self.m_BatteryPower.powerSystemLoss
        var P_battery_dc_pre_bms: Float64 = self.m_BatteryPower.powerBatteryDC
        var P_battery_dc: Float64 = self.m_BatteryPower.powerBatteryDC
        var P_pv_dc: Float64 = self.m_BatteryPower.powerSystem

        if P_battery_dc_pre_bms < 0.0:
            P_battery_dc = P_battery_dc_pre_bms / self.m_BatteryPower.singlePointEfficiencyDCToDC
        elif P_battery_dc > 0.0:
            P_battery_dc = P_battery_dc_pre_bms * self.m_BatteryPower.singlePointEfficiencyDCToDC

        var pv_handles_loss: Bool = P_pv_dc > P_system_loss_dc and P_battery_dc <= self.m_BatteryPower.tolerance

        var P_gen_dc: Float64 = P_pv_dc + P_battery_dc - P_system_loss_dc
        var voltage: Float64 = self.m_BatteryPower.voltageSystem
        var efficiencyDCAC: Float64 = self.m_BatteryPower.sharedInverter[].efficiencyAC * 0.01

        if voltage <= 0.0:
            voltage = self.m_BatteryPower.sharedInverter[].getInverterDCNominalVoltage()

        if isnan(efficiencyDCAC) or self.m_BatteryPower.sharedInverter[].efficiencyAC <= 0.0:
            efficiencyDCAC = self.m_BatteryPower.sharedInverter[].getMaxPowerEfficiency() * 0.01

        if P_battery_dc < 0.0:
            if self.m_BatteryPower.canSystemCharge or self.m_BatteryPower.canClipCharge:
                P_pv_to_batt_dc = fabs(P_battery_dc)
                if P_pv_to_batt_dc > P_pv_dc - P_system_loss_dc:
                    P_pv_to_batt_dc = P_pv_dc - P_system_loss_dc
                    if P_pv_to_batt_dc < 0.0:
                        P_pv_to_batt_dc = 0.0

            if P_pv_dc >= P_pv_to_batt_dc + P_system_loss_dc:
                P_pv_to_inverter_dc = P_pv_dc - P_pv_to_batt_dc - P_system_loss_dc
            else:
                P_pv_to_inverter_dc = P_pv_dc - P_pv_to_batt_dc
                pv_handles_loss = False

            if pv_handles_loss:
                P_grid_to_batt_dc = fabs(P_battery_dc) - P_pv_to_batt_dc
            else:
                P_grid_to_batt_dc = fabs(P_battery_dc) - P_pv_to_batt_dc - P_system_loss_dc

            if not self.m_BatteryPower.canGridCharge and P_grid_to_batt_dc > self.m_BatteryPower.tolerance:
                self.m_BatteryPower.powerBatteryDC = -P_pv_to_batt_dc * self.m_BatteryPower.singlePointEfficiencyDCToDC
                self.calculateDCConnected()
                return

            var P_gen_dc_inverter: Float64 = P_pv_to_inverter_dc - P_grid_to_batt_dc
            if not pv_handles_loss:
                P_gen_dc_inverter -= P_system_loss_dc

            self.m_BatteryPower.sharedInverter[].calculateACPower(P_gen_dc_inverter, voltage, self.m_BatteryPower.sharedInverter[].Tdry_C)
            efficiencyDCAC = self.m_BatteryPower.sharedInverter[].efficiencyAC * 0.01
            if efficiencyDCAC <= 0.05 and (P_grid_to_batt_dc > 0.0 or P_pv_to_inverter_dc > 0.0):
                efficiencyDCAC = 0.05

            if P_gen_dc_inverter > 0.0:
                self.m_BatteryPower.sharedInverter[].powerAC_kW = P_gen_dc_inverter * efficiencyDCAC
            else:
                self.m_BatteryPower.sharedInverter[].powerAC_kW = P_gen_dc_inverter / efficiencyDCAC
            self.m_BatteryPower.sharedInverter[].efficiencyAC = efficiencyDCAC * 100.0

            P_gen_ac = self.m_BatteryPower.sharedInverter[].powerAC_kW
            P_grid_to_batt_ac = P_grid_to_batt_dc / efficiencyDCAC

            if isnan(P_gen_ac) and self.m_BatteryPower.sharedInverter[].powerDC_kW == 0.0:
                P_gen_ac = 0.0
                P_grid_to_batt_ac = 0.0

            P_pv_ac = P_pv_to_inverter_dc * efficiencyDCAC
            P_pv_to_load_ac = P_load_ac
            if P_pv_to_load_ac > P_pv_ac:
                P_pv_to_load_ac = P_pv_ac

            P_grid_to_load_ac = P_load_ac - P_pv_to_load_ac
            P_pv_to_grid_ac = P_pv_ac - P_pv_to_load_ac

            if P_pv_to_batt_dc + P_grid_to_batt_ac > 0.0:
                P_battery_ac = -(P_pv_to_batt_dc + P_grid_to_batt_ac)
            P_pv_to_batt_ac = P_pv_to_batt_dc
        else:
            self.m_BatteryPower.sharedInverter[].calculateACPower(P_gen_dc, voltage, self.m_BatteryPower.sharedInverter[].Tdry_C)
            efficiencyDCAC = self.m_BatteryPower.sharedInverter[].efficiencyAC * 0.01
            P_gen_ac = self.m_BatteryPower.sharedInverter[].powerAC_kW

            if pv_handles_loss:
                P_pv_ac = (P_pv_dc - P_system_loss_dc) * efficiencyDCAC
                P_battery_ac = P_battery_dc * efficiencyDCAC
            else:
                P_pv_ac = P_pv_dc * efficiencyDCAC
                P_battery_ac = (P_battery_dc - P_system_loss_dc) * efficiencyDCAC

            if not self.m_BatteryPower.canDischarge and P_battery_ac > 0.0:
                P_batt_to_grid_ac = P_batt_to_load_ac = 0.0
                P_battery_ac = 0.0

            P_pv_to_load_ac = P_pv_ac
            if P_pv_ac >= P_load_ac:
                P_pv_to_load_ac = P_load_ac
                P_batt_to_load_ac = 0.0
                P_pv_to_grid_ac = P_pv_ac - P_pv_to_load_ac
            else:
                P_batt_to_load_ac = fmin(P_battery_ac, P_load_ac - P_pv_to_load_ac)
            P_batt_to_grid_ac = P_battery_ac - P_batt_to_load_ac

        P_conversion_loss_ac = P_gen_dc - P_gen_ac + P_battery_dc_pre_bms - P_battery_dc
        P_grid_to_load_ac = P_load_ac - P_pv_to_load_ac - P_batt_to_load_ac
        P_grid_ac = P_gen_ac - P_load_ac

        if P_pv_to_load_ac + P_grid_to_load_ac + P_batt_to_load_ac != P_load_ac:
            P_grid_to_load_ac = P_load_ac - P_pv_to_load_ac - P_batt_to_load_ac

        if fabs(P_grid_to_load_ac) < self.m_BatteryPower.tolerance:
            P_grid_to_load_ac = 0.0
        if fabs(P_grid_to_batt_ac) < self.m_BatteryPower.tolerance:
            P_grid_to_batt_ac = 0.0
        if fabs(P_grid_ac) < self.m_BatteryPower.tolerance:
            P_grid_ac = 0.0

        self.m_BatteryPower.powerBatteryAC = P_battery_ac
        self.m_BatteryPower.powerGrid = P_grid_ac
        self.m_BatteryPower.powerGeneratedBySystem = P_gen_ac
        self.m_BatteryPower.powerSystemToLoad = P_pv_to_load_ac
        self.m_BatteryPower.powerSystemToBattery = P_pv_to_batt_ac
        self.m_BatteryPower.powerSystemToGrid = P_pv_to_grid_ac
        self.m_BatteryPower.powerGridToBattery = P_grid_to_batt_ac
        self.m_BatteryPower.powerGridToLoad = P_grid_to_load_ac
        self.m_BatteryPower.powerBatteryToLoad = P_batt_to_load_ac
        self.m_BatteryPower.powerBatteryToGrid = P_batt_to_grid_ac
        self.m_BatteryPower.powerConversionLoss = P_conversion_loss_ac