# Helper: noop write for null stream
@always_inline
def noop_write(s: String):

# Null stream type (analogous to C++ nullstream)
struct nullstream:
    var write_fn: fn(String) -> None

    def __init__(inout self):
        self.write_fn = noop_write

    def __init__(inout self, other: nullstream):
        self.write_fn = other.write_fn

    def __lshift__[T: Writable](inout self, value: T) -> inout Self:
        # No output
        return self

    def __lshift__(inout self, value: String) -> inout Self:
        return self

# Singleton null stream instance
var ns: nullstream

# Logger class (analogous to C++ logger)
struct logger:
    var _out_stream: nullstream

    def __init__(inout self):
        self._out_stream = ns

    def __init__(inout self, stream: nullstream):
        self._out_stream = stream

    # Explicit conversion to nullstream (not used further but kept for faithfulness)
    def to_nullstream(inout self) -> inout nullstream:
        return self._out_stream

    def __lshift__[T: Writable](inout self, value: T) -> inout Self:
        self._out_stream.__lshift__(value)
