# Template operator<< for vector (equivalent to vector)
def __lshift__[T: Writable](inout s: nullstream, t: DynamicVector[T]) -> inout nullstream:
    s << "["
    for i in range(len(t)):
        s << String(t[i])
        if i != len(t) - 1:
            s << ", "
    s << "]"
    return s

# Template operator<< for matrix_t
def __lshift__[T: Writable](inout s: nullstream, t: matrix_t[T]) -> inout nullstream:
    var nr = t.nrows()
    var nc = t.ncols()
    s << "["
    for i in range(nr):
        s << "["
        for j in range(nc):
            s << String(t.at(i, j))
            if j != nc - 1:
                s << ", "
        s << "]"
        if i != nr - 1:
            s << ", "
    s << "]"
    return s

