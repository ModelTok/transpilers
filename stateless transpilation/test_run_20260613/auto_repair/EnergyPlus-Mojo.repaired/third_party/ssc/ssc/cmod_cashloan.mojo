class cm_cashloan(compute_module):
private:
    var cf: util.matrix_t[Float64]
    var ibi_fed_amount: Float64
    var ibi_sta_amount: Float64
    var ibi_uti_amount: Float64
    var ibi_oth_amount: Float64
    var ibi_fed_per: Float64
    var ibi_sta_per: Float64
    var ibi_uti_per: Float64
    var ibi_oth_per: Float64
    var cbi_fed_amount: Float64
    var cbi_sta_amount: Float64
    var cbi_uti_amount: Float64
    var cbi_oth_amount: Float64
    var hourly_energy_calcs: hourly_energy_calculation

public:
    def __init__(inout self):
        self.add_var_info(vtab_standard_financial_)
        self.add_var_info(vtab_standard_loan_)
        self.add_var_info(vtab_oandm_)
        self.add_var_info(vtab_depreciation_)
        self.add_var_info(vtab_tax_credits_)
        self.add_var_info(vtab_payment_incentives_)
        self.add_var_info(vtab_battery_replacement_cost_)
        self.add_var_info(vtab_fuelcell_replacement_cost_)
        self.add_var_info(vtab_cashloan)

    def exec(inout self):
        var i: Int
        var is_commercial: Bool = (self.as_integer("market")==1)
        var is_mortgage: Bool = (self.as_integer("mortgage")==1)
        var nyears: Int = self.as_integer("analysis_period")
        self.cf.resize_fill( CF_max, nyears+1, 0.0 )
        var count: Int = 0
        var arrp: Pointer[ssc_number_t] = 0
        if self.as_integer("system_use_lifetime_output") == 1:
            for i in range(1, nyears+1):
                self.cf.at(CF_degradation, i) = 1.0
        else:
            var count_degrad: Int = 0
            var degrad: Pointer[ssc_number_t] = 0
            degrad = self.as_array("degradation", &count_degrad)
            if count_degrad == 1:
                for i in range(1, nyears+1):
                    self.cf.at(CF_degradation, i) = pow((1.0 - degrad[0] / 100.0), i - 1)
            elif count_degrad > 0:
                for i in range(0, min(nyears, count_degrad)):
                    self.cf.at(CF_degradation, i + 1) = (1.0 - degrad[i] / 100.0)
        self.hourly_energy_calcs.calculate(self)
        if self.as_integer("system_use_lifetime_output")==0:
            var first_year_energy: Float64 = 0.0
            for h in range(0, 8760):
                first_year_energy += self.hourly_energy_calcs.hourly_energy()[h]
            for y in range(1, nyears+1):
                self.cf.at(CF_energy_net, y) = first_year_energy * self.cf.at(CF_degradation, y)
        else:
            for y in range(1, nyears+1):
                self.cf.at(CF_energy_net, y) = 0
                var ind: Int = 0
                for m in range(0, 12):
                    for d in range(0, util.nday[m]):
                        for h in range(0, 24):
                            if ind < 8760:
                                self.cf.at(CF_energy_net, y) += self.hourly_energy_calcs.hourly_energy()[(y - 1) * 8760 + ind] * self.cf.at(CF_degradation, y)
                                ind += 1
        if self.is_assigned("annual_thermal_value"):
            arrp = self.as_array("annual_thermal_value", &count)
            i = 0
            while i < nyears and i < count:
                self.cf.at(CF_thermal_value, i + 1) = Float64(arrp[i +1])
                i += 1
        arrp = self.as_array("annual_energy_value", &count)
        i=0
        while i < nyears and i < count:
            self.cf.at(CF_energy_value, i+1) = Float64(arrp[i+1])
            i += 1
        var year1_fuel_use: Float64 = self.as_double("annual_fuel_usage")
        var fuel_use: List[Float64] = List[Float64]()
        if (self.as_integer("system_use_lifetime_output") == 1) and self.is_assigned("annual_fuel_usage_lifetime"):
            fuel_use = self.as_vector_double("annual_fuel_usage_lifetime")
            if fuel_use.size() != (nyears + 1):
                throw exec_error("singleowner", util.format("fuel usage years (%d) not equal to analysis period years (%d).", fuel_use.size() - 1, nyears))
        else:
            fuel_use.push_back(0.0)
            for y in range(0, nyears):
                fuel_use.push_back(year1_fuel_use)
        var nameplate: Float64 = self.as_double("system_capacity")
        var inflation_rate: Float64 = self.as_double("inflation_rate")*0.01
        var property_tax: Float64 = self.as_double("property_tax_rate")*0.01
        var property_tax_decline_percentage: Float64 = self.as_double("prop_tax_assessed_decline")
        var insurance_rate: Float64 = self.as_double("insurance_rate")*0.01
        var salvage_frac: Float64 = self.as_double("salvage_percentage")*0.01
        arrp = self.as_array("federal_tax_rate", &count)
        if count > 0:
            if count == 1:
                for i in range(0, nyears):
                    self.cf.at(CF_federal_tax_frac, i + 1) = arrp[0]*0.01
            else:
                for i in range(0, min(nyears, count)):
                    self.cf.at(CF_federal_tax_frac, i + 1) = arrp[i] * 0.01
        arrp = self.as_array("state_tax_rate", &count)
        if count > 0:
            if count == 1:
                for i in range(0, nyears):
                    self.cf.at(CF_state_tax_frac, i + 1) = arrp[0] * 0.01
            else:
                for i in range(0, min(nyears, count)):
                    self.cf.at(CF_state_tax_frac, i + 1) = arrp[i] * 0.01
        for i in range(0, nyears+1):
            self.cf.at(CF_effective_tax_frac, i) = self.cf.at(CF_state_tax_frac, i) + (1.0 - self.cf.at(CF_state_tax_frac, i))*self.cf.at(CF_federal_tax_frac, i)
        var real_discount_rate: Float64 = self.as_double("real_discount_rate")*0.01
        var nom_discount_rate: Float64 = (1.0 + real_discount_rate) * (1.0 + inflation_rate) - 1.0
        var total_cost: Float64 = self.as_double("total_installed_cost")
        var property_tax_assessed_value: Float64 = total_cost * self.as_double("prop_tax_cost_assessed_percent") * 0.01
        var loan_term: Int = self.as_integer("loan_term")
        var loan_rate: Float64 = self.as_double("loan_rate")*0.01
        var debt_frac: Float64 = self.as_double("debt_fraction")*0.01
        self.escal_or_annual( CF_om_fixed_expense, nyears, "om_fixed", inflation_rate, 1.0, False, self.as_double("om_fixed_escal")*0.01 )
        self.escal_or_annual( CF_om_production_expense, nyears, "om_production", inflation_rate, 0.001, False, self.as_double("om_production_escal")*0.01 )
        self.escal_or_annual( CF_om_capacity_expense, nyears, "om_capacity", inflation_rate, 1.0, False, self.as_double("om_capacity_escal")*0.01 )
        self.escal_or_annual( CF_om_fuel_expense, nyears, "om_fuel_cost", inflation_rate, self.as_double("system_heat_rate")*0.001, False, self.as_double("om_fuel_cost_escal")*0.01 )
        var add_om_num_types: Int = self.as_integer("add_om_num_types")
        var nameplate1: ssc_number_t = 0
        var nameplate2: ssc_number_t = 0
        if add_om_num_types > 0:
            self.escal_or_annual(CF_om_fixed1_expense, nyears, "om_fixed1", inflation_rate, 1.0, False, self.as_double("om_fixed_escal")*0.01)
            self.escal_or_annual(CF_om_production1_expense, nyears, "om_production1", inflation_rate, 0.001, False, self.as_double("om_production_escal")*0.01)
            self.escal_or_annual(CF_om_capacity1_expense, nyears, "om_capacity1", inflation_rate, 1.0, False, self.as_double("om_capacity_escal")*0.01)
            nameplate1 = self.as_number("om_capacity1_nameplate")
        if add_om_num_types > 1:
            self.escal_or_annual(CF_om_fixed2_expense, nyears, "om_fixed2", inflation_rate, 1.0, False, self.as_double("om_fixed_escal")*0.01)
            self.escal_or_annual(CF_om_production2_expense, nyears, "om_production2", inflation_rate, 0.001, False, self.as_double("om_production_escal")*0.01)
            self.escal_or_annual(CF_om_capacity2_expense, nyears, "om_capacity2", inflation_rate, 1.0, False, self.as_double("om_capacity_escal")*0.01)
            nameplate2 = self.as_number("om_capacity2_nameplate")
        if (self.as_integer("en_batt") == 1) and (self.as_integer("batt_replacement_option") > 0):
            var batt_rep: Pointer[ssc_number_t] = 0
            var replacement_percent: List[ssc_number_t] = List[ssc_number_t]()
            batt_rep = self.as_array("batt_bank_replacement", &count)
            if self.as_integer("batt_replacement_option") == 1:
                for i in range(0, count):
                    replacement_percent.push_back(100)
            else:
                replacement_percent = self.as_vector_ssc_number_t("batt_replacement_schedule_percent")
            var batt_cap: Float64 = self.as_double("batt_computed_bank_capacity")
            self.escal_or_annual(CF_battery_replacement_cost_schedule, nyears, "om_replacement_cost1", inflation_rate, batt_cap, False, self.as_double("om_replacement_cost_escal") * 0.01)
            for i in range(0, min(nyears, count)):
                self.cf.at(CF_battery_replacement_cost, i + 1) = batt_rep[i + 1] * replacement_percent[i] * 0.01 * self.cf.at(CF_battery_replacement_cost_schedule, i + 1)
        if self.is_assigned("fuelcell_replacement_option") and (self.as_integer("fuelcell_replacement_option") > 0):
            var fuelcell_rep: Pointer[ssc_number_t] = 0
            if self.as_integer("fuelcell_replacement_option") == 1:
                fuelcell_rep = self.as_array("fuelcell_replacement", &count)
            else:
                fuelcell_rep = self.as_array("fuelcell_replacement_schedule", &count)
            self.escal_or_annual(CF_fuelcell_replacement_cost_schedule, nyears, "om_replacement_cost2", inflation_rate, nameplate2, False, self.as_double("om_replacement_cost_escal")*0.01)
            for i in range(0, min(nyears, count)):
                self.cf.at(CF_fuelcell_replacement_cost, i + 1) = fuelcell_rep[i] * self.cf.at(CF_fuelcell_replacement_cost_schedule, i + 1)
        self.escal_or_annual( CF_om_opt_fuel_1_expense, nyears, "om_opt_fuel_1_cost", inflation_rate, 1.0, False, self.as_double("om_opt_fuel_1_cost_escal")*0.01 )
        self.escal_or_annual( CF_om_opt_fuel_2_expense, nyears, "om_opt_fuel_2_cost", inflation_rate, 1.0, False, self.as_double("om_opt_fuel_2_cost_escal")*0.01 )
        var om_opt_fuel_1_usage: Float64 = self.as_double("om_opt_fuel_1_usage")
        var om_opt_fuel_2_usage: Float64 = self.as_double("om_opt_fuel_2_usage")
        self.ibi_fed_amount = self.as_double("ibi_fed_amount")
        self.ibi_sta_amount = self.as_double("ibi_sta_amount")
        self.ibi_uti_amount = self.as_double("ibi_uti_amount")
        self.ibi_oth_amount = self.as_double("ibi_oth_amount")
        self.ibi_fed_per = self.as_double("ibi_fed_percent")*0.01*total_cost
        if self.ibi_fed_per > self.as_double("ibi_fed_percent_maxvalue"):
            self.ibi_fed_per = self.as_double("ibi_fed_percent_maxvalue")
        self.ibi_sta_per = self.as_double("ibi_sta_percent")*0.01*total_cost
        if self.ibi_sta_per > self.as_double("ibi_sta_percent_maxvalue"):
            self.ibi_sta_per = self.as_double("ibi_sta_percent_maxvalue")
        self.ibi_uti_per = self.as_double("ibi_uti_percent")*0.01*total_cost
        if self.ibi_uti_per > self.as_double("ibi_uti_percent_maxvalue"):
            self.ibi_uti_per = self.as_double("ibi_uti_percent_maxvalue")
        self.ibi_oth_per = self.as_double("ibi_oth_percent")*0.01*total_cost
        if self.ibi_oth_per > self.as_double("ibi_oth_percent_maxvalue"):
            self.ibi_oth_per = self.as_double("ibi_oth_percent_maxvalue")
        self.cbi_fed_amount = 1000.0*nameplate*self.as_double("cbi_fed_amount")
        if self.cbi_fed_amount > self.as_double("cbi_fed_maxvalue"):
            self.cbi_fed_amount = self.as_double("cbi_fed_maxvalue")
        self.cbi_sta_amount = 1000.0*nameplate*self.as_double("cbi_sta_amount")
        if self.cbi_sta_amount > self.as_double("cbi_sta_maxvalue"):
            self.cbi_sta_amount = self.as_double("cbi_sta_maxvalue")
        self.cbi_uti_amount = 1000.0*nameplate*self.as_double("cbi_uti_amount")
        if self.cbi_uti_amount > self.as_double("cbi_uti_maxvalue"):
            self.cbi_uti_amount = self.as_double("cbi_uti_maxvalue")
        self.cbi_oth_amount = 1000.0*nameplate*self.as_double("cbi_oth_amount")
        if self.cbi_oth_amount > self.as_double("cbi_oth_maxvalue"):
            self.cbi_oth_amount = self.as_double("cbi_oth_maxvalue")
        self.compute_production_incentive( CF_pbi_fed, nyears, "pbi_fed_amount", "pbi_fed_term", "pbi_fed_escal" )
        self.compute_production_incentive( CF_pbi_sta, nyears, "pbi_sta_amount", "pbi_sta_term", "pbi_sta_escal" )
        self.compute_production_incentive( CF_pbi_uti, nyears, "pbi_uti_amount", "pbi_uti_term", "pbi_uti_escal" )
        self.compute_production_incentive( CF_pbi_oth, nyears, "pbi_oth_amount", "pbi_oth_term", "pbi_oth_escal" )
        self.compute_production_incentive_IRS_2010_37( CF_ptc_sta, nyears, "ptc_sta_amount", "ptc_sta_term", "ptc_sta_escal" )
        self.compute_production_incentive_IRS_2010_37( CF_ptc_fed, nyears, "ptc_fed_amount", "ptc_fed_term", "ptc_fed_escal" )
        var federal_itc_basis: Float64 = total_cost
            - ( self.as_boolean("ibi_fed_amount_deprbas_fed")  ? self.ibi_fed_amount : 0 )
            - ( self.as_boolean("ibi_sta_amount_deprbas_fed")  ? self.ibi_sta_amount : 0 )
            - ( self.as_boolean("ibi_uti_amount_deprbas_fed")  ? self.ibi_uti_amount : 0 )
            - ( self.as_boolean("ibi_oth_amount_deprbas_fed")  ? self.ibi_oth_amount : 0 )
            - ( self.as_boolean("ibi_fed_percent_deprbas_fed") ? self.ibi_fed_per : 0 )
            - ( self.as_boolean("ibi_sta_percent_deprbas_fed") ? self.ibi_sta_per : 0 )
            - ( self.as_boolean("ibi_uti_percent_deprbas_fed") ? self.ibi_uti_per : 0 )
            - ( self.as_boolean("ibi_oth_percent_deprbas_fed") ? self.ibi_oth_per : 0 )
            - ( self.as_boolean("cbi_fed_deprbas_fed")  ? self.cbi_fed_amount : 0 )
            - ( self.as_boolean("cbi_sta_deprbas_fed")  ? self.cbi_sta_amount : 0 )
            - ( self.as_boolean("cbi_uti_deprbas_fed")  ? self.cbi_uti_amount : 0 )
            - ( self.as_boolean("cbi_oth_deprbas_fed")  ? self.cbi_oth_amount : 0 )
        var itc_fed_amount: Float64 = self.as_double("itc_fed_amount")
        var itc_fed_frac: Float64 = self.as_double("itc_fed_percent")*0.01
        var itc_fed_per: Float64 = itc_fed_frac * federal_itc_basis
        if itc_fed_per > self.as_double("itc_fed_percent_maxvalue"):
            itc_fed_per = self.as_double("itc_fed_percent_maxvalue")
        var state_itc_basis: Float64 = total_cost
            - ( self.as_boolean("ibi_fed_amount_deprbas_sta")  ? self.ibi_fed_amount : 0 )
            - ( self.as_boolean("ibi_sta_amount_deprbas_sta")  ? self.ibi_sta_amount : 0 )
            - ( self.as_boolean("ibi_uti_amount_deprbas_sta")  ? self.ibi_uti_amount : 0 )
            - ( self.as_boolean("ibi_oth_amount_deprbas_sta")  ? self.ibi_oth_amount : 0 )
            - ( self.as_boolean("ibi_fed_percent_deprbas_sta") ? self.ibi_fed_per : 0 )
            - ( self.as_boolean("ibi_sta_percent_deprbas_sta") ? self.ibi_sta_per : 0 )
            - ( self.as_boolean("ibi_uti_percent_deprbas_sta") ? self.ibi_uti_per : 0 )
            - ( self.as_boolean("ibi_oth_percent_deprbas_sta") ? self.ibi_oth_per : 0 )
            - ( self.as_boolean("cbi_fed_deprbas_sta")  ? self.cbi_fed_amount : 0 )
            - ( self.as_boolean("cbi_sta_deprbas_sta")  ? self.cbi_sta_amount : 0 )
            - ( self.as_boolean("cbi_uti_deprbas_sta")  ? self.cbi_uti_amount : 0 )
            - ( self.as_boolean("cbi_oth_deprbas_sta")  ? self.cbi_oth_amount : 0 )
        var itc_sta_amount: Float64 = self.as_double("itc_sta_amount")
        var itc_sta_frac: Float64 = self.as_double("itc_sta_percent")*0.01
        var itc_sta_per: Float64 = itc_sta_frac * state_itc_basis
        if itc_sta_per > self.as_double("itc_sta_percent_maxvalue"):
            itc_sta_per = self.as_double("itc_sta_percent_maxvalue")
        var federal_depr_basis: Float64 = federal_itc_basis
            - ( self.as_boolean("itc_fed_amount_deprbas_fed")   ? 0.5*itc_fed_amount : 0 )
            - ( self.as_boolean("itc_fed_percent_deprbas_fed")  ? 0.5*itc_fed_per : 0 )
            - ( self.as_boolean("itc_sta_amount_deprbas_fed")   ? 0.5*itc_sta_amount : 0 )
            - ( self.as_boolean("itc_sta_percent_deprbas_fed")  ? 0.5*itc_sta_per : 0 )
        var state_depr_basis: Float64 = state_itc_basis
            - ( self.as_boolean("itc_fed_amount_deprbas_sta")   ? 0.5*itc_fed_amount : 0 )
            - ( self.as_boolean("itc_fed_percent_deprbas_sta")  ? 0.5*itc_fed_per : 0 )
            - ( self.as_boolean("itc_sta_amount_deprbas_sta")   ? 0.5*itc_sta_amount : 0 )
            - ( self.as_boolean("itc_sta_percent_deprbas_sta")  ? 0.5*itc_sta_per : 0 )
        if is_commercial:
            if self.as_integer("depr_sta_type") == 1:
                self.depreciation_sched_macrs_half_year( CF_sta_depr_sched, nyears )
            elif self.as_integer("depr_sta_type") == 2:
                self.depreciation_sched_straight_line( CF_sta_depr_sched, nyears, self.as_integer("depr_sta_sl_years") )
            elif self.as_integer("depr_sta_type") == 3:
                var arr_len: Int
                var arr_cust: Pointer[ssc_number_t] = self.as_array( "depr_sta_custom", &arr_len )
                self.depreciation_sched_custom( CF_sta_depr_sched, nyears, arr_cust, arr_len )
            if self.as_integer("depr_fed_type") == 1:
                self.depreciation_sched_macrs_half_year( CF_fed_depr_sched, nyears )
            elif self.as_integer("depr_fed_type") == 2:
                self.depreciation_sched_straight_line( CF_fed_depr_sched, nyears, self.as_integer("depr_fed_sl_years") )
            elif self.as_integer("depr_fed_type") == 3:
                var arr_len: Int
                var arr_cust: Pointer[ssc_number_t] = self.as_array( "depr_fed_custom", &arr_len )
                self.depreciation_sched_custom( CF_fed_depr_sched, nyears, arr_cust, arr_len )
        var state_tax_savings: Float64 = 0.0
        var federal_tax_savings: Float64 = 0.0
        var adjusted_installed_cost: Float64 = total_cost
            - self.ibi_fed_amount
            - self.ibi_sta_amount
            - self.ibi_uti_amount
            - self.ibi_oth_amount
            - self.ibi_fed_per
            - self.ibi_sta_per
            - self.ibi_uti_per
            - self.ibi_oth_per
            - self.cbi_fed_amount
            - self.cbi_sta_amount
            - self.cbi_uti_amount
            - self.cbi_oth_amount
        var loan_amount: Float64 = debt_frac * adjusted_installed_cost
        var first_cost: Float64 = adjusted_installed_cost - loan_amount
        var capital_investment: Float64 = loan_amount + first_cost
        self.cf.at(CF_after_tax_net_equity_cost_flow,0) = -first_cost + state_tax_savings + federal_tax_savings
        self.cf.at(CF_after_tax_cash_flow,0) = self.cf.at(CF_after_tax_net_equity_cost_flow,0)
        self.cf.at(CF_payback_with_expenses, 0) = -capital_investment
        self.cf.at(CF_cumulative_payback_with_expenses, 0) = -capital_investment
        self.cf.at(CF_discounted_costs, 0) = capital_investment
        self.cf.at(CF_discounted_payback, 0) = self.cf.at(CF_discounted_savings, 0) - self.cf.at(CF_discounted_costs, 0)
        self.cf.at(CF_discounted_cumulative_payback, 0) = self.cf.at(CF_discounted_payback, 0)
        self.cf.at(CF_payback_without_expenses,0) = -capital_investment
        self.cf.at(CF_cumulative_payback_without_expenses,0) = -capital_investment
        var ibi_total: Float64 = self.ibi_fed_amount + self.ibi_fed_per + self.ibi_sta_amount + self.ibi_sta_per + self.ibi_uti_amount + self.ibi_uti_per + self.ibi_oth_amount + self.ibi_oth_per
        var cbi_total: Float64 = self.cbi_fed_amount + self.cbi_sta_amount + self.cbi_uti_amount + self.cbi_oth_amount
        var itc_total_fed: Float64 = itc_fed_amount + itc_fed_per
        var itc_total_sta: Float64 = itc_sta_amount + itc_sta_per
        for i in range(1, nyears+1):
            self.cf.at(CF_om_production_expense,i) *= self.cf.at(CF_energy_net,i)
            self.cf.at(CF_om_capacity_expense,i) *= nameplate
            self.cf.at(CF_om_capacity1_expense, i) *= nameplate1
            self.cf.at(CF_om_capacity2_expense, i) *= nameplate2
            self.cf.at(CF_om_fuel_expense,i) *= fuel_use[i]
            self.cf.at(CF_om_opt_fuel_1_expense,i) *= om_opt_fuel_1_usage
            self.cf.at(CF_om_opt_fuel_2_expense,i) *= om_opt_fuel_2_usage
            var decline_percent: Float64 = 100 - (i-1)*property_tax_decline_percentage
            self.cf.at(CF_property_tax_assessed_value,i) = (decline_percent > 0) ? property_tax_assessed_value * decline_percent * 0.01 : 0.0
            self.cf.at(CF_property_tax_expense,i) = self.cf.at(CF_property_tax_assessed_value,i) * property_tax
            self.cf.at(CF_insurance_expense,i) = total_cost * insurance_rate * pow( 1 + inflation_rate, i-1 )
            self.cf.at(CF_net_salvage_value, i) = 0.0
            if i == nyears:
                self.cf.at(CF_net_salvage_value,i) = total_cost * salvage_frac
            self.cf.at(CF_operating_expenses,i) = 
                +self.cf.at(CF_om_fixed_expense, i)
                + self.cf.at(CF_om_production_expense, i)
                + self.cf.at(CF_om_capacity_expense, i)
                + self.cf.at(CF_om_fixed1_expense, i)
                + self.cf.at(CF_om_production1_expense, i)
                + self.cf.at(CF_om_capacity1_expense, i)
                + self.cf.at(CF_om_fixed2_expense, i)
                + self.cf.at(CF_om_production2_expense, i)
                + self.cf.at(CF_om_capacity2_expense, i)
                + self.cf.at(CF_om_fuel_expense,i)
                + self.cf.at(CF_om_opt_fuel_1_expense,i)
                + self.cf.at(CF_om_opt_fuel_2_expense,i)
                + self.cf.at(CF_property_tax_expense,i)
                + self.cf.at(CF_insurance_expense,i)
                + self.cf.at(CF_battery_replacement_cost, i)
                + self.cf.at(CF_fuelcell_replacement_cost, i)
                - self.cf.at(CF_net_salvage_value,i)
            if is_commercial:
                self.cf.at(CF_deductible_expenses,i) = -self.cf.at(CF_operating_expenses,i)
            else:
                self.cf.at(CF_deductible_expenses,i) = -self.cf.at(CF_property_tax_expense,i)
            if i == 1:
                self.cf.at(CF_debt_balance, i-1) = loan_amount
                self.cf.at(CF_debt_payment_interest, i) = loan_amount * loan_rate
                self.cf.at(CF_debt_payment_principal,i) = -ppmt( loan_rate, i, loan_term, loan_amount, 0, 0 )
                self.cf.at(CF_debt_balance, i) = self.cf.at(CF_debt_balance, i - 1) - self.cf.at(CF_debt_payment_principal, i)
            else:
                if i <= loan_term:
                    self.cf.at(CF_debt_payment_interest, i) = loan_rate * self.cf.at(CF_debt_balance, i-1)
                    if loan_rate != 0.0:
                        self.cf.at(CF_debt_payment_principal,i) = loan_rate * loan_amount/(1 - pow((1 + loan_rate),-loan_term)) - self.cf.at(CF_debt_payment_interest,i)
                    else:
                        self.cf.at(CF_debt_payment_principal,i) = loan_amount / loan_term - self.cf.at(CF_debt_payment_interest,i)
                    self.cf.at(CF_debt_balance, i) = self.cf.at(CF_debt_balance, i - 1) - self.cf.at(CF_debt_payment_principal, i)
            self.cf.at(CF_debt_payment_total,i) = self.cf.at(CF_debt_payment_principal,i) + self.cf.at(CF_debt_payment_interest,i)
            self.cf.at(CF_pbi_total, i) = self.cf.at(CF_pbi_fed, i) + self.cf.at(CF_pbi_sta, i) + self.cf.at(CF_pbi_uti, i) + self.cf.at(CF_pbi_oth, i)
            self.cf.at(CF_ptc_total, i) = self.cf.at(CF_ptc_fed, i) + self.cf.at(CF_ptc_sta, i)
            self.cf.at(CF_sta_depreciation,i) = self.cf.at(CF_sta_depr_sched,i)*state_depr_basis
            self.cf.at(CF_fed_depreciation,i) = self.cf.at(CF_fed_depr_sched,i)*federal_depr_basis
            self.cf.at(CF_sta_incentive_income_less_deductions, i) =
                + self.cf.at(CF_deductible_expenses, i) 
                + self.cf.at(CF_pbi_total,i)
                - self.cf.at(CF_sta_depreciation,i)
            if i==1:
                self.cf.at(CF_sta_incentive_income_less_deductions, i) += ibi_total + cbi_total
            if is_commercial or is_mortgage:
                self.cf.at(CF_sta_incentive_income_less_deductions, i) -= self.cf.at(CF_debt_payment_interest,i)
            self.cf.at(CF_sta_taxable_income_less_deductions, i) = self.taxable_incentive_income( i, "sta" ) + self.cf.at(CF_deductible_expenses,i) - self.cf.at(CF_sta_depreciation,i)
            self.cf.at(CF_sta_taxable_incentive_income, i) = self.taxable_incentive_income(i, "sta")
            if is_commercial or is_mortgage:
                self.cf.at(CF_sta_taxable_income_less_deductions, i) -= self.cf.at(CF_debt_payment_interest,i)
            self.cf.at(CF_sta_tax_savings, i) = self.cf.at(CF_ptc_sta,i) - self.cf.at(CF_state_tax_frac,i)*self.cf.at(CF_sta_taxable_income_less_deductions,i)
            if i==1:
                self.cf.at(CF_sta_tax_savings, i) += itc_sta_amount + itc_sta_per
            self.cf.at(CF_fed_incentive_income_less_deductions, i) =
                + self.cf.at(CF_deductible_expenses, i)
                + self.cf.at(CF_pbi_total,i)
                - self.cf.at(CF_fed_depreciation,i)
                + self.cf.at(CF_sta_tax_savings, i)
            if i==1:
                self.cf.at(CF_fed_incentive_income_less_deductions, i) += ibi_total + cbi_total
            if is_commercial or is_mortgage:
                self.cf.at(CF_fed_incentive_income_less_deductions, i) -= self.cf.at(CF_debt_payment_interest,i)
            self.cf.at(CF_fed_taxable_income_less_deductions, i) = self.taxable_incentive_income( i, "fed" ) + self.cf.at(CF_deductible_expenses,i) - self.cf.at(CF_fed_depreciation,i) + self.cf.at(CF_sta_tax_savings, i)
            self.cf.at(CF_fed_taxable_incentive_income, i) = self.taxable_incentive_income(i, "fed")
            if is_commercial or is_mortgage:
                self.cf.at(CF_fed_taxable_income_less_deductions, i) -= self.cf.at(CF_debt_payment_interest,i)
            self.cf.at(CF_fed_tax_savings, i) = self.cf.at(CF_ptc_fed,i) - self.cf.at(CF_federal_tax_frac,i)*self.cf.at(CF_fed_taxable_income_less_deductions,i)
            if i==1:
                self.cf.at(CF_fed_tax_savings, i) += itc_fed_amount + itc_fed_per
            self.cf.at(CF_sta_and_fed_tax_savings,i) = self.cf.at(CF_sta_tax_savings, i)+self.cf.at(CF_fed_tax_savings, i)
            self.cf.at(CF_after_tax_net_equity_cost_flow, i) =
                + (is_commercial ? self.cf.at(CF_deductible_expenses, i) : -self.cf.at(CF_operating_expenses,i) )
                - self.cf.at(CF_debt_payment_total, i)
                + self.cf.at(CF_pbi_total, i)
                + self.cf.at(CF_sta_and_fed_tax_savings,i)
            self.cf.at(CF_discounted_costs, i) = -self.cf.at(CF_after_tax_net_equity_cost_flow, i) - self.cf.at(CF_debt_payment_total, i)
            if is_commercial or is_mortgage:
                self.cf.at(CF_discounted_costs, i) += self.cf.at(CF_debt_payment_interest, i) * self.cf.at(CF_effective_tax_frac,i)
            self.cf.at(CF_discounted_costs, i) /= pow((1.0 + nom_discount_rate), (i - 1))
            self.cf.at(CF_discounted_savings, i) = ((is_commercial ? (1.0 - self.cf.at(CF_effective_tax_frac, i)) : 1.0)*self.cf.at(CF_energy_value, i)) / pow((1.0 + nom_discount_rate), (i - 1)) + ((is_commercial ? (1.0 - self.cf.at(CF_effective_tax_frac, i)) : 1.0)*self.cf.at(CF_thermal_value, i)) / pow((1.0 + nom_discount_rate), (i - 1))
            self.cf.at(CF_discounted_payback, i) = self.cf.at(CF_discounted_savings, i) - self.cf.at(CF_discounted_costs, i)
            self.cf.at(CF_discounted_cumulative_payback, i) = self.cf.at(CF_discounted_cumulative_payback, i - 1) + self.cf.at(CF_discounted_payback, i)
            self.cf.at(CF_after_tax_cash_flow,i) = 
                self.cf.at(CF_after_tax_net_equity_cost_flow, i)
                + ((is_commercial ? (1.0 - self.cf.at(CF_effective_tax_frac, i)) : 1.0)*self.cf.at(CF_energy_value, i))
                + ((is_commercial ? (1.0 - self.cf.at(CF_effective_tax_frac, i)) : 1.0)*self.cf.at(CF_thermal_value, i))
            if is_commercial or is_mortgage:
                self.cf.at(CF_payback_with_expenses,i) = self.cf.at(CF_after_tax_cash_flow,i) + self.cf.at(CF_debt_payment_interest, i) * (1 - self.cf.at(CF_effective_tax_frac, i)) + self.cf.at(CF_debt_payment_principal,i)
            else:
                self.cf.at(CF_payback_with_expenses,i) = self.cf.at(CF_after_tax_cash_flow,i) + self.cf.at(CF_debt_payment_interest,i) + self.cf.at(CF_debt_payment_principal,i)
            self.cf.at(CF_cumulative_payback_with_expenses,i) = self.cf.at(CF_cumulative_payback_with_expenses,i-1) + self.cf.at(CF_payback_with_expenses,i)
            if is_commercial or is_mortgage:
                self.cf.at(CF_payback_without_expenses,i) =
                    + self.cf.at(CF_after_tax_cash_flow,i)
                    + self.cf.at(CF_debt_payment_interest, i) * (1.0 - self.cf.at(CF_effective_tax_frac, i))
                    + self.cf.at(CF_debt_payment_principal,i)
                    - self.cf.at(CF_deductible_expenses,i)
                    + self.cf.at(CF_deductible_expenses, i) * self.cf.at(CF_effective_tax_frac, i)
            else:
                self.cf.at(CF_payback_without_expenses,i) =
                    + self.cf.at(CF_after_tax_cash_flow,i)
                    + self.cf.at(CF_debt_payment_interest,i)
                    + self.cf.at(CF_debt_payment_principal,i)
                    - self.cf.at(CF_deductible_expenses,i)
                    + self.cf.at(CF_deductible_expenses, i) * self.cf.at(CF_effective_tax_frac, i)
            self.cf.at(CF_cumulative_payback_without_expenses,i) =
                + self.cf.at(CF_cumulative_payback_without_expenses,i-1)
                + self.cf.at(CF_payback_without_expenses,i)
        var npv_energy_real: Float64 = self.npv( CF_energy_net, nyears, real_discount_rate )
        var lcoe_real: Float64 = -( self.cf.at(CF_after_tax_net_equity_cost_flow,0) + self.npv(CF_after_tax_net_equity_cost_flow, nyears, nom_discount_rate) ) * 100
        if npv_energy_real == 0.0:
            lcoe_real = Float64.nan
        else:
            lcoe_real /= npv_energy_real
        var npv_energy_nom: Float64 = self.npv( CF_energy_net, nyears, nom_discount_rate )
        var lcoe_nom: Float64 = -( self.cf.at(CF_after_tax_net_equity_cost_flow,0) + self.npv(CF_after_tax_net_equity_cost_flow, nyears, nom_discount_rate) ) * 100
        if npv_energy_nom == 0.0:
            lcoe_nom = Float64.nan
        else:
            lcoe_nom /= npv_energy_nom
        var net_present_value: Float64 = self.cf.at(CF_after_tax_cash_flow, 0) + self.npv(CF_after_tax_cash_flow, nyears, nom_discount_rate )
        var payback: Float64 = self.compute_payback(CF_cumulative_payback_with_expenses, CF_payback_with_expenses, nyears)
        var discounted_payback: Float64 = self.compute_payback(CF_discounted_cumulative_payback, CF_discounted_payback, nyears)
        var npv_fed_ptc: Float64 = self.npv(CF_ptc_fed, nyears, nom_discount_rate)
        var npv_sta_ptc: Float64 = self.npv(CF_ptc_sta, nyears, nom_discount_rate)
        npv_fed_ptc /= (1.0 - self.cf.at(CF_effective_tax_frac,1))
        npv_sta_ptc /= (1.0 - self.cf.at(CF_effective_tax_frac, 1))
        var lcoptc_fed_nom: Float64 = 0.0
        if npv_energy_nom != 0:
            lcoptc_fed_nom = npv_fed_ptc / npv_energy_nom * 100.0
        var lcoptc_fed_real: Float64 = 0.0
        if npv_energy_real != 0:
            lcoptc_fed_real = npv_fed_ptc / npv_energy_real * 100.0
        var lcoptc_sta_nom: Float64 = 0.0
        if npv_energy_nom != 0:
            lcoptc_sta_nom = npv_sta_ptc / npv_energy_nom * 100.0
        var lcoptc_sta_real: Float64 = 0.0
        if npv_energy_real != 0:
            lcoptc_sta_real = npv_sta_ptc / npv_energy_real * 100.0
        self.assign("lcoptc_fed_nom", var_data(ssc_number_t(lcoptc_fed_nom)))
        self.assign("lcoptc_fed_real", var_data(ssc_number_t(lcoptc_fed_real)))
        self.assign("lcoptc_sta_nom", var_data(ssc_number_t(lcoptc_sta_nom)))
        self.assign("lcoptc_sta_real", var_data(ssc_number_t(lcoptc_sta_real)))
        var wacc: Float64 = 0.0
        wacc = (1.0 - debt_frac)*nom_discount_rate + debt_frac*loan_rate*(1.0 - self.cf.at(CF_effective_tax_frac, 1))
        wacc *= 100.0
        self.assign("wacc", var_data(ssc_number_t(wacc)))
        self.assign("effective_tax_rate", var_data(ssc_number_t(self.cf.at(CF_effective_tax_frac, 1)*100.0)))
        var ub_w_sys: Pointer[ssc_number_t] = 0
        ub_w_sys = self.as_array("elec_cost_with_system", &count)
        if count != (nyears+1):
            throw exec_error("third party ownership", util.format("utility bill with system input wrong length (%d) should be (%d)", count, nyears+1))
        var ub_wo_sys: Pointer[ssc_number_t] = 0
        ub_wo_sys = self.as_array("elec_cost_without_system", &count)
        if count != (nyears+1):
            throw exec_error("third party ownership", util.format("utility bill without system input wrong length (%d) should be (%d)", count, nyears+1))
        for i in range(0, count):
            self.cf.at(CF_nte, i) = Float64(ub_wo_sys[i] - ub_w_sys[i]) * 100.0
        var lnte_real: Float64 = self.npv( CF_nte, nyears, nom_discount_rate )
        for i in range(0, count):
            if self.cf.at(CF_energy_net,i) > 0:
                self.cf.at(CF_nte,i) /= self.cf.at(CF_energy_net,i)
        var lnte_nom: Float64 = lnte_real
        if npv_energy_real == 0.0:
            lnte_real = Float64.nan
        else:
            lnte_real /= npv_energy_real
        if npv_energy_nom == 0.0:
            lnte_nom = Float64.nan
        else:
            lnte_nom /= npv_energy_nom
        self.assign( "lnte_real", var_data(ssc_number_t(lnte_real)) )
        self.assign( "lnte_nom", var_data(ssc_number_t(lnte_nom)) )
        self.save_cf(CF_nte, nyears, "cf_nte")
        self.assign( "year1_nte", var_data(ssc_number_t(self.cf.at(CF_nte,1))) )
        self.assign( "cf_length", var_data(ssc_number_t(nyears+1)) )
        self.assign("payback", var_data(ssc_number_t(payback)))
        self.assign("discounted_payback", var_data(ssc_number_t(discounted_payback)))
        self.assign("lcoe_real", var_data(ssc_number_t(lcoe_real)))
        self.assign( "lcoe_nom", var_data(ssc_number_t(lcoe_nom)) )
        self.assign( "npv",  var_data(ssc_number_t(net_present_value)) )
        self.assign( "depr_basis_fed", var_data(ssc_number_t(federal_depr_basis)))
        self.assign( "depr_basis_sta", var_data(ssc_number_t(state_depr_basis)))
        self.assign( "discount_nominal", var_data(ssc_number_t(nom_discount_rate*100.0)))
        self.assign( "adjusted_installed_cost", var_data(ssc_number_t(adjusted_installed_cost)))
        self.assign( "first_cost", var_data(ssc_number_t(first_cost)))
        self.assign( "total_cost", var_data(ssc_number_t(total_cost)))
        self.assign( "loan_amount", var_data(ssc_number_t(loan_amount)))
        self.save_cf( CF_energy_net, nyears, "cf_energy_net" )
        self.save_cf(CF_energy_value, nyears, "cf_energy_value")
        self.save_cf(CF_thermal_value, nyears, "cf_thermal_value")
        for i in range(1, nyears+1):
            var rr: Float64 = 1.0
            if nom_discount_rate != -1.0:
                rr = 1.0/(1.0+nom_discount_rate)
            var result: Float64 = 0
            for j in range(nyears, i-1, -1):
                result = rr * result + self.cf.at(CF_energy_value, j) + self.cf.at(CF_thermal_value, j)
            self.cf.at(CF_value_added,i) = result*rr + self.cf.at(CF_net_salvage_value,i)
        self.save_cf( CF_value