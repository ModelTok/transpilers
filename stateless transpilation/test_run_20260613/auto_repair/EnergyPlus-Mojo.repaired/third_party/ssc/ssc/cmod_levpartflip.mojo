const SSC_INPUT: Int = 0
const SSC_INOUT: Int = 1
const SSC_OUTPUT: Int = 2
const SSC_NUMBER: Int = 0
const SSC_ARRAY: Int = 1
const SSC_MATRIX: Int = 2

struct var_info:
    var vartype: Int
    var datatype: Int
    var name: String
    var label: String
    var units: String
    var meta: String
    var group: String
    var required_if: String
    var constraints: String
