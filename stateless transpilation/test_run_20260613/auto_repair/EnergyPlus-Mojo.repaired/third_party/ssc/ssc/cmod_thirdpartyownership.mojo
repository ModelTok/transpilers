from core import *
from lib_financial import *
from common_financial import *
from util import matrix_t, nday, format
from math import pow, nan

using libfin

static var vtab_thirdpartyownership: StaticArray[var_info, 27] = [
/*   VARTYPE           DATATYPE          NAME                        LABEL                                  UNITS         META                      GROUP            REQUIRED_IF                 CONSTRAINTS                      UI_HINTS*/
	{ SSC_INPUT, SSC_NUMBER, "analysis_period", "Analyis period", "years", "", "Financials", "?=30", "INTEGER,MIN=0,MAX=50", "" },
	{ SSC_INPUT, SSC_NUMBER, "real_discount_rate", "Real discount rate", "%", "", "Financials", "*", "MIN=-99", "" },
	{ SSC_INPUT, SSC_NUMBER, "inflation_rate", "Inflation rate", "%", "", "Financials", "*", "MIN=-99", "" },
	{ SSC_INPUT, SSC_NUMBER, "lease_or_ppa", "Lease or PPA agreement", "0/1", "0=lease,1=ppa", "thirdpartyownership", "?=0", "INTEGER,MIN=0,MAX=1", "" },
	{ SSC_INPUT,        SSC_ARRAY,       "annual_energy_value",             "Energy value",                       "$",            "",                      "thirdpartyownership",      "*",                       "",                                         "" },
	{ SSC_INPUT, SSC_ARRAY, "gen", "Power generated by renewable resource", "kW", "", "", "*", "", "" },
	{ SSC_INPUT, SSC_ARRAY, "degradation", "Annual degradation", "%", "", "AnnualOutput", "*", "", "" },
	{ SSC_INPUT, SSC_NUMBER, "system_use_lifetime_output", "Lifetime hourly system outputs", "0/1", "0=hourly first year,1=hourly lifetime", "AnnualOutput", "*", "INTEGER,MIN=0", "" },
	{ SSC_INPUT, SSC_NUMBER, "lease_price", "Monthly lease price", "$/month", "", "Cash Flow", "lease_or_ppa=0", "", "" },
	{ SSC_INPUT, SSC_NUMBER, "lease_escalation", "Monthly lease escalation", "%/year", "", "Cash Flow", "lease_or_ppa=0", "", "" },
	{ SSC_INPUT, SSC_NUMBER, "ppa_price", "Monthly lease price", "$/month", "", "Cash Flow", "lease_or_ppa=1", "", "" },
	{ SSC_INPUT, SSC_NUMBER, "ppa_escalation", "Monthly lease escalation", "%/year", "", "Cash Flow", "lease_or_ppa=1", "", "" },
	/* financial outputs */
	{ SSC_OUTPUT,        SSC_NUMBER,     "cf_length",                "Agreement period",      "",             "",                      "Financial Metrics",      "*",                       "INTEGER",                                  "" },
	{ SSC_OUTPUT,        SSC_NUMBER,     "npv",                      "Net present value",				   "$",            "",                      "Financial Metrics",      "*",                       "",                                         "" },
	{ SSC_OUTPUT,        SSC_ARRAY,      "cf_energy_net",      "Energy",                  "kWh",            "",                      "Cash Flow",      "*",                     "LENGTH_EQUAL=cf_length",                "" },
	{ SSC_OUTPUT,        SSC_ARRAY,      "cf_agreement_cost",      "Agreement cost",                  "$",            "",                      "Cash Flow",      "*",                     "LENGTH_EQUAL=cf_length",                "" },
	{ SSC_OUTPUT,        SSC_ARRAY,      "cf_after_tax_net_equity_cost_flow",        "After-tax annual costs",           "$",            "",                      "Cash Flow",      "*",                     "LENGTH_EQUAL=cf_length",                "" },
	{ SSC_OUTPUT,        SSC_ARRAY,      "cf_after_tax_cash_flow",                   "After-tax cash flow",                      "$",            "",                      "Cash Flow",      "*",                     "LENGTH_EQUAL=cf_length",                "" },
	{ SSC_OUTPUT,        SSC_ARRAY,      "cf_payback_with_expenses",                 "Simple payback with expenses",                    "$",            "",                      "Cash Flow",      "*",                     "LENGTH_EQUAL=cf_length",                "" },
	{ SSC_OUTPUT,        SSC_ARRAY,      "cf_cumulative_payback_with_expenses",      "Cumulative simple payback with expenses",         "$",            "",                      "Cash Flow",      "*",                     "LENGTH_EQUAL=cf_length",                "" },
	{ SSC_INPUT,        SSC_ARRAY,       "elec_cost_with_system",             "Energy value",                       "$",            "",                      "Electricity Cost",      "*",                       "",                                         "" },
	{ SSC_INPUT,        SSC_ARRAY,       "elec_cost_without_system",             "Energy value",                       "$",            "",                      "Electricity Cost",      "*",                       "",                                         "" },
	{ SSC_OUTPUT,        SSC_ARRAY,      "cf_nte",      "Host indifference point by year",         "cents/kWh",            "",                      "Cash Flow",      "*",                     "LENGTH_EQUAL=cf_length",                "" },
	{ SSC_OUTPUT,        SSC_NUMBER,     "year1_nte",                "Host indifference point in Year 1",                          "cents/kWh",    "",                      "Financial Metrics",      "*",                       "",                                         "" },
	{ SSC_OUTPUT,        SSC_NUMBER,     "lnte_real",                "Host indifference point nominal levelized value",                          "cents/kWh",    "",                      "Financial Metrics",      "*",                       "",                                         "" },
	{ SSC_OUTPUT,        SSC_NUMBER,     "lnte_nom",                 "Host indifference point real levelized value",                       "cents/kWh",    "",                      "Financial Metrics",      "*",                       "",                                         "" },
	var_info_invalid
]

extern var_info vtab_depreciation[]

enum CF_:
	CF_degradation
	CF_energy_net
	CF_energy_value
	CF_agreement_cost
	CF_after_tax_net_equity_cost_flow
	CF_after_tax_cash_flow
	CF_payback_with_expenses
	CF_cumulative_payback_with_expenses
	CF_nte
	CF_max

struct cm_thirdpartyownership(compute_module):
	private:
		var cf: matrix_t[Float64]
		var hourly_energy_calcs: hourly_energy_calculation

	def __init__(inout self):
		self.add_var_info(vtab_depreciation)
		self.add_var_info(vtab_thirdpartyownership)

	def exec(inout self):
		var i: Int
		var nyears: Int = self.as_unsigned_long("analysis_period")
		self.cf.resize_fill(CF_max, nyears+1, 0.0)
		var count: Int = 0
		var arrp: Pointer[ssc_number_t] = None
		if self.as_integer("system_use_lifetime_output") == 1:
			for i in range(1, nyears+1):
				self.cf[CF_degradation][i-1] = 1.0
		else:
			var count_degrad: Int = 0
			var degrad: Pointer[ssc_number_t] = None
			degrad = self.as_array("degradation", &count_degrad)
			if count_degrad == 1:
				for i in range(1, nyears+1):
					self.cf[CF_degradation][i-1] = (1.0 - degrad[0] / 100.0) ** (i - 1)
			elif count_degrad > 0:
				for i in range(0, min(nyears, count_degrad)):
					self.cf[CF_degradation][i] = (1.0 - degrad[i] / 100.0)
		self.hourly_energy_calcs.calculate(self)
		if self.as_integer("system_use_lifetime_output") == 0:
			var first_year_energy: Float64 = 0.0
			for i in range(0, 8760):
				first_year_energy += self.hourly_energy_calcs.hourly_energy()[i]
			for y in range(1, nyears+1):
				self.cf[CF_energy_net][y-1] = first_year_energy * self.cf[CF_degradation][y-1]
		else:
			for y in range(1, nyears+1):
				self.cf[CF_energy_net][y-1] = 0
				var i: Int = 0
				for m in range(0, 12):
					for d in range(0, nday[m]):
						for h in range(0, 24):
							if i < 8760:
								self.cf[CF_energy_net][y-1] += self.hourly_energy_calcs.hourly_energy()[(y - 1) * 8760 + i] * self.cf[CF_degradation][y-1]
								i += 1
		arrp = self.as_array("annual_energy_value", &count)
		if count != nyears+1:
			raise exec_error("third party ownership", format("energy value input wrong length (%d) should be (%d)", count, nyears+1))
		for i in range(0, count):
			self.cf[CF_energy_value][i] = Float64(arrp[i])
		var inflation_rate: Float64 = self.as_double("inflation_rate") * 0.01
		var real_discount_rate: Float64 = self.as_double("real_discount_rate") * 0.01
		var nom_discount_rate: Float64 = (1.0 + real_discount_rate) * (1.0 + inflation_rate) - 1.0
		var monthly_lease: Bool = (self.as_integer("lease_or_ppa") == 0)
		var annual_price: Float64 = 0
		var annual_esc: Float64 = 0
		if monthly_lease:
			annual_price = self.as_double("lease_price") * 12.0
			annual_esc = self.as_double("lease_escalation") / 100.0
			for i in range(1, nyears+1):
				self.cf[CF_agreement_cost][i-1] = annual_price * (1 + annual_esc) ** (i-1)
		else:
			annual_price = self.as_double("ppa_price")
			annual_esc = self.as_double("ppa_escalation") / 100.0
			for i in range(1, nyears+1):
				self.cf[CF_agreement_cost][i-1] = annual_price * self.cf[CF_energy_net][i-1] * (1 + annual_esc) ** (i-1)
		for i in range(1, nyears+1):
			self.cf[CF_after_tax_net_equity_cost_flow][i-1] = -self.cf[CF_agreement_cost][i-1]
			self.cf[CF_after_tax_cash_flow][i-1] = self.cf[CF_after_tax_net_equity_cost_flow][i-1] + self.cf[CF_energy_value][i-1]
			self.cf[CF_payback_with_expenses][i-1] = self.cf[CF_after_tax_cash_flow][i-1]
			self.cf[CF_cumulative_payback_with_expenses][i-1] = self.cf[CF_cumulative_payback_with_expenses][i-2] + self.cf[CF_payback_with_expenses][i-1]
		var npv_energy_real: Float64 = self.npv(CF_energy_net, nyears, real_discount_rate)
		var lcoe_real: Float64 = -(self.cf[CF_after_tax_net_equity_cost_flow][0] + self.npv(CF_after_tax_net_equity_cost_flow, nyears, nom_discount_rate)) * 100
		if npv_energy_real == 0.0:
			lcoe_real = nan
		else:
			lcoe_real /= npv_energy_real
		var npv_energy_nom: Float64 = self.npv(CF_energy_net, nyears, nom_discount_rate)
		var lcoe_nom: Float64 = -(self.cf[CF_after_tax_net_equity_cost_flow][0] + self.npv(CF_after_tax_net_equity_cost_flow, nyears, nom_discount_rate)) * 100
		if npv_energy_nom == 0.0:
			lcoe_nom = nan
		else:
			lcoe_nom /= npv_energy_nom
		var ub_w_sys: Pointer[ssc_number_t] = None
		ub_w_sys = self.as_array("elec_cost_with_system", &count)
		if count != nyears+1:
			raise exec_error("third party ownership", format("utility bill with system input wrong length (%d) should be (%d)", count, nyears+1))
		var ub_wo_sys: Pointer[ssc_number_t] = None
		ub_wo_sys = self.as_array("elec_cost_without_system", &count)
		if count != nyears+1:
			raise exec_error("third party ownership", format("utility bill without system input wrong length (%d) should be (%d)", count, nyears+1))
		for i in range(0, count):
			self.cf[CF_nte][i] = Float64(ub_wo_sys[i] - ub_w_sys[i]) * 100.0  # $ to cents
		var lnte_real: Float64 = self.npv(CF_nte, nyears, nom_discount_rate)
		for i in range(0, count):
			if self.cf[CF_energy_net][i] > 0:
				self.cf[CF_nte][i] /= self.cf[CF_energy_net][i]
		var lnte_nom: Float64 = lnte_real
		if npv_energy_real == 0.0:
			lnte_real = nan
		else:
			lnte_real /= npv_energy_real
		if npv_energy_nom == 0.0:
			lnte_nom = nan
		else:
			lnte_nom /= npv_energy_nom
		self.assign("lnte_real", var_data(ssc_number_t(lnte_real)))
		self.assign("lnte_nom", var_data(ssc_number_t(lnte_nom)))
		self.save_cf(CF_nte, nyears, "cf_nte")
		self.assign("year1_nte", var_data(ssc_number_t(self.cf[CF_nte][0])))
		var net_present_value: Float64 = self.cf[CF_after_tax_cash_flow][0] + self.npv(CF_after_tax_cash_flow, nyears, nom_discount_rate)
		self.assign("cf_length", var_data(ssc_number_t(nyears+1)))
		self.assign("npv", var_data(ssc_number_t(net_present_value)))
		self.assign("discount_nominal", var_data(ssc_number_t(nom_discount_rate*100.0)))
		self.save_cf(CF_agreement_cost, nyears, "cf_agreement_cost")
		self.save_cf(CF_energy_net, nyears, "cf_energy_net")
		self.save_cf(CF_after_tax_net_equity_cost_flow, nyears, "cf_after_tax_net_equity_cost_flow")
		self.save_cf(CF_after_tax_cash_flow, nyears, "cf_after_tax_cash_flow")
		self.save_cf(CF_payback_with_expenses, nyears, "cf_payback_with_expenses")
		self.save_cf(CF_cumulative_payback_with_expenses, nyears, "cf_cumulative_payback_with_expenses")

	/* These functions can be placed in common financial library with matrix and constants passed? */
	def save_cf(inout self, cf_line: Int, nyears: Int, name: String):
		var arrp: Pointer[ssc_number_t] = self.allocate(name, nyears+1)
		for i in range(0, nyears+1):
			arrp[i] = ssc_number_t(self.cf[cf_line][i])

	def npv(self, cf_line: Int, nyears: Int, rate: Float64) -> Float64:
		if rate <= -1.0:
			raise general_error("cannot calculate NPV with discount rate less or equal to -1.0")
		var rr: Float64 = 1/(1+rate)
		var result: Float64 = 0
		for i in range(nyears, 0, -1):
			result = rr * result + self.cf[cf_line][i-1]
		return result * rr

	def min(self, a: Float64, b: Float64) -> Float64:
		return a if a < b else b

# DEFINE_MODULE_ENTRY( thirdpartyownership, "Residential/Commercial 3rd Party Ownership Finance model.", 1 );
def thirdpartyownership() -> compute_module:
    return cm_thirdpartyownership()