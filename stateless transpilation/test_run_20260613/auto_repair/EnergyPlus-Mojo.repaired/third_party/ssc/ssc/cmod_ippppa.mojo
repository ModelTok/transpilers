# extern var_info arrays
from common_financial import vtab_standard_financial, vtab_standard_loan, vtab_oandm, vtab_depreciation, vtab_tax_credits, vtab_payment_incentives

enum CF:
    energy_net = 0
    energy_value = 1
    degradation = 2
    ppa_price = 3
    energy_price = 4
    om_fixed_expense = 5
    om_production_expense = 6
    om_capacity_expense = 7
    om_fuel_expense = 8
    om_opt_fuel_2_expense = 9
    om_opt_fuel_1_expense = 10
    federal_tax_frac = 11
    state_tax_frac = 12
    effective_tax_frac = 13
    property_tax_assessed_value = 14
    property_tax_expense = 15
    insurance_expense = 16
    operating_expenses = 17
    net_salvage_value = 18
    deductible_expenses = 19
    debt_balance = 20
    debt_payment_interest = 21
    debt_payment_principal = 22
    debt_payment_total = 23
    pbi_fed = 24
    pbi_sta = 25
    pbi_uti = 26
    pbi_oth = 27
    pbi_total = 28
    ptc_fed = 29
    ptc_sta = 30
    ptc_total = 31
    sta_depr_sched = 32
    sta_depreciation = 33
    sta_incentive_income_less_deductions = 34
    sta_taxable_income_less_deductions = 35
    sta_tax_savings = 36
    fed_depr_sched = 37
    fed_depreciation = 38
    fed_incentive_income_less_deductions = 39
    fed_taxable_income_less_deductions = 40
    fed_tax_savings = 41
    sta_and_fed_tax_savings = 42
    after_tax_net_equity_cash_flow = 43
    after_tax_net_equity_cost_flow = 44
    after_tax_cash_flow = 45
    revenue_monthly_firstyear = 46
    energy_net_monthly_firstyear = 47
    recapitalization = 48
    recapitalization_boolean = 49
    operating_income = 50
    sta_income_taxes = 51
    fed_income_taxes = 52
    pretax_dscr = 53
    max = 54

class cm_ippppa(compute_module):
    var cf: DynamicMatrix[float64]
    var ibi_fed_amount: float64
    var ibi_sta_amount: float64
    var ibi_uti_amount: float64
    var ibi_oth_amount: float64
    var ibi_fed_per: float64
    var ibi_sta_per: float64
    var ibi_uti_per: float64
    var ibi_oth_per: float64
    var ibi_total: float64
    var cbi_fed_amount: float64
    var cbi_sta_amount: float64
    var cbi_uti_amount: float64
    var cbi_oth_amount: float64
    var cbi_total: float64
    var itc_sta_total: float64
    var itc_sta_amount: float64
    var itc_sta_per: float64
    var itc_fed_total: float64
    var itc_fed_amount: float64
    var itc_fed_per: float64
    var ppa: float64
    var ppa_escalation: float64
    var year1_fuel_use: float64
    var inflation_rate: float64
    var property_tax: float64
    var property_tax_decline_percentage: float64
    var insurance_rate: float64
    var salvage_frac: float64
    var real_discount_rate: float64
    var nom_discount_rate: float64
    var min_dscr_target: float64
    var min_irr_target: float64
    var aftertax_irr: float64
    var min_after_tax_cash_flow: float64
    var min_dscr: float64
    var loan_amount: float64
    var loan_rate: float64
    var first_cost: float64
    var debt_frac: float64
    var adjusted_installed_cost: float64
    var ppa_soln_tolerance: float64
    var lcoe_real: float64
    var net_present_value: float64
    var min_dscr_required: Int
    var positive_cashflow_required: Int
    var ppa_soln_mode: Int
    var nyears: Int
    var loan_term: Int
    var is_commercialppa: Bool
    var weighting_factor: float64
    var m_disp_calcs: dispatch_calculations
    var hourly_energy_calcs: hourly_energy_calculation

    def __init__(inout self):
        self.add_var_info(vtab_standard_financial)
        self.add_var_info(vtab_standard_loan)
        self.add_var_info(vtab_oandm)
        self.add_var_info(vtab_depreciation)
        self.add_var_info(vtab_tax_credits)
        self.add_var_info(vtab_payment_incentives)
        self.add_var_info(vtab_ippppa)

    def exec(self):
        var i: Int = 0
        self.is_commercialppa = (self.as_integer("market") == 1)
        self.ppa_soln_mode = self.as_integer("soln_mode") # 0 for iterative, 1 for specified
        self.ppa_soln_tolerance = self.as_double("ppa_soln_tolerance")
        self.weighting_factor = 1.0 # binary search algorithm - updated in check constraints.
        self.nyears = self.as_integer("analysis_period")
        self.cf.resize_fill(CF.max.to_int(), self.nyears + 1, 0.0)
        var nameplate: float64 = self.as_double("system_capacity") # kW
        var first_year_energy: float64 = 0.0
        if self.as_integer("system_use_lifetime_output") == 1:
            for i in range(1, self.nyears + 1):
                self.cf.at(CF.degradation.to_int(), i) = 1.0
        else:
            var count_degrad: Int = 0
            var degrad = self.as_array("degradation", count_degrad)
            if count_degrad == 1:
                for i in range(1, self.nyears + 1):
                    self.cf.at(CF.degradation.to_int(), i) = pow((1.0 - degrad[0] / 100.0), i - 1)
            elif count_degrad > 0:
                for i in range(0, min(self.nyears, count_degrad)):
                    self.cf.at(CF.degradation.to_int(), i + 1) = (1.0 - degrad[i] / 100.0)

        self.hourly_energy_calcs.calculate(self)

        if self.as_integer("system_use_lifetime_output") == 1:
            for y in range(1, self.nyears + 1):
                for h in range(0, 8760):
                    self.cf.at(CF.energy_net.to_int(), y) += self.hourly_energy_calcs.hourly_energy()[(y - 1) * 8760 + h] * self.cf.at(CF.degradation.to_int(), y)
        else:
            for i in range(0, 8760):
                first_year_energy += self.hourly_energy_calcs.hourly_energy()[i] # sum up hourly kWh to get total annual kWh first year production includes first year curtailment, availability
            self.cf.at(CF.energy_net.to_int(), 1) = first_year_energy
            for i in range(1, self.nyears + 1):
                self.cf.at(CF.energy_net.to_int(), i) = first_year_energy * self.cf.at(CF.degradation.to_int(), i)

        first_year_energy = self.cf.at(CF.energy_net.to_int(), 1)

        if not self.is_commercialppa:
            var degrade_cf = List[float64]()
            for i in range(0, self.nyears + 1):
                degrade_cf.append(self.cf.at(CF.degradation.to_int(), i))
            self.m_disp_calcs.init(self, degrade_cf, self.hourly_energy_calcs.hourly_energy())

        for i in range(1, self.nyears + 1):
            self.cf.at(CF.om_production_expense.to_int(), i) *= self.cf.at(CF.energy_net.to_int(), i)
            self.cf.at(CF.om_capacity_expense.to_int(), i) *= nameplate

        if self.ppa_soln_mode == 0:
            self.ppa_escalation = 0.01 * self.as_double("ppa_escalation")
        else:
            self.ppa_escalation = 0.01 * self.as_double("bid_price_esc")
        self.escal_or_annual(CF.ppa_price.to_int(), self.nyears, "bid_price", self.ppa_escalation, 100.0, False)
        self.ppa = self.cf(CF.ppa_price.to_int(), 1) # assignment in metrics table
        self.year1_fuel_use = self.as_double("annual_fuel_usage") # kWht
        self.inflation_rate = self.as_double("inflation_rate") * 0.01
        self.property_tax = self.as_double("property_tax_rate") * 0.01
        self.property_tax_decline_percentage = self.as_double("prop_tax_assessed_decline")
        self.insurance_rate = self.as_double("insurance_rate") * 0.01
        self.salvage_frac = self.as_double("salvage_percentage") * 0.01
        var count: Int
        var arrp = self.as_array("federal_tax_rate", count)
        if count > 0:
            if count == 1: # single value input
                for i in range(0, self.nyears):
                    self.cf.at(CF.federal_tax_frac.to_int(), i + 1) = arrp[0] * 0.01
            else: # schedule
                for i in range(0, min(self.nyears, count)):
                    self.cf.at(CF.federal_tax_frac.to_int(), i + 1) = arrp[i] * 0.01
        arrp = self.as_array("state_tax_rate", count)
        if count > 0:
            if count == 1: # single value input
                for i in range(0, self.nyears):
                    self.cf.at(CF.state_tax_frac.to_int(), i + 1) = arrp[0] * 0.01
            else: # schedule
                for i in range(0, min(self.nyears, count)):
                    self.cf.at(CF.state_tax_frac.to_int(), i + 1) = arrp[i] * 0.01
        for i in range(0, self.nyears + 1):
            self.cf.at(CF.effective_tax_frac.to_int(), i) = self.cf.at(CF.state_tax_frac.to_int(), i) + (1.0 - self.cf.at(CF.state_tax_frac.to_int(), i)) * self.cf.at(CF.federal_tax_frac.to_int(), i)
        self.real_discount_rate = self.as_double("real_discount_rate") * 0.01
        self.nom_discount_rate = (1.0 + self.real_discount_rate) * (1.0 + self.inflation_rate) - 1.0
        self.min_dscr_target = self.as