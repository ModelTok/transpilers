class cm_trough_physical(compute_module):
    def __init__(self):
        add_var_info(self, _cm_vtab_trough_physical)
        add_var_info(self, vtab_adjustment_factors)

    def exec(self):
        var weather_reader = C_csp_weatherreader()
        weather_reader.m_weather_data_provider = __import__("weatherfile")(as_string(self, "file_name"))
        weather_reader.m_filename = as_string(self, "file_name")
        weather_reader.m_trackmode = 0
        weather_reader.m_tilt = 0.0
        weather_reader.m_azimuth = 0.0
        weather_reader.init()
        if weather_reader.has_error():
            raise exec_error("trough_physical", weather_reader.get_error())
        var nhourssim = 8760.0  # [hr] Number of hours to simulate
        var sim_setup = C_csp_solver.S_sim_setup()
        sim_setup.m_sim_time_start = 0.0  # [s] starting first hour of year
        sim_setup.m_sim_time_end = nhourssim * 3600.0  # [s] full year simulation
        var steps_per_hour = 1  # [-]
        var n_wf_records = int(weather_reader.m