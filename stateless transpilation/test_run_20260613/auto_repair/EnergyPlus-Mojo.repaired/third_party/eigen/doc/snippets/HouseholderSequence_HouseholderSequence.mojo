from Eigen import *

Matrix3d v = Matrix3d.Random()
print("The matrix v is:")
print(v)
Vector3d v0 = Vector3d(1, v[1,0], v[2,0])
print("The first Householder vector is: v_0 = ", v0.transpose())
Vector3d v1 = Vector3d(0, 1, v[2,1])
print("The second Householder vector is: v_1 = ", v1.transpose())
Vector3d v2 = Vector3d(0, 0, 1)
print("The third Householder vector is: v_2 = ", v2.transpose())
Vector3d h = Vector3d.Random()
print("The Householder coefficients are: h = ", h.transpose())
Matrix3d H0 = Matrix3d.Identity() - h[0] * v0 * v0.adjoint()
print("The first Householder reflection is represented by H_0 = ")
print(H0)
Matrix3d H1 = Matrix3d.Identity() - h[1] * v1 * v1.adjoint()
print("The second Householder reflection is represented by H_1 = ")
print(H1)
Matrix3d H2 = Matrix3d.Identity() - h[2] * v2 * v2.adjoint()
print("The third Householder reflection is represented by H_2 = ")
print(H2)
print("Their product is H_0 H_1 H_2 = ")
print(H0 * H1 * H2)
HouseholderSequence[Matrix3d, Vector3d] hhSeq = HouseholderSequence[Matrix3d, Vector3d](v, h)
Matrix3d hhSeqAsMatrix = Matrix3d(hhSeq)
print("If we construct a HouseholderSequence from v and h")
print("and convert it to a matrix, we get:")
print(hhSeqAsMatrix)