from Eigen import MatrixXf, JacobiSVD, ComputeThinU, ComputeThinV, Vector3f

var m = MatrixXf.Random(3, 2)
print("Here is the matrix m:")
print(m)
var svd = JacobiSVD[MatrixXf](m, ComputeThinU | ComputeThinV)
print("Its singular values are:")
print(svd.singularValues())
print("Its left singular vectors are the columns of the thin U matrix:")
print(svd.matrixU())
print("Its right singular vectors are the columns of the thin V matrix:")
print(svd.matrixV())
var rhs = Vector3f(1, 0, 0)
print("Now consider this rhs vector:")
print(rhs)
print("A least-squares solution of m*x = rhs is:")
print(svd.solve(rhs))