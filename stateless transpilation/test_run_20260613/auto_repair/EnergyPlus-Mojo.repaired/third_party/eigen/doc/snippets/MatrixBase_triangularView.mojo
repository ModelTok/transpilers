var m = Matrix3i.Random()
print("Here is the matrix m:")
print(m)
print("Here is the upper-triangular matrix extracted from m:")
print(Matrix3i(m.triangularView[Eigen.Upper]()))
print("Here is the strictly-upper-triangular matrix extracted from m:")
print(Matrix3i(m.triangularView[Eigen.StrictlyUpper]()))
print("Here is the unit-lower-triangular matrix extracted from m:")
print(Matrix3i(m.triangularView[Eigen.UnitLower]()))