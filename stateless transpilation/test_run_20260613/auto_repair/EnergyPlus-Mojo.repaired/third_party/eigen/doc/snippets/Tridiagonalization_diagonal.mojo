from Eigen import MatrixXcd, MatrixXd, VectorXd, Tridiagonalization

var X = MatrixXcd.Random(4,4)
var A = X + X.adjoint()
print("Here is a random self-adjoint 4x4 matrix:")
print(A)
print()
var triOfA = Tridiagonalization[MatrixXcd](A)
var T: MatrixXd = triOfA.matrixT()
print("The tridiagonal matrix T is:")
print(T)
print()
print("We can also extract the diagonals of T directly ...")
var diag: VectorXd = triOfA.diagonal()
print("The diagonal is:")
print(diag)
var subdiag: VectorXd = triOfA.subDiagonal()
print("The subdiagonal is:")
print(subdiag)