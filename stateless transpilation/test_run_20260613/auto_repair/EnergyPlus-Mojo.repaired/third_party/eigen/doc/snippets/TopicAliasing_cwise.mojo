from Eigen import MatrixXf, ArrayXXf

def main():
    var mat = MatrixXf(2, 2)
    mat = MatrixXf([[1, 2], [4, 7]])
    print("Here is the matrix mat:")
    print(mat)
    print()
    mat = 2 * mat
    print("After 'mat = 2 * mat', mat =")
    print(mat)
    print()
    mat = mat - MatrixXf.Identity(2, 2)
    print("After the subtraction, it becomes")
    print(mat)
    print()
    var arr = ArrayXXf(mat)
    arr = arr.square()
    print("After squaring, it becomes")
    print(arr)
    print()
    mat = MatrixXf([[1, 2], [4, 7]])
    mat = (2 * mat - MatrixXf.Identity(2, 2)).array().square()
    print("Doing everything at once yields")
    print(mat)
    print()