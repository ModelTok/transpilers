from main import *
from memory import memset_zero
from math import isfinite, isinf, isnan
from complex import Complex
from random import random_si64

def check(b: Bool, ref: Bool):
    print(b, end="")
    if b == ref:
        print(" OK  ", end="")
    else:
        print(" BAD ", end="")

def check_inf_nan[T: DType](dryrun: Bool):
    alias T_scalar = SIMD[T, 1]
    var m = Matrix[T_scalar, Dynamic, 1](10)
    m.setRandom()
    m[3] = T_scalar(std.numeric_limits[T_scalar].quiet_NaN())
    if dryrun:
        print("isfinite(", m[3], ") = ", end="")
        check(isfinite(m[3]), False)
        print("  ; numext::isfinite = ", end="")
        check(numext.isfinite(m[3]), False)
        print()
        print("isinf(", m[3], ")    = ", end="")
        check(isinf(m[3]), False)
        print("  ; numext::isinf    = ", end="")
        check(numext.isinf(m[3]), False)
        print()
        print("isnan(", m[3], ")    = ", end="")
        check(isnan(m[3]), True)
        print("  ; numext::isnan    = ", end="")
        check(numext.isnan(m[3]), True)
        print()
        print("allFinite: ", end="")
        check(m.allFinite(), 0)
        print()
        print("hasNaN:    ", end="")
        check(m.hasNaN(), 1)
        print()
        print()
    else:
        VERIFY(not numext.isfinite(m[3]))
        VERIFY(not numext.isinf(m[3]))
        VERIFY(numext.isnan(m[3]))
        VERIFY(not m.allFinite())
        VERIFY(m.hasNaN())
    var hidden_zero = T_scalar(std.numeric_limits[T_scalar].min()) * T_scalar(std.numeric_limits[T_scalar].min())
    m[4] /= hidden_zero
    if dryrun:
        print("isfinite(", m[4], ") = ", end="")
        check(isfinite(m[4]), False)
        print("  ; numext::isfinite = ", end="")
        check(numext.isfinite(m[4]), False)
        print()
        print("isinf(", m[4], ")    = ", end="")
        check(isinf(m[4]), True)
        print("  ; numext::isinf    = ", end="")
        check(numext.isinf(m[4]), True)
        print()
        print("isnan(", m[4], ")    = ", end="")
        check(isnan(m[4]), False)
        print("  ; numext::isnan    = ", end="")
        check(numext.isnan(m[4]), False)
        print()
        print("allFinite: ", end="")
        check(m.allFinite(), 0)
        print()
        print("hasNaN:    ", end="")
        check(m.hasNaN(), 1)
        print()
        print()
    else:
        VERIFY(not numext.isfinite(m[4]))
        VERIFY(numext.isinf(m[4]))
        VERIFY(not numext.isnan(m[4]))
        VERIFY(not m.allFinite())
        VERIFY(m.hasNaN())
    m[3] = 0
    if dryrun:
        print("isfinite(", m[3], ") = ", end="")
        check(isfinite(m[3]), True)
        print("  ; numext::isfinite = ", end="")
        check(numext.isfinite(m[3]), True)
        print()
        print("isinf(", m[3], ")    = ", end="")
        check(isinf(m[3]), False)
        print("  ; numext::isinf    = ", end="")
        check(numext.isinf(m[3]), False)
        print()
        print("isnan(", m[3], ")    = ", end="")
        check(isnan(m[3]), False)
        print("  ; numext::isnan    = ", end="")
        check(numext.isnan(m[3]), False)
        print()
        print("allFinite: ", end="")
        check(m.allFinite(), 0)
        print()
        print("hasNaN:    ", end="")
        check(m.hasNaN(), 0)
        print()
        print()
        print()
    else:
        VERIFY(numext.isfinite(m[3]))
        VERIFY(not numext.isinf(m[3]))
        VERIFY(not numext.isnan(m[3]))
        VERIFY(not m.allFinite())
        VERIFY(not m.hasNaN())

def test_fastmath():
    print("*** float *** \n")
    check_inf_nan[DType.float32](True)
    print("*** double ***\n")
    check_inf_nan[DType.float64](True)
    print("*** long double *** \n")
    check_inf_nan[DType.float64](True)
    check_inf_nan[DType.float32](False)
    check_inf_nan[DType.float64](False)
    check_inf_nan[DType.float64](False)