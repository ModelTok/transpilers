from ...eigen import Matrix, Vector, NumTraits, internal, test_precision, VERIFY, CALL_SUBTEST, g_repeat, EIGEN_TEST_MAX_SIZE, Eigen, Dynamic, Index, Matrix3d, MatrixXcf, MatrixXcd, RowMajor

def trmv[MatrixType: AnyType](m: MatrixType):
    alias Scalar = MatrixType.Scalar
    alias RealScalar = NumTraits[Scalar].Real
    alias VectorType = Matrix[Scalar, MatrixType.RowsAtCompileTime, 1]
    var largerEps: RealScalar = 10 * test_precision[RealScalar]()
    var rows: Index = m.rows()
    var cols: Index = m.cols()
    var m1: MatrixType = MatrixType.Random(rows, cols)
    var m3: MatrixType = MatrixType(rows, cols)
    var v1: VectorType = VectorType.Random(rows)
    var s1: Scalar = internal.random[Scalar]()
    m1 = MatrixType.Random(rows, cols)
    m3 = m1.triangularView[Eigen.Lower]()
    VERIFY((m3 * v1).isApprox(m1.triangularView[Eigen.Lower]() * v1, largerEps))
    m3 = m1.triangularView[Eigen.Upper]()
    VERIFY((m3 * v1).isApprox(m1.triangularView[Eigen.Upper]() * v1, largerEps))
    m3 = m1.triangularView[Eigen.UnitLower]()
    VERIFY((m3 * v1).isApprox(m1.triangularView[Eigen.UnitLower]() * v1, largerEps))
    m3 = m1.triangularView[Eigen.UnitUpper]()
    VERIFY((m3 * v1).isApprox(m1.triangularView[Eigen.UnitUpper]() * v1, largerEps))
    m3 = m1.triangularView[Eigen.Lower]()
    VERIFY(((s1*m3).conjugate() * v1).isApprox((s1*m1).conjugate().triangularView[Eigen.Lower]() * v1, largerEps))
    m3 = m1.triangularView[Eigen.Upper]()
    VERIFY((m3.conjugate() * v1.conjugate()).isApprox(m1.conjugate().triangularView[Eigen.Upper]() * v1.conjugate(), largerEps))
    m3 = m1.triangularView[Eigen.Upper]()
    VERIFY((m3.transpose() * v1).isApprox(m1.transpose().triangularView[Eigen.Lower]() * v1, largerEps))
    m3 = m1.triangularView[Eigen.Lower]()
    VERIFY((m3.transpose() * v1).isApprox(m1.transpose().triangularView[Eigen.Upper]() * v1, largerEps))
    m3 = m1.triangularView[Eigen.UnitUpper]()
    VERIFY((m3.transpose() * v1).isApprox(m1.transpose().triangularView[Eigen.UnitLower]() * v1, largerEps))
    m3 = m1.triangularView[Eigen.UnitLower]()
    VERIFY((m3.transpose() * v1).isApprox(m1.transpose().triangularView[Eigen.UnitUpper]() * v1, largerEps))
    m3 = m1.triangularView[Eigen.Upper]()
    VERIFY((m3.adjoint() * v1).isApprox(m1.adjoint().triangularView[Eigen.Lower]() * v1, largerEps))
    m3 = m1.triangularView[Eigen.Lower]()
    VERIFY((m3.adjoint() * (s1*v1.conjugate())).isApprox(m1.adjoint().triangularView[Eigen.Upper]() * (s1*v1.conjugate()), largerEps))
    m3 = m1.triangularView[Eigen.UnitUpper]()
    m3 = m1.triangularView[Eigen.Lower]()
    VERIFY((v1.transpose() * m3).isApprox(v1.transpose() * m1.triangularView[Eigen.Lower](), largerEps))
    VERIFY((v1.adjoint() * m3).isApprox(v1.adjoint() * m1.triangularView[Eigen.Lower](), largerEps))
    VERIFY((v1.adjoint() * m3.adjoint()).isApprox(v1.adjoint() * m1.triangularView[Eigen.Lower]().adjoint(), largerEps))

def test_product_trmv():
    var s: Int = 0
    for i in range(g_repeat):
        CALL_SUBTEST_1(fn() => trmv[Matrix[Float32, 1, 1]](Matrix[Float32, 1, 1]()))
        CALL_SUBTEST_2(fn() => trmv[Matrix[Float32, 2, 2]](Matrix[Float32, 2, 2]()))
        CALL_SUBTEST_3(fn() => trmv[Matrix3d](Matrix3d()))
        s = internal.random[Int](1, EIGEN_TEST_MAX_SIZE / 2)
        CALL_SUBTEST_4(fn() => trmv[MatrixXcf](MatrixXcf(s, s)))
        CALL_SUBTEST_5(fn() => trmv[MatrixXcd](MatrixXcd(s, s)))
        TEST_SET_BUT_UNUSED_VARIABLE(s)
        s = internal.random[Int](1, EIGEN_TEST_MAX_SIZE)
        CALL_SUBTEST_6(fn() => trmv[Matrix[Float32, Dynamic, Dynamic, RowMajor]](Matrix[Float32, Dynamic, Dynamic, RowMajor](s, s)))
        TEST_SET_BUT_UNUSED_VARIABLE(s)