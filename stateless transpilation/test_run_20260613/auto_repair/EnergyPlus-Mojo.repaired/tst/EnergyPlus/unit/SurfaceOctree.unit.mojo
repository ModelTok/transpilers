from testing import assert_eq, assert_true, assert_false
from Fixtures.EnergyPlusFixture import EnergyPlusFixture
from EnergyPlus.Data.EnergyPlusData import EnergyPlusData
from EnergyPlus.DataSurfaces import SurfaceData, SurfaceShape
from EnergyPlus.SurfaceOctree import SurfaceOctreeCube, Vertex, Surfaces

alias Vertex = SurfaceOctreeCube.Vertex
alias Surfaces = SurfaceOctreeCube.Surfaces

@test
def test_SurfaceOctreeTest_Basic():
    var TotSurfaces: Int = 6
    var surface = SurfaceData()
    surface.Area = 1.0
    surface.Sides = 4
    surface.Vertex = DynamicVector[Vertex](4)
    var Surface = DynamicVector[SurfaceData](TotSurfaces, surface)
    Surface[0].Vertex = DynamicVector[Vertex]([Vertex(0, 0, 0), Vertex(1, 0, 0), Vertex(1, 0, 1), Vertex(0, 0, 1)])
    Surface[1].Vertex = DynamicVector[Vertex]([Vertex(0, 1, 0), Vertex(1, 1, 0), Vertex(1, 1, 1), Vertex(0, 1, 1)])
    Surface[2].Vertex = DynamicVector[Vertex]([Vertex(0, 0, 0), Vertex(0, 1, 0), Vertex(0, 1, 1), Vertex(0, 0, 1)])
    Surface[3].Vertex = DynamicVector[Vertex]([Vertex(1, 0, 0), Vertex(1, 1, 0), Vertex(1, 1, 1), Vertex(1, 0, 1)])
    Surface[4].Vertex = DynamicVector[Vertex]([Vertex(0, 0, 0), Vertex(1, 0, 0), Vertex(1, 1, 0), Vertex(0, 1, 0)])
    Surface[5].Vertex = DynamicVector[Vertex]([Vertex(0, 0, 1), Vertex(1, 0, 1), Vertex(1, 1, 1), Vertex(0, 1, 1)])
    var cube = SurfaceOctreeCube(Surface)
    assert_eq(cube.l(), Vertex(0.0, 0.0, 0.0))
    assert_eq(cube.c(), Vertex(0.5, 0.5, 0.5))
    assert_eq(cube.u(), Vertex(1.0, 1.0, 1.0))
    assert_eq(cube.w(), 1.0)
    # Contains
    assert_true(cube.contains(Vertex(0, 1, 0)))
    assert_false(cube.contains(Vertex(0, 2, 0)))
    assert_true(cube.contains(Surface[0]))
    assert_true(cube.contains(Surface[1]))
    assert_true(cube.contains(Surface[2]))
    assert_true(cube.contains(Surface[3]))
    assert_true(cube.contains(Surface[4]))
    assert_true(cube.contains(Surface[5]))
    var other_surface = surface
    other_surface.Vertex = DynamicVector[Vertex]([Vertex(0, 0, 0), Vertex(1, 0, 0), Vertex(1, 0, 1), 2 * Vertex(0, 0, 1)])
    assert_false(cube.contains(other_surface))
    # X line through center
    var a = Vertex(-1.0, 0.5, 0.5)
    var b = Vertex(2.0, 0.5, 0.5)
    var dir = (b - a).normalize_zero()
    assert_true(cube.segmentIntersectsSphere(a, b))
    assert_true(cube.rayIntersectsSphere(a, dir))
    assert_true(cube.lineIntersectsSphere(a, dir))
    var surfaces = Surfaces()
    cube.surfacesSegmentIntersectsSphere(a, b, surfaces)
    assert_eq(surfaces.size(), 6)
    surfaces.clear()
    cube.surfacesRayIntersectsSphere(a, dir, surfaces)
    assert_eq(surfaces.size(), 6)
    surfaces.clear()
    cube.surfacesLineIntersectsSphere(a, dir, surfaces)
    assert_eq(surfaces.size(), 6)
    surfaces.clear()
    # Diagonal
    a = Vertex(0.0)
    b = Vertex(1.0)
    dir = (b - a).normalize_zero()
    assert_true(cube.segmentIntersectsSphere(a, b))
    assert_true(cube.rayIntersectsSphere(a, dir))
    assert_true(cube.lineIntersectsSphere(a, dir))
    # Center up half-diagonal
    a = Vertex(0.5)
    b = Vertex(2.0)
    dir = (b - a).normalize_zero()
    assert_true(cube.segmentIntersectsSphere(a, b))
    assert_true(cube.rayIntersectsSphere(a, dir))
    assert_true(cube.lineIntersectsSphere(a, dir))
    # Outward at corner
    a = Vertex(1.0)
    b = Vertex(2.0)
    dir = (b - a).normalize_zero()
    assert_true(cube.segmentIntersectsSphere(a, b))
    assert_true(cube.rayIntersectsSphere(a, dir))
    assert_true(cube.lineIntersectsSphere(a, dir))
    # Tangent at origin
    a = Vertex(-1.0 + 1.0e-12, 1.0 + 1.0e-12, 0.0)
    b = Vertex(1.0 + 1.0e-12, -1.0 + 1.0e-12, 0.0)
    dir = (b - a).normalize_zero()
    assert_true(cube.segmentIntersectsSphere(a, b))
    assert_true(cube.rayIntersectsSphere(a, dir))
    assert_true(cube.lineIntersectsSphere(a, dir))
    # Inward outside but pointing to corner
    a = Vertex(3.0)
    b = Vertex(2.0)
    dir = (b - a).normalize_zero()
    assert_false(cube.segmentIntersectsSphere(a, b))
    assert_true(cube.rayIntersectsSphere(a, dir))
    assert_true(cube.lineIntersectsSphere(a, dir))
    # Just beyond corner
    a = Vertex(1.0000001)
    b = Vertex(2.0000002)
    dir = (b - a).normalize_zero()
    assert_false(cube.segmentIntersectsSphere(a, b))
    assert_false(cube.rayIntersectsSphere(a, dir))
    assert_true(cube.lineIntersectsSphere(a, dir))
    # Way outside cube but along diagonal
    a = Vertex(5.0)
    b = Vertex(9.0)
    dir = (b - a).normalize_zero()
    assert_false(cube.segmentIntersectsSphere(a, b))
    assert_false(cube.rayIntersectsSphere(a, dir))
    assert_true(cube.lineIntersectsSphere(a, dir))
    # Way outside cube with no contact
    a = Vertex(9.0)
    b = Vertex(12.0, 8.0, 4.0)
    dir = (b - a).normalize_zero()
    assert_false(cube.segmentIntersectsSphere(a, b))
    assert_false(cube.rayIntersectsSphere(a, dir))
    assert_false(cube.lineIntersectsSphere(a, dir))
    # X line through center (cube)
    a = Vertex(-1.0, 0.5, 0.5)
    b = Vertex(2.0, 0.5, 0.5)
    dir = (b - a).normalize_zero()
    var dir_inv = SurfaceOctreeCube.safe_inverse(dir)
    assert_true(cube.segmentIntersectsCube(a, b))
    assert_true(cube.rayIntersectsCube(a, dir, dir_inv))
    assert_true(cube.lineIntersectsCube(a, dir, dir_inv))
    surfaces.clear()
    cube.surfacesSegmentIntersectsCube(a, b, surfaces)
    assert_eq(surfaces.size(), 6)
    surfaces.clear()
    cube.surfacesRayIntersectsCube(a, dir, dir_inv, surfaces)
    assert_eq(surfaces.size(), 6)
    surfaces.clear()
    cube.surfacesLineIntersectsCube(a, dir, dir_inv, surfaces)
    assert_eq(surfaces.size(), 6)
    # Diagonal (cube)
    a = Vertex(0.0)
    b = Vertex(1.0)
    dir = (b - a).normalize_zero()
    dir_inv = 1.0 / dir
    assert_true(cube.segmentIntersectsCube(a, b))
    assert_true(cube.rayIntersectsCube(a, dir, dir_inv))
    assert_true(cube.lineIntersectsCube(a, dir, dir_inv))
    # Center up half-diagonal (cube)
    a = Vertex(0.5)
    b = Vertex(2.0)
    dir = (b - a).normalize_zero()
    dir_inv = 1.0 / dir
    assert_true(cube.segmentIntersectsCube(a, b))
    assert_true(cube.rayIntersectsCube(a, dir, dir_inv))
    assert_true(cube.lineIntersectsCube(a, dir, dir_inv))
    # Outward at corner (cube)
    a = Vertex(1.0)
    b = Vertex(2.0)
    dir = (b - a).normalize_zero()
    dir_inv = 1.0 / dir
    assert_true(cube.segmentIntersectsCube(a, b))
    assert_true(cube.rayIntersectsCube(a, dir, dir_inv))
    assert_true(cube.lineIntersectsCube(a, dir, dir_inv))
    # Tangent at origin (cube)
    a = Vertex(-1.0 + 1.0e-12, 1.0 + 1.0e-12, 0.0)
    b = Vertex(1.0 + 1.0e-12, -1.0 + 1.0e-12, 0.0)
    dir = (b - a).normalize_zero()
    dir_inv = Vertex(1.0 / dir.x, 1.0 / dir.y, 0.0)
    assert_true(cube.segmentIntersectsCube(a, b))
    assert_true(cube.rayIntersectsCube(a, dir, dir_inv))
    assert_true(cube.lineIntersectsCube(a, dir, dir_inv))
    # Inward outside but pointing to corner (cube)
    a = Vertex(3.0)
    b = Vertex(2.0)
    dir = (b - a).normalize_zero()
    dir_inv = 1.0 / dir
    assert_false(cube.segmentIntersectsCube(a, b))
    assert_true(cube.rayIntersectsCube(a, dir, dir_inv))
    assert_true(cube.lineIntersectsCube(a, dir, dir_inv))
    # Just beyond corner (cube)
    a = Vertex(1.0000001)
    b = Vertex(2.0000002)
    dir = (b - a).normalize_zero()
    dir_inv = 1.0 / dir
    assert_false(cube.segmentIntersectsCube(a, b))
    assert_false(cube.rayIntersectsCube(a, dir, dir_inv))
    assert_true(cube.lineIntersectsCube(a, dir, dir_inv))
    # Way outside cube but along diagonal (cube)
    a = Vertex(5.0)
    b = Vertex(9.0)
    dir = (b - a).normalize_zero()
    dir_inv = 1.0 / dir
    assert_false(cube.segmentIntersectsCube(a, b))
    assert_false(cube.rayIntersectsCube(a, dir, dir_inv))
    assert_true(cube.lineIntersectsCube(a, dir, dir_inv))
    # Way outside cube with no contact (cube)
    a = Vertex(9.0)
    b = Vertex(12.0, 8.0, 4.0)
    dir = (b - a).normalize_zero()
    dir_inv = 1.0 / dir
    assert_false(cube.segmentIntersectsCube(a, b))
    assert_false(cube.rayIntersectsCube(a, dir, dir_inv))
    assert_false(cube.lineIntersectsCube(a, dir, dir_inv))
    # X-axis aligned line through enclosing sphere but not cube
    a = Vertex(-1.0, 1.1, 1.1)
    b = Vertex(2.0, 1.1, 1.1)
    dir = (b - a).normalize_zero()
    assert_true(cube.segmentIntersectsSphere(a, b))
    assert_true(cube.rayIntersectsSphere(a, dir))
    assert_true(cube.lineIntersectsSphere(a, dir))
    assert_false(cube.segmentIntersectsCube(a, b))
    assert_false(cube.rayIntersectsCube(a, dir))
    assert_false(cube.lineIntersectsCube(a, dir))
    surfaces.clear()
    cube.surfacesSegmentIntersectsSphere(a, b, surfaces)
    assert_eq(surfaces.size(), 6)
    surfaces.clear()
    cube.surfacesRayIntersectsSphere(a, dir, surfaces)
    assert_eq(surfaces.size(), 6)
    surfaces.clear()
    cube.surfacesLineIntersectsSphere(a, dir, surfaces)
    assert_eq(surfaces.size(), 6)
    surfaces.clear()
    cube.surfacesSegmentIntersectsCube(a, b, surfaces)
    assert_eq(surfaces.size(), 0)
    surfaces.clear()
    cube.surfacesRayIntersectsCube(a, dir, surfaces)
    assert_eq(surfaces.size(), 0)
    surfaces.clear()
    cube.surfacesLineIntersectsCube(a, dir, surfaces)
    assert_eq(surfaces.size(), 0)

@test
def test_EnergyPlusFixture_Composite():
    var fixture = EnergyPlusFixture()
    var state = fixture.state
    state.dataSurface.TotSurfaces = 12
    var surface = SurfaceData()
    surface.Area = 1.0
    surface.Sides = 4
    surface.Vertex = DynamicVector[Vertex](4)
    state.dataSurface.Surface = DynamicVector[SurfaceData](state.dataSurface.TotSurfaces, surface)
    state.dataSurface.Surface[0].Vertex = DynamicVector[Vertex]([2 * Vertex(0, 0, 0), 2 * Vertex(1, 0, 0), 2 * Vertex(1, 0, 1), 2 * Vertex(0, 0, 1)])
    state.dataSurface.Surface[1].Vertex = DynamicVector[Vertex]([2 * Vertex(0, 1, 0), 2 * Vertex(1, 1, 0), 2 * Vertex(1, 1, 1), 2 * Vertex(0, 1, 1)])
    state.dataSurface.Surface[2].Vertex = DynamicVector[Vertex]([2 * Vertex(0, 0, 0), 2 * Vertex(0, 1, 0), 2 * Vertex(0, 1, 1), 2 * Vertex(0, 0, 1)])
    state.dataSurface.Surface[3].Vertex = DynamicVector[Vertex]([2 * Vertex(1, 0, 0), 2 * Vertex(1, 1, 0), 2 * Vertex(1, 1, 1), 2 * Vertex(1, 0, 1)])
    state.dataSurface.Surface[4].Vertex = DynamicVector[Vertex]([2 * Vertex(0, 0, 0), 2 * Vertex(1, 0, 0), 2 * Vertex(1, 1, 0), 2 * Vertex(0, 1, 0)])
    state.dataSurface.Surface[5].Vertex = DynamicVector[Vertex]([2 * Vertex(0, 0, 1), 2 * Vertex(1, 0, 1), 2 * Vertex(1, 1, 1), 2 * Vertex(0, 1, 1)])
    state.dataSurface.Surface[6].Vertex = DynamicVector[Vertex]([Vertex(0, 0, 0), Vertex(1, 0, 0), Vertex(1, 0, 1), Vertex(0, 0, 1)])
    state.dataSurface.Surface[7].Vertex = DynamicVector[Vertex]([Vertex(0, 1, 0), Vertex(1, 1, 0), Vertex(1, 1, 1), Vertex(0, 1, 1)])
    state.dataSurface.Surface[8].Vertex = DynamicVector[Vertex]([Vertex(0, 0, 0), Vertex(0, 1, 0), Vertex(0, 1, 1), Vertex(0, 0, 1)])
    state.dataSurface.Surface[9].Vertex = DynamicVector[Vertex]([Vertex(1, 0, 0), Vertex(1, 1, 0), Vertex(1, 1, 1), Vertex(1, 0, 1)])
    state.dataSurface.Surface[10].Vertex = DynamicVector[Vertex]([Vertex(0, 0, 0), Vertex(1, 0, 0), Vertex(1, 1, 0), Vertex(0, 1, 0)])
    state.dataSurface.Surface[11].Vertex = DynamicVector[Vertex]([Vertex(0, 0, 1), Vertex(1, 0, 1), Vertex(1, 1, 1), Vertex(0, 1, 1)])
    for i in range(state.dataSurface.TotSurfaces):
        state.dataSurface.Surface[i].Shape = SurfaceShape.Rectangle
    var cube = SurfaceOctreeCube(state.dataSurface.Surface)
    assert_eq(cube.l(), Vertex(0.0, 0.0, 0.0))
    assert_eq(cube.c(), Vertex(1.0, 1.0, 1.0))
    assert_eq(cube.u(), Vertex(2.0, 2.0, 2.0))
    assert_eq(cube.w(), 2.0)
    # X line through outer and inner cube
    var a = Vertex(-1.0, 0.5, 0.5)
    var b = Vertex(3.0, 0.5, 0.5)
    var dir = (b - a).normalize_zero()
    assert_true(cube.segmentIntersectsSphere(a, b))
    assert_true(cube.rayIntersectsSphere(a, dir))
    assert_true(cube.lineIntersectsSphere(a, dir))
    assert_true(cube.segmentIntersectsCube(a, b))
    assert_true(cube.rayIntersectsCube(a, dir))
    assert_true(cube.lineIntersectsCube(a, dir))
    var surfaces = Surfaces()
    cube.surfacesSegmentIntersectsSphere(a, b, surfaces)
    assert_eq(surfaces.size(), 12)
    surfaces.clear()
    cube.surfacesRayIntersectsSphere(a, dir, surfaces)
    assert_eq(surfaces.size(), 12)
    surfaces.clear()
    cube.surfacesLineIntersectsSphere(a, dir, surfaces)
    assert_eq(surfaces.size(), 12)
    surfaces.clear()
    cube.surfacesSegmentIntersectsCube(a, b, surfaces)
    assert_eq(surfaces.size(), 12)
    surfaces.clear()
    cube.surfacesRayIntersectsCube(a, dir, surfaces)
    assert_eq(surfaces.size(), 12)
    surfaces.clear()
    cube.surfacesLineIntersectsCube(a, dir, surfaces)
    assert_eq(surfaces.size(), 12)
    # X line through outer and inner enclosing spheres and outer cube but not inner cube
    a = Vertex(-1.0, 1.1, 1.1)
    b = Vertex(3.0, 1.1, 1.1)
    dir = (b - a).normalize_zero()
    assert_true(cube.segmentIntersectsSphere(a, b))
    assert_true(cube.rayIntersectsSphere(a, dir))
    assert_true(cube.lineIntersectsSphere(a, dir))
    assert_true(cube.segmentIntersectsCube(a, b))
    assert_true(cube.rayIntersectsCube(a, dir))
    assert_true(cube.lineIntersectsCube(a, dir))
    surfaces.clear()
    cube.surfacesSegmentIntersectsSphere(a, b, surfaces)
    assert_eq(surfaces.size(), 12)
    surfaces.clear()
    cube.surfacesRayIntersectsSphere(a, dir, surfaces)
    assert_eq(surfaces.size(), 12)
    surfaces.clear()
    cube.surfacesLineIntersectsSphere(a, dir, surfaces)
    assert_eq(surfaces.size(), 12)
    surfaces.clear()
    cube.surfacesSegmentIntersectsCube(a, b, surfaces)
    assert_eq(surfaces.size(), 6)
    surfaces.clear()
    cube.surfacesRayIntersectsCube(a, dir, surfaces)
    assert_eq(surfaces.size(), 6)
    surfaces.clear()
    cube.surfacesLineIntersectsCube(a, dir, surfaces)
    assert_eq(surfaces.size(), 6)
    # X line through outer but not inner cube
    a = Vertex(-1.0, 1.5, 1.5)
    b = Vertex(3.0, 1.5, 1.5)
    dir = (b - a).normalize_zero()
    assert_true(cube.segmentIntersectsSphere(a, b))
    assert_true(cube.rayIntersectsSphere(a, dir))
    assert_true(cube.lineIntersectsSphere(a, dir))
    assert_true(cube.segmentIntersectsCube(a, b))
    assert_true(cube.rayIntersectsCube(a, dir))
    assert_true(cube.lineIntersectsCube(a, dir))
    surfaces.clear()
    cube.surfacesSegmentIntersectsSphere(a, b, surfaces)
    assert_eq(surfaces.size(), 6)
    surfaces.clear()
    cube.surfacesRayIntersectsSphere(a, dir, surfaces)
    assert_eq(surfaces.size(), 6)
    surfaces.clear()
    cube.surfacesLineIntersectsSphere(a, dir, surfaces)
    assert_eq(surfaces.size(), 6)
    surfaces.clear()
    cube.surfacesSegmentIntersectsCube(a, b, surfaces)
    assert_eq(surfaces.size(), 6)
    surfaces.clear()
    cube.surfacesRayIntersectsCube(a, dir, surfaces)
    assert_eq(surfaces.size(), 6)
    surfaces.clear()
    cube.surfacesLineIntersectsCube(a, dir, surfaces)
    assert_eq(surfaces.size(), 6)
    # Hits cube but predicate never satisfied
    a = Vertex(-1.0, 0.5, 0.5)
    b = Vertex(3.0, 0.5, 0.5)
    dir = (b - a).normalize_zero()
    var predicate = fn(surface: SurfaceData) -> Bool: return surface.Shape == SurfaceShape.Triangle
    assert_false(cube.hasSurfaceSegmentIntersectsCube(a, b, predicate))
    assert_false(cube.hasSurfaceRayIntersectsCube(a, dir, predicate))
    # Hits cube and predicate satisfied
    predicate = fn(surface: SurfaceData) -> Bool: return surface.Shape == SurfaceShape.Rectangle
    assert_true(cube.hasSurfaceSegmentIntersectsCube(a, b, predicate))
    assert_true(cube.hasSurfaceRayIntersectsCube(a, dir, predicate))
    # Misses cube so predicate never tested
    a = Vertex(-1.0, 3.0, 3.0)
    b = Vertex(3.0, 3.0, 3.0)
    dir = (b - a).normalize_zero()
    predicate = fn(surface: SurfaceData) -> Bool: return surface.Shape == SurfaceShape.Rectangle
    assert_false(cube.hasSurfaceSegmentIntersectsCube(a, b, predicate))
    assert_false(cube.hasSurfaceRayIntersectsCube(a, dir, predicate))
    # Hits cube: find max vertices in a surface
    a = Vertex(-1.0, 0.5, 0.5)
    b = Vertex(3.0, 0.5, 0.5)
    dir = (b - a).normalize_zero()
    var n: UInt = 0
    var function = fn(surface: SurfaceData): n = max(n, surface.Vertex.size())
    cube.processSurfaceRayIntersectsCube(a, dir, function)
    assert_eq(n, 4)
    # Hits cube: find number of surfaces but no higher than 8
    a = Vertex(-1.0, 0.5, 0.5)
    b = Vertex(3.0, 0.5, 0.5)
    dir = (b - a).normalize_zero()
    n = 0
    predicate = fn(surface: SurfaceData) -> Bool:
        n += 1
        return n >= 8
    cube.processSomeSurfaceRayIntersectsCube(state, a, dir, predicate)
    assert_eq(n, 8)