        var VBMatNum: Int = Material.GetMaterialNum(*state, "VBU8D6+45SW1")
        var matVenetBlind = state.dataMaterial.materials[VBMatNum - 1] as Material.MaterialBlindEQL
        CalcEQLOpticalProperty(*state, SurfNum, DataWindowEquivalentLayer.SolarArrays.BEAM, AbsSolBeam)
        EXPECT_EQ(static_cast[Int](matVenetBlind.slatAngleType), state.dataWindowEquivalentLayer.lscVBPROF)
        EXPECT_NEAR(-71.0772, state.dataSurface.surfShades[SurfNum - 1].blind.slatAngDeg, 0.0001)
        ProfAngVer = Dayltg.ProfileAngle(*state, SurfNum, state.dataEnvrn.SOLCOS, DataWindowEquivalentLayer.Orientation.Horizontal)
        EXPECT_NEAR(-Constant.RadToDeg * ProfAngVer, state.dataSurface.surfShades[SurfNum - 1].blind.slatAngDeg, 0.0001)

