            "    836.8000,                !- Specific Heat {J/kg-K}",
            "    0.9000000,               !- Thermal Absorptance",
            "    0.7600000,               !- Solar Absorptance",
            "    0.7600000;               !- Visible Absorptance",
            "  Material,",
            "    E1 - 3 / 4 IN PLASTER OR GYP BOARD,  !- Name",
            "    Smooth,                  !- Roughness",
