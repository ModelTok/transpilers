            "    0.7264224,               !- Conductivity {W/m-K}",
            "    1601.846,                !- Density {kg/m3}",
            "    836.8000,                !- Specific Heat {J/kg-K}",
            "    0.9000000,               !- Thermal Absorptance",
            "    0.9200000,               !- Solar Absorptance",
            "    0.9200000;               !- Visible Absorptance",
            "  Construction,",
            "    EXTWALL80,               !- Name",
            "    A1 - 1 IN STUCCO,        !- Outside Layer",
