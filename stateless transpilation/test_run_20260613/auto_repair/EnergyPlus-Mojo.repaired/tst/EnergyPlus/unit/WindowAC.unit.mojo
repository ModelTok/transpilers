        ])
        ASSERT_TRUE(process_idf(idf_objects))
        state.init_state(state) # must initialize this to get schedules initialized
        errorsFound = False
        HeatBalanceManager.GetProjectControlData(state, errorsFound) # read project control data
        EXPECT_FALSE(errorsFound)
        state.dataGlobal.DDOnlySimulation = True
        SimulationManager.GetProjectData(state)
        HeatBalanceManager.SetPreConstructionInputParameters(state) # establish array bounds for constructions early
        state.dataGlobal.BeginSimFlag = True
        state.dataGlobal.BeginEnvrnFlag = True
        state.dataGlobal.ZoneSizingCalc = True
        EnergyPlus.createFacilityElectricPowerServiceObject(state)
        SizingManager.ManageSizing(state)
        SimulationManager.SetupSimulation(state, errorsFound)
        qDotMet = 0.0    # Watts total cap
        lDotProvid = 0.0 # latent removal kg/s
        compIndex = 0
        WindowAC.SimWindowAC(state, "ZONE1WINDAC", 1, True, qDotMet, lDotProvid, compIndex)
        EXPECT_EQ(compIndex, 1)
        expected_full_airflow = 0.041484382187390034
        scaler_cooling_saf = 0.5
        scaler_cooling_cap = 0.5
        expected_full_cap = 622.50474573886743
        windowAC = state.dataWindowAC.WindAC[compIndex - 1]
        ASSERT_GT(windowAC.FanIndex, 0)
        fan = state.dataFans.fans[windowAC.FanIndex - 1]
        finalZoneSizing = state.dataSize.FinalZoneSizing[1 - 1]
        EXPECT_NEAR(expected_full_airflow, finalZoneSizing.DesCoolVolFlow, 0.0001)
        ASSERT_GT(windowAC.HVACSizingIndex, 0)
        zoneHVACSizing = state.dataSize.ZoneHVACSizing[windowAC.HVACSizingIndex - 1]
        EXPECT_EQ(FractionOfAutosizedCoolingAirflow, zoneHVACSizing.CoolingSAFMethod)
        EXPECT_EQ(scaler_cooling_saf, zoneHVACSizing.MaxCoolAirVolFlow)
        EXPECT_EQ(FractionOfAutosizedCoolingCapacity, zoneHVACSizing.CoolingCapMethod)
        EXPECT_EQ(scaler_cooling_cap, zoneHVACSizing.ScaledCoolingCapacity)
        EXPECT_ENUM_EQ(windowAC.coilType, CoilType.CoolingDXVariableSpeed)
        ASSERT_GT(windowAC.DXCoilIndex, 0)
        varSpeedCoil = state.dataVariableSpeedCoils.VarSpeedCoil[windowAC.DXCoilIndex - 1]
        EXPECT_NEAR(expected_full_airflow * scaler_cooling_saf, windowAC.MaxAirVolFlow, 0.0001)
        EXPECT_NEAR(expected_full_airflow * scaler_cooling_saf, fan.maxAirFlowRate, 0.0001)
        EXPECT_NEAR(622.505, varSpeedCoil.RatedCapCoolTotal, 0.001)
        vsd_coil_norm_speed_tot_cap = 36991.44197 # Speed 1 Reference Unit Gross Rated Total Cooling Capacity {w}
        vsd_coil_norm_speed_airflow = 3.776       # Speed 1 Reference Unit Gross Rated Cooling COP {dimensionless}
        vsd_coil_norm_speed_airflow_per_cap = vsd_coil_norm_speed_airflow / vsd_coil_norm_speed_tot_cap
        EXPECT_NEAR(vsd_coil_norm_speed_airflow_per_cap, varSpeedCoil.MSRatedAirVolFlowPerRatedTotCap[1 - 1], 0.0001)
        EXPECT_NEAR(expected_full_cap * vsd_coil_norm_speed_airflow_per_cap, varSpeedCoil.RatedAirVolFlowRate, 0.0001)
        state.dataZoneEnergyDemand.ZoneSysEnergyDemand[1 - 1].RemainingOutputReqToCoolSP = -295.0
        state.dataZoneEnergyDemand.CurDeadBandOrSetback[1 - 1] = False
        WindowAC.SimWindowAC(state, "ZONE1WINDAC", 1, True, qDotMet, lDotProvid, compIndex)
        EXPECT_NEAR(-295.0, qDotMet, 0.1)
        EXPECT_EQ("0.0", RetrievePreDefTableEntry(state, state.dataOutRptPredefined.pdchZnHtCalcDesLd, "WEST ZONE"))
        EXPECT_EQ("0.0", RetrievePreDefTableEntry(state, state.dataOutRptPredefined.pdchZnHtCalcDesAirFlow, "WEST ZONE"))
        EXPECT_EQ("0.0", RetrievePreDefTableEntry(state, state.dataOutRptPredefined.pdchZnHtUserDesAirFlow, "WEST ZONE"))
        EXPECT_EQ("N/A", RetrievePreDefTableEntry(state, state.dataOutRptPredefined.pdchZnHtDesDay, "WEST ZONE"))
        EXPECT_EQ("N/A", RetrievePreDefTableEntry(state, state.dataOutRptPredefined.pdchZnHtPkTime, "WEST ZONE"))