def assert_near(actual: Float64, expected: Float64, tol: Float64):
    if abs(actual - expected) > tol:
        print("Assertion failed: actual=", actual, " expected=", expected, " tol=", tol)
        raise Error("assert_near")

def assert_true(condition: Bool):
    if not condition:
        print("Assertion failed: expected true")
        raise Error("assert_true")

def assert_false(condition: Bool):
    if condition:
        print("Assertion failed: expected false")
        raise Error("assert_false")

def assert_eq[T: EqualityComparable](actual: T, expected: T):
    if actual != expected:
        print("Assertion failed: actual=", actual, " expected=", expected)
        raise Error("assert_eq")

def assert_throw[T: Callable](fn: T, error_type: type):
    # Simplified: just call and assume it throws
    try:
        fn()
        print("Expected throw but no exception")
        raise Error("assert_throw")
    except:

