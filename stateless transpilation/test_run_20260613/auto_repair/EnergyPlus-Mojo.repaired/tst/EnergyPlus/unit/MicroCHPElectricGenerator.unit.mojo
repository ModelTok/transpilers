    assert_true(process_idf(idf_objects))
    state.init_state(state)
    state.dataPlnt.TotNumLoops = 1
    state.dataPlnt.PlantLoop.resize(1)
    state.dataPlnt.PlantLoop[0].glycol = Fluid.GetWater(state)
    state.dataPlnt.PlantLoop[0].LoopSide[DataPlant.LoopSideLocation.Demand].Branch.resize(2)
    state.dataPlnt.PlantLoop[0].LoopSide[DataPlant.LoopSideLocation.Demand].TotalBranches = 2
    state.dataPlnt.PlantLoop[0].LoopSide[DataPlant.LoopSideLocation.Demand].Branch[0].TotalComponents = 1
    state.dataPlnt.PlantLoop[0].LoopSide[DataPlant.LoopSideLocation.Demand].Branch[1].TotalComponents = 1
    state.dataPlnt.PlantLoop[0].LoopSide[DataPlant.LoopSideLocation.Demand].Branch[0].Comp.resize(1)
    state.dataPlnt.PlantLoop[0].LoopSide[DataPlant.LoopSideLocation.Demand].Branch[1].Comp.resize(1)
    state.dataPlnt.PlantLoop[0].FluidName = "WATER"
    var MicroCHP1_ptr = Pointer.address_of(state.dataPlnt.PlantLoop[0].LoopSide[DataPlant.LoopSideLocation.Demand].Branch[0].Comp[0])
    var MicroCHP2_ptr = Pointer.address_of(state.dataPlnt.PlantLoop[0].LoopSide[DataPlant.LoopSideLocation.Demand].Branch[1].Comp[0])
    MicroCHP1_ptr[].TypeOf = "GENERATOR:MICROCHP"
    MicroCHP1_ptr[].Type = DataPlant.PlantEquipmentType.Generator_MicroCHP
    MicroCHP1_ptr[].Name = "MICROCOGEN1"
    MicroCHP2_ptr[].TypeOf = "GENERATOR:MICROCHP"
    MicroCHP2_ptr[].Type = DataPlant.PlantEquipmentType.Generator_MicroCHP
    MicroCHP2_ptr[].Name = "MICROCOGEN2"
    MicroCHP1_ptr[].compPtr = MicroCHPElectricGenerator.MicroCHPDataStruct.factory(state, "MICROCOGEN1")
    MicroCHP2_ptr[].compPtr = MicroCHPElectricGenerator.MicroCHPDataStruct.factory(state, "MICROCOGEN2")
    assert_eq(state.dataCHPElectGen.NumMicroCHPs, 2)
    var FirstHVACIteration = True
    var GetCompSizFac = False
    var microCHPData1 = MicroCHP1_ptr[].compPtr as MicroCHPElectricGenerator.MicroCHPDataStruct
    var microCHPData2 = MicroCHP2_ptr[].compPtr as MicroCHPElectricGenerator.MicroCHPDataStruct
    microCHPData1.InitMicroCHPNoNormalizeGenerators(state)
    microCHPData2.InitMicroCHPNoNormalizeGenerators(state)
    MicroCHP1_ptr[].initLoopEquip(state, GetCompSizFac)
    MicroCHP1_ptr[].simulate(state, FirstHVACIteration)
    MicroCHP2_ptr[].initLoopEquip(state, GetCompSizFac)
    MicroCHP2_ptr[].simulate(state, FirstHVACIteration)
    assert_eq(state.dataGenerator.GeneratorDynamics[0].Name, MicroCHP1_ptr[].Name)
    assert_eq(state.dataGenerator.GeneratorDynamics[1].Name, MicroCHP2_ptr[].Name)