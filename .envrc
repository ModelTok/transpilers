# direnv config. Activates the uv-managed virtualenv on `cd`. Run `direnv allow`
# once after cloning. Falls back to `uv sync` if .venv is missing.

if ! has uv; then
    echo "[direnv] uv not installed — see https://docs.astral.sh/uv/" >&2
    return 1
fi

if [[ ! -d .venv ]]; then
    echo "[direnv] .venv missing — running 'uv sync'..." >&2
    uv sync >&2
fi

export VIRTUAL_ENV="$PWD/.venv"
PATH_add "$VIRTUAL_ENV/bin"
